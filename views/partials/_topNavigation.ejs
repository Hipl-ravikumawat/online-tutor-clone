<div class="top_nav">
  <div class="nav_menu">
    <div class="nav toggle">
      <a id="menu_toggle"><i class="fa fa-bars"></i></a>
    </div>
    <nav class="nav navbar-nav">
      <ul class=" navbar-right">
        <li class="nav-item dropdown open">
          <a href="javascript:;" class="message-drop" id="navbarDropdown1" data-toggle="dropdown" aria-expanded="false" title="Notification">
            <i class="fa fa-bell-o"></i>
          </a>
          <ul class="dropdown-menu" role="menu" aria-labelledby="navbarDropdown1">
            <li class="nav-item">
              <a class="dropdown-item">
                <strong>See All Alerts</strong>
                <i class="fa fa-angle-right"></i>
              </a>
            </li>
          </ul>
          </li>
        <li class="nav-item dropdown open">
          <a href="javascript:;" class="user-profile dropdown-toggle" aria-haspopup="true" id="navbarDropdown"
            data-toggle="dropdown" aria-expanded="false" title="Profile">

            <img src="<%=loggedUserInfo.profile_image !='' && fs.existsSync('assets/ProfileImage/'+loggedUserInfo.profile_image) ? '/ProfileImage/'+loggedUserInfo.profile_image:'/images/noImage.jpg'%>" alt="profile_image">
          
            <span class="active-status"></span>
            <p>
              <span class="wel-text">Welcome</span>
              <span class="name-text"><%= loggedUserInfo.first_name !='' ? loggedUserInfo.first_name+' '+loggedUserInfo.last_name : '' %></span>
            </p>
          </a>
          <div class="dropdown-menu dropdown-usermenu pull-right" aria-labelledby="navbarDropdown">
            <a class="dropdown-item profile"  href="/profile"><p>Profile</p></a>
            <% if(loggedUserInfo.role == 2){%>
              <a class="dropdown-item profile"  href="/tutor-preferences/<%=loggedUserInfo._id%>"><p>My Preferences</p> </a>
            <% } if(loggedUserInfo.role == 1) { %>
            <a class="dropdown-item profile"  href="/business-settings"><p>Business Settings</p> </a>
            <% } if(secretLoginFlag){ %>
            <a class="dropdown-item logout" onclick="confirmBeforeLogout('/exitsecret/<%=loggedUserInfo._id%>',2)" href="javascript:void(0)"><i class="fa fa-sign-out pull-right"></i><p>Exit</p></a>
            <% } else { %> 
            <a class="dropdown-item logout" href="javascript:void(0)" onclick="confirmBeforeLogout('/logout',1)"><i class="fa fa-sign-out pull-right"></i> <p>Log Out</p></a>
            <% } %>
          </div>
        </li>
      </ul>
    </nav>
  </div>
