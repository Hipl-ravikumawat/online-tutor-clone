                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!-- Send Email Invoice Modal -->
    <div class="modal fade common-modal" data-backdrop="static" id="sendEmailInvoice" tabindex="-1" role="dialog" aria-labelledby="sendEmailInvoiceLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-centered max-928 normal_form_block" role="document">
        <div class="modal-content form-wizard">
          <div class="modal-header">
            <h3 class="modal-title title_style" id="sendEmailInvoiceLabel">Send Email Invoice</h3>
            <button type="button" class="close p-0 m-0 opacity-100" data-dismiss="modal" aria-label="Close">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M18 6L6 18" stroke="#4A4674" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M6 6L18 18" stroke="#4A4674" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <form class="form-design" method="post">
            <input type="hidden" name="invoiceId" id="invoiceIdField" />
            <div class="modal-body form_normal settings_content">
              <div class="form-group">
                <label for="from_mail" class="form-label">From</label>
                <select multiple name="from_mail" id="from_mail" class="form-control select2">
                  <% sentFrom.forEach(function(user, index) { %>
                    <option value="<%= user.value %>" <%= index === 0 ? 'selected' : '' %>>
                      <%= user.label %>
                    </option>
                  <% }); %>
                </select>
                 <div class="text-danger error-message" id="error-from_mail"></div>
              </div>
              <div class="form-group ">
                <label for="to_mail" class="form-label">To</label>
                <div id="to_mail_wrapper" class="select-box-user">
                  <select name="to_mail" id="to_mail" class="form-control select2"></select>
                  <div class="text-danger error-message" id="error-to_mail"></div>
                </div>
                <p class="select-comma-user" style="display: none;"></p>
                <div id="to_mail_summary" class="mt-2" style="display: none;"></div>
              </div>
              <div class="form-group form-check">
                <input class="form-check-input" type="checkbox" value="1" id="bcc_email" name="bcc_email">
                <label class="form-check-label" for="bcc_email">BCC me on this Email</label>
              </div>
              <div class="mb-3">
                <label class="form-label">Template</label>
                <div class="row">
                  <div class="col-md-6">
                    <div class="radio_group form-check form-check-inline w-100 m-0">
