                                    <li class="both-btnli">
                                        <div class="dropdown short_dropdown" id="transactions-sort-dropdown">
                                            <button class="bus-outline-btn dropdown-toggle" type="button" data-toggle="dropdown"  aria-expanded="false">
                                                <img src="/images/short-icon.svg" alt="Setting"  class="mr-2">Sort</button>

                                            <div class="dropdown-menu">
                                                <button type="button" class="dropdown-item shortbtn sort-trigger" data-column="">Clear Sort</button>
                                                <button type="button" class="dropdown-item sort-trigger" data-column-name="date" data-column="0" data-order="1" >Date</button>
                                            </div>
                                        </div>
                                    </li>
                                    <li class="search_box searchDropdownCount both-btnli search_btn" id="familyTransactionDropdown">
                                        <div class="dropdown">
                                            <button class="bus-outline-btn dropdown-toggle" type="button" data-toggle="dropdown" aria-expanded="false">
                                                <img src="/images/search-icon.svg" alt="Search" class="mr-2">
                                                Search
                                                <span class="sounts" style="display: none;"></span>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-area dropdown-menu-right">
                                            <form id="familyTransactionSearchForm">
                                                <div class="position-relative form-group">
                                                    <input type="search" name="category_search" class="form-control" placeholder="Search by category or description..." />
                                                    <img src="/images/search-icon.svg" alt="Search" class="search_drop_icon">
                                                </div>
                                                <div class="form-group position-relative flaticon mb-0 mt-20">
                                                    <label label="" for="amount_search" class="form-label">By Charges or Payments</label>
                                                    <input type="number" class="pl-40 w-100" id="amount_search" name="amount_search" placeholder="0.00">
                                                    <span class="input-icon"><i class="<%= currency.icon || 'fa fa-dollar' %>" aria-hidden="true"></i></span>
                                                </div>
                                                <div class="form-group form-check mt-20 mb-20">
                                                    <input class="form-check-input" type="checkbox" value="1" id="show_zero_entries" name="show_zero_entries">
                                                    <label class="form-check-label" for="show_zero_entries">Show <%= currency.symbol %>0.00 Entries</label>
                                                </div>
                                                <div class="d-flex mt-20">
                                                    <button type="button" class="btn form-button cancel-btn theme-btn cancel-event mr-3 w-100">Clear</button>
                                                    <button type="submit" class="btn theme-btn w-100">Search</button>
                                                </div>
                                            </form>
                                            </div>
                                        </div>
                                    </li>
                                </ul>
                                <div class="clearfix"></div>
                            </div>
                            <div class="x_content">
                                <div class="card-box table-responsive allselect-table">
                                    <table id="familyTransactionsTable"
                                        class="table table-striped table-bordered dt-responsive nowrap"
                                        cellspacing="0" width="100%">
                                        <thead>
                                            <tr>
                                                <th class="date">Date</th>
                                                <th>Student</th>
                                                <th>Description</th>
                                                <th>Charges & Discounts</th>
                                                <th>Payments & Refunds</th>
                                                <th>Balance</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Invoices Tab -->
                    <div class="tab-pane fade" id="invoices" role="tabpanel"
                        aria-labelledby="pills-invoices-tab">
                        <div class="x_panel">
                            <div class="x_title">
                                <!-- <% if(loggedUserInfo.role != 3) { %>
                                    <div class="left-btns">
                                        <ul>
                                            <li>
                                                <a href="/families-invoices/add-invoice-details/<%= student._id %>" class="btn theme-btn" data-toggle="tooltip" rel="tooltip" data-placement="top"
                                                    title="New Invoice">+ New
                                                    Invoice</a>
                                            </li>
                                            <li class="both-btnli">
                                                <div class="dropdown">
                                                    <button class="bus-outline-btn dropdown-toggle" type="button" data-toggle="dropdown"
                                                        aria-expanded="false"><img src="/images/options-icon.svg" alt="Options"
                                                            class="mr-2">Options</button>
                                                    <div class="dropdown-menu">
                                                        <button type="button" class="dropdown-item">Download Selected
                                                            Invoices</button>
                                                        <button type="button" class="dropdown-item">Download Invoice
                                                            Details</button>
                                                        <button type="button" class="dropdown-item">Archive</button>
                                                        <button type="button" class="dropdown-item">Unarchive</button>
                                                        <button type="button" class="dropdown-item">Delete</button>
                                                    </div>
                                                </div>
                                            </li>
                                        </ul>
                                    </div>
                                <% } %> -->
                                <% if(loggedUserInfo.role != 3) { %>
                                    <div class="left-btns">
                                        <ul>
                                            <li>
                                                <a href="/families-invoices/add-invoice-details/<%= student._id %>" class="btn theme-btn" data-toggle="tooltip" rel="tooltip" data-placement="top"
                                                    title="New Invoice">+ New Invoice</a>
                                            </li>
                                        
                                            <li class="both-btnli">
                                                <div class="dropdown">
                                                    <button class="bus-outline-btn dropdown-toggle action-btn" type="button" data-toggle="dropdown"
                                                        aria-expanded="false" disabled>
                                                        <img src="/images/options-icon.svg" alt="Options" class="mr-2">Options
                                                    </button>
                                                    <div class="dropdown-menu">
                                                        <button type="button" class="dropdown-item download-selected">Download Selected Invoices</button>
                                                        <button type="button" class="dropdown-item download-invoice-details">Download Invoice Details</button>
                                                        <button type="button" class="dropdown-item archive-action" data-action="archive">Archive</button>
                                                        <button type="button" class="dropdown-item archive-action" data-action="unarchive">Unarchive</button>
                                                        <button type="button" class="dropdown-item delete-invoice">Delete</button>
                                                    </div>
                                                </div>
                                            </li>
                                        </ul>
                                    </div>
                                <% } %>
                                <ul class="right-btns settings_content">
                                    <li class="both-btnli">
                                        <div class="dropdown select_all_dropdown" id="invoice-colvis-dropdown">
                                            <button class="bus-outline-btn dropdown-toggle" type="button" data-toggle="dropdown"
                                                aria-expanded="false">
                                                <img src="/images/columns-icon.svg" alt="Email" class="mr-2">Columns
                                            </button>
                                            <div class="dropdown-menu">
                                                <div class="dropdown-item">
                                                    <label><input type="checkbox" class="select-all custom-colvis show-all" data-column="all" /><span></span>Show All</label>
                                                </div>
                                                <div class="dropdown-item">
                                                    <label><input type="checkbox" class="show-default custom-colvis" data-column="default" /><span></span>Show Default</label>
                                                </div>
                                                <hr style="margin:0;" />
                                                <div class="dropdown-item">
                                                    <label><input type="checkbox" class="column-checkbox custom-colvis" data-column="due-date" data-column-index="3" /><span></span>Due
                                                        Date</label>
                                                </div>
                                                <div class="dropdown-item">
                                                    <label><input type="checkbox" class="column-checkbox custom-colvis" data-column="invoice-number" data-column-index="2" /><span></span>Invoice #</label>
                                                </div>
                                                <div class="dropdown-item">
                                                    <label><input type="checkbox" class="column-checkbox custom-colvis" data-column="private-note" data-column-index="5" /><span></span>Private Note</label>
                                                </div>
                                            </div>
                                        </div>
                                    </li>
                                    <li class="both-btnli">
                                        <div class="dropdown short_dropdown" id="invoices-sort-dropdown">
                                            <button class="bus-outline-btn dropdown-toggle" type="button" data-toggle="dropdown"
                                                aria-expanded="false"><img src="/images/short-icon.svg" alt="Setting" class="mr-2">Sort</button>
                                            <div class="dropdown-menu">
                                                <button type="button" class="dropdown-item shortbtn sort-trigger" data-column="">Clear Sort</button>
                                                <button type="button" class="dropdown-item sort-trigger" data-column-name="invoice_amount" data-column="6" data-order="1">Invoice Amount</button>
                                                <button type="button" class="dropdown-item sort-trigger" data-column-name="invoice_date" data-column="1" data-order="1">Invoice Date</button>
                                            </div>
                                        </div>
                                    </li>

                                    <li class="search_box searchDropdownCount both-btnli search_btn" id="invoicesDropdown">
                                        <div class="dropdown">
                                            <button class="bus-outline-btn dropdown-toggle" type="button" data-toggle="dropdown" aria-expanded="false">
                                                <img src="/images/search-icon.svg" alt="Search" class="mr-2">
                                                Search
                                                <span class="sounts"></span>
                                            </button>
                                            <div class="dropdown-menu dropdown-menu-area dropdown-menu-right">
                                                <form id="invoicesSearchForm">
                                                    <div class="position-relative form-group">
                                                        <input type="search" class="form-control" id="family_or_invoice_number" name="family_or_invoice_number" placeholder="Family or invoice number..." />
                                                        <img src="/images/search-icon.svg" alt="Search" class="search_drop_icon">
                                                    </div>
                                                    <div class="form-group form-check mt-20 mb-20">
                                                        <input class="form-check-input search-input" type="checkbox" value="1" id="filter_invoice_date" name="filter_invoice_date" />
                                                        <label class="form-check-label" for="filter_invoice_date">Filter By Invoice Date</label>
                                                    </div>
                                                    <div class="form-group position-relative mb-0">
                                                        <label label="" for="date_range_block" class="form-label">Date Range <span class="text-muted small">(Optional)</span></label>
                                                        <input type="text" name="date_range_block" id="date_range_block" class="pl-40 w-100" disabled />
                                                        <span class="input-icon"><img src="/images/date-icon.svg" alt="date-icon"></span>
                                                    </div>
                                                    <div class="mt-20 mb-20">
                                                        <div class="form-group form-check mb-2">
                                                            <input class="form-check-input search-input" type="checkbox" value="0" id="hide_emailed" name="hide_emailed" />
