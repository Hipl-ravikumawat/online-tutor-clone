                                <div class="card-box allselect-table">
                                    <table id="familyInvoiceTable" class="table table-striped table-bordered dt-responsive checkbox_alignment" cellspacing="0" width="100%">
                                        <thead>
                                            <tr>
                                            <th style="text-align: center"><input type="checkbox" id="family_select_all" /></th>
                                            <th class="invoice-date">Invoice Date</th>
                                            <th class="invoice-number">Invoice #</th>
                                            <th class="due-date">Due Date</th>
                                            <th class="date-range">Date Range</th>
                                            <th class="private-note">Private Note</th>
                                            <th class="invoice-amount">Invoice Amount</th>
