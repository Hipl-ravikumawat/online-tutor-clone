<script>
    function toggleActionButtons(tableId,section) {
        const anyChecked = $(`#${tableId} tbody input[type="checkbox"]:checked`).length > 0;
        $(`#${section} .action-btn`).prop('disabled', !anyChecked);
    }

    $(document).ready(function () {
        $('.download-btn').click(function () {
            const txnId = $(this).data('txn-id');
            const element = document.getElementById(`pdf-content-${txnId}`);

            // Temporarily make the content visible
            element.style.visibility = 'visible';
            element.style.position = 'relative';
            element.style.height = 'auto';

            const options = {
                margin: 0.3,
                filename: `payment-${txnId}.pdf`,
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2 },
                jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' }
            };

            html2pdf().set(options).from(element).save().then(() => {
                // Hide it again after PDF is created
                element.style.visibility = 'hidden';
                element.style.position = 'absolute';
                element.style.height = '0';
            });
        });
    });
</script>

