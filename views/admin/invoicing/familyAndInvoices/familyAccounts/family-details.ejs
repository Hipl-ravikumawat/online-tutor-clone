<div class="right_col mt-sm-3" role="main">
    <div class="bussniess_setting">
        <% if(loggedUserInfo.role != 3) { %>
        <a class="back-link" href="/families-invoices#FamilyAccounts"><span class="fa fa-chevron-left mr-2"></span>Back to family & invoices</a>
        <div class="drop-down my-3 family_in_dropdown">
            <div class="selected">
                <a href="javascript:void(0)" class="item-selected">
                    <% const activeFamily = familySets.find(set=> set._id.toString() === student._id.toString()); %>
                        <%= activeFamily ? (activeFamily.familyNames || activeFamily.studentName) : " Select Family" %>
                </a>
            </div>
            <div class="drop-options" style="display: none;">
                <ul>
                    <%
                    if(familySets){ 
                        familySets.forEach(set=> { %>
                            <li>
                               <a href="<%= loggedUserInfo.role != 3 ? '/families-invoices/family/' + set._id : 'javascript:void(0)' %>"
                                class="<%= student._id.toString() === set._id.toString() ? 'active' : '' %>">
                                <%= set.familyNames || set.studentName %>
                                </a>
                            </li>
                        <% })
                    } %>
                </ul>
            </div>
        </div>
        <% } %>
        <div class=" row row-gap-30">
            <div class="col-xl-3 col-lg-4">
                <div class="card">
                    <div class="card-body">
                        <h2 class="title-text mb-4">Family Details</h2>

                        <div class="family_card">
                            <div class="f_card_top">
                                <h6>Students</h6>
                                <% if (student) { %>
                                    <span class="f_status 
                                        <%= student.status == 0 ? 'f_inactive' : 
                                        student.status == 1 ? 'f_active' : 
                                        student.status == 2 ? 'f_trial' : 
                                        student.status == 3 ? 'f_waiting' : 'f_inactive' %>">
                                        <%= student.status == 0 ? 'Deactive' : 
                                        student.status == 1 ? 'Active' : 
                                        student.status == 2 ? 'Trial' : 
                                        student.status == 3 ? 'Waiting' : 'Unknown' %>
                                    </span>
                                <% } %>
                            </div>
                            <div class="f_card_body">
                                <ul class="f_detail_link_area">
                                    <li>
                                        <a href="<%= loggedUserInfo.role != 3 ? '/student-preferences/' + student._id : 'javascript:void(0)' %>"
                                            class="f_detail_link">
                                            <%= ucwords(student?.studentName) || '' %>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <div class="family_card mt-3">
                            <div class="f_card_top">
                                <h6>Family Contacts</h6>
                            </div>
                            <div class="f_card_body">
                                <ul class="f_detail_link_area">
                                    <!-- student name as first family contact -->
                                    <li>
                                        <a href="<%= loggedUserInfo.role != 3 ? '/student-preferences/' + student._id : 'javascript:void(0)' %>"
                                            class="f_detail_link">
                                            <%= ucwords(student.studentName) %>
                                        </a>
                                        
                                    </li>
                                     <!-- family contacts -->
                                    <% if(contacts){ 
                                        contacts.forEach(contact=> { %>
                                        <li>
                                            <a href="<%= loggedUserInfo.role != 3 ? '/student-preferences/' + student._id : 'javascript:void(0)' %>"
                                                class="f_detail_link">
                                                <%= ucwords(contact.full_name) %>
                                            </a>
                                            <% if(contact.isInvoiceRecipient){ %>
                                                <!-- <span class="f_status">Invoice Recipient</span> -->
                                                <p class="f_status">Invoice Recipient</p>
                                            <% } %>
                                        </li>
                                        <% })
                                    } %>
                                    
                                </ul>
                            </div>
                        </div>

                        <% if (autoInvoiceDisplay) { %>
                            <div class="family_card mt-3">
                                <div class="f_card_top">
                                    <h6>Next Invoice</h6>
                                </div>
                                <div class="f_card_body">
                                    <p><b>Invoice Date:</b> <%= autoInvoiceDisplay.nextInvoiceDate %></p>
                                    <p><b>Date Range:</b> <%= autoInvoiceDisplay.billingRange %></p>
                                    <p><b>Total Due:</b> <%= currency.symbol %><%= Math.abs(finalBalance) %> Balance Owing</p>
                                </div>
                            </div>
                            <div class="family_card mt-3">
                                <div class="f_card_top">
                                    <h6>Auto-Invoice Settings</h6>
                                </div>
                                <div class="f_card_body">
                                    <p><%= autoInvoiceDisplay.invoiceFor %></p>
                                    <p><b>Repeats:</b> <%= autoInvoiceDisplay.repeatRule %></p>
                                    <p><b>Balance Forward:</b> 
                                    <span class="badge badge-<%= autoInvoiceDisplay.balanceForward === 'Enabled' ? 'success' : 'danger' %>">
                                        <%= autoInvoiceDisplay.balanceForward %>
                                    </span>
                                    </p>
                                
                                    <p><b>Auto-Email:</b> 
                                        <span class="badge badge-<%= autoInvoiceDisplay.autoEmail === 'Enabled' ? 'success' : 'danger' %>">
                                            <%= autoInvoiceDisplay.autoEmail %>
                                        </span>
                                    </p>
                                </div>
                            </div>
                        <% } %>

                        <% if (loggedUserInfo.role != 3) { %>
                            <div class="mt-3">
                                <% if (autoInvoiceDisplay) { %>
                                <!-- Edit Auto Invoicing -->
                                <a href="#"
                                    class="btn theme-btn custom-btns mb-2"
                                    id="enable-auto-invoice"
                                    data-id="<%= student._id %>"
                                    title="Edit auto invoicing">
                                    Edit Auto-Invoice Settings
                                </a>

                                <!-- Disable Auto Invoicing -->
                                <a href="#"
                                    class="btn theme-btn custom-btns btn-transparent"
                                    id="disable-auto-invoice"
                                    data-id="<%= student._id %>"
                                    data-toggle="modal"
                                    data-target="#disableAutoInvoicing"
                                    title="Disable auto invoicing">
                                    Disable Auto Invoicing
                                </a>
                                <% } else { %>
                                <!-- Enable Auto Invoicing -->
                                <a href="#"
                                    class="btn theme-btn custom-btns mb-2"
                                    id="enable-auto-invoice"
                                    data-id="<%= student._id %>"
                                    title="Enable auto invoicing">
                                    Enable Auto Invoicing
                                </a>
                                <% } %>
                            </div>
                            <% } %>
                    </div>
                </div>
            </div>
            <div class="col-xl-9 col-lg-8">
                <div class="card tabcard mb-3">
                    <div class="card-body p-3">
                        <!-- Tab Navigation -->
                        <div class="setting_tab families-tab">
                            <ul class="nav nav-pills" id="pills-tab" role="tablist">
                                <li class="nav-item">
                                    <a class="nav-link" id="pills-account-tab"
                                        data-toggle="pill" href="#account" role="tab"
                                        aria-controls="account"
                                        aria-selected="false">Account</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" id="pills-invoices-tab"
                                        data-toggle="pill" href="#invoices" role="tab"
                                        aria-controls="invoices"
                                        aria-selected="false">Invoices</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="tab-content" id="pills-tabContent">
                    <!-- Family Accounts Tab -->
                    <div class="tab-pane fade" id="account" role="tabpanel"
                        aria-labelledby="pills-account-tab">
                        <div class="card mb-3">
                            <div class="card-body date_dropdown">
                                <h2 class="title-text mb-0 balance-total">
                                    Balance Remaining: <strong><%= Number(finalBalance).toFixed(2) %></strong> as of
                                    <div class="ml-2">
                                        <div id="display-date">
                                            <%= filterDate ? new
                                                Date(filterDate).toLocaleDateString('en-GB').replace(/\//g, '-'
                                                ) : new Date(new Date().getFullYear(), new
                                                Date().getMonth() + 1,
                                                0).toLocaleDateString('en-GB').replace(/\//g, '-'
                                                ) %>
                                        </div>
                                    </div>
                                    <div class="ml-2 position-relative">
                                        <span class="owed_date" style="cursor: pointer;">
                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                width="13" height="7" viewBox="0 0 13 7"
                                                fill="none">
                                                <path
                                                    d="M12.1589 1L7.56569 5.59317C7.02325 6.13561 6.13561 6.13561 5.59317 5.59317L1 1"
                                                    stroke="#201B53" stroke-width="1.5"
                                                    stroke-miterlimit="10"
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round" />
                                            </svg>
                                        </span>
                                        <input type="text" id="hidden-date-input" class="hidden_input_area" />
                                    </div>
                                </h2>
                            </div>
                            <%- include('../partials/balance_date_prompt') %>
                        </div>
                        <div class="x_panel">
                            <div class="x_title">

                                <% if(loggedUserInfo.role != 3) { %>
                                <div class="left-btns">
                                    <ul>
                                        <li>
                                            <a href="/families-invoices/transaction-details/<%= student._id %>" class="btn theme-btn"
