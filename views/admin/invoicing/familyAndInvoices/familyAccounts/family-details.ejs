    async function transactionTable() {
        let studentId = '<%= studentId %>';
        if ($.fn.DataTable.isDataTable("#familyTransactionsTable")) {
            $("#familyTransactionsTable").DataTable().destroy();
        }

        let savedOrder = [[0, "desc"]]; 
        try {
            const saved = localStorage.getItem(TRANS_SORT_STORAGE_KEY);
            if (saved) {
                const { columnName, direction } = JSON.parse(saved);
                const colMap = { 'date': 0 }; 
                const colIndex = colMap[columnName];
                if (colIndex !== undefined) {
                    savedOrder = [[colIndex, direction]];
                }
            }
        } catch(e) {}

        studentTransactionTable = $("#familyTransactionsTable").DataTable({
            serverSide: true,
            paging: true,
            pageLength: 10,
            responsive: false,
            // scrollX: true,
            autoWidth: false,
            dom: '<"table-responsive families-invoices-responsive"t><"bottom_table_field"<""l><""i><""p>>r',
            // order: [[0, "desc"]],
            order: savedOrder,
            ajax: {
                url: "/families-invoices/transactions/dataTable",
                type: "POST",
                data: function (d) {
                    const selectedDate = $('#hidden-date-input').data('daterangepicker')?.startDate;
                    
                    // Convert single date to date range for recurring transactions
                    if (selectedDate && moment(selectedDate).isValid()) {
                        // For recurring transactions, we need to show all transactions UP TO the selected date
                        // So we set start date to a very early date and end date to the selected date
                        d.filter_start_date = '01-01-1972'; // Very early start date to capture all recurring transactions
                        d.filter_end_date = selectedDate.format('DD-MM-YYYY'); // End at the selected date
                    } else {
                        // If no date selected, use current date as end point
                        d.filter_end_date = moment().format('DD-MM-YYYY');
                    }
                    
                    d.studentId = studentId;

                    // Custom Search Filters
                    d.searchCategory = $('#familyTransactionDropdown input[type="search"]').val()?.trim() || '';
                    d.showZeroEntries = $('#familyTransactionDropdown #show_zero_entries').is(':checked') ? 1 : 0;
                    d.searchAmount = $('#familyTransactionDropdown #amount_search').val() || '';
                    
                    // Add the single filterDate for backward compatibility if needed
                    d.filterDate = selectedDate ? selectedDate.format('DD-MM-YYYY') : '';
                }
            },
            columns: [
                {
                    data: "date",
                    orderable:true,
                    render: function (data, type, row) {
                        const categoryTxt = (row.category) ? `<br/><span class="status-label background-neutral"><i class="fa fa-calendar"></i> ${row.category}</span>` : '';
                        const recurringText = (row.recurring) ? `<br/><span class="status-label background-neutral"><i class="fa fa-refresh"></i> Recurring</span>` : '';
                        return (row.date ? moment(row.date).format("DD-MM-YYYY") : "-") + ` ${categoryTxt} ${recurringText}`;
                    }
                },
                {
                    data: "student_name",
                    orderable:false,
                    defaultContent: "-"
                },
                {
                    data: "note",
                    orderable:false,
                    defaultContent: "-"
                },
                {
                    data: "null",
                    orderable:false,
                    render: function (data, type, row) {
                        const amount_txt = row.amount.toFixed(2);
                        const className = ['Charge','Discount'].includes(row.transaction_type) ? 'background-danger' : '';
                        return ['Charge','Discount'].includes(row.transaction_type) ? `<span class="status-label ${className} nowrap">${row.transaction_type} ${row.currency}${amount_txt}</span>` : '-';
                    }
                },
                {
                    data: null,
                    orderable:false,
                    render: function (data, type, row) {
                        const amount_txt = row.amount.toFixed(2);
                        const className = ['Payment','Refund'].includes(row.transaction_type) ? 'background-success' : '';
                        return ['Payment','Refund'].includes(row.transaction_type) ? `<span class="status-label ${className} nowrap">${row.transaction_type} ${row.currency}${amount_txt}</span>` : '-';
                    }
                },
                {
                    data: null,
                    orderable:false,
                    render: function (data, type, row) {
                        const derived_amount_txt = row.derived_balance.toFixed(2);
                        const className = (row.derived_balance > 0) ? 'background-success' : 'background-danger';
                        return `<span class="status-label ${className}">${row.currency}${derived_amount_txt}</span>`;
                    }
                },
                {
                    data: "slug",
                    orderable: false,
                    name: 'actions',
                    searchable: false,
                    defaultContent: '',
                    render: function (data, type, row) {
                        let buttons = "";
                        if (row.event && row.event !== null) {
                            buttons += `
                                <a class="dropdown-item" href="/attendance-notes/take-attendance/${row.event}">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="#4a4674" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34a.9959.9959 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                    </svg>
                                    Edit Attendance
                                </a>
                            `;

                            buttons += `
                                <a class="dropdown-item" href="/calendar/edit-an-event/${row.event}">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="#4a4674" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34a.9959.9959 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                    </svg>
                                    Edit Event Details
                                </a>
                            `;
                        } else {
                             buttons += `
                                <a class="dropdown-item" href="/families-invoices/transaction-details/edit/${row._id}">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="#4a4674" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34a.9959.9959 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                    </svg>
                                    Edit Transaction
                                </a>`;
                            if (row.transaction_type && ['Payment','Refund'].includes(row.transaction_type)) {
                                buttons += `<a class="dropdown-item download-receipt" href="javascript:void(0);" data-id="${row._id}">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="#4a4674" xmlns="http://www.w3.org/2000/svg"> <path d="M12 15.575C11.8667 15.575 11.7417 15.5542 11.625 15.5125C11.5083 15.4708 11.4 15.4 11.3 15.3L7.7 11.7C7.5 11.5 7.40417 11.2667 7.4125 11C7.42083 10.7333 7.51667 10.5 7.7 10.3C7.9 10.1 8.1375 9.99583 8.4125 9.9875C8.6875 9.97917 8.925 10.075 9.125 10.275L11 12.15V4C11 3.71667 11.0958 3.47917 11.2875 3.2875C11.4792 3.09583 11.7167 3 12 3C12.2833 3 12.5208 3.09583 12.7125 3.2875C12.9042 3.47917 13 3.71667 13 4V12.15L14.875 10.275C15.075 10.075 15.3125 9.97917 15.5875 9.9875C15.8625 9.99583 16.1 10.1 16.3 10.3C16.4833 10.5 16.5792 10.7333 16.5875 11C16.5958 11.2667 16.5 11.5 16.3 11.7L12.7 15.3C12.6 15.4 12.4917 15.4708 12.375 15.5125C12.2583 15.5542 12.1333 15.575 12 15.575ZM5 21C4.45 21 3.97917 20.8042 3.5875 20.4125C3.19583 20.0208 3 19.55 3 19V17C3 16.7167 3.09583 16.4792 3.2875 16.2875C3.47917 16.0958 3.71667 16 4 16C4.28333 16 4.52083 16.0958 4.7125 16.2875C4.90417 16.4792 5 16.7167 5 17V19H19V17C19 16.7167 19.0958 16.4792 19.2875 16.2875C19.4792 16.0958 19.7167 16 20 16C20.2833 16 20.5208 16.0958 20.7125 16.2875C20.9042 16.4792 21 16.7167 21 17V19C21 19.55 20.8042 20.0208 20.4125 20.4125C20.0208 20.8042 19.55 21 19 21H5Z"></path> </svg>  
                                    Download Receipt
                                </a>`;
                            }
                            buttons += `<a class="dropdown-item delete-transaction" href="#" onclick="confirmBeforeDeletion('/families-invoices/transaction-details/destroy/${row._id}')" title="Delete Transaction">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="#4a4674" xmlns="http://www.w3.org/2000/svg"> <path d="M6 19C6 20.1 6.9 21 8 21H16C17.1 21 18 20.1 18 19V9C18 7.9 17.1 7 16 7H8C6.9 7 6 7.9 6 9V19ZM9 9H15C15.55 9 16 9.45 16 10V18C16 18.55 15.55 19 15 19H9C8.45 19 8 18.55 8 18V10C8 9.45 8.45 9 9 9ZM15.5 4L14.79 3.29C14.61 3.11 14.35 3 14.09 3H9.91C9.65 3 9.39 3.11 9.21 3.29L8.5 4H6C5.45 4 5 4.45 5 5C5 5.55 5.45 6 6 6H18C18.55 6 19 5.55 19 5C19 4.45 18.55 4 18 4H15.5Z"></path> </svg>
                                Delete Transaction</a>`;
                        }
                        
                        return `
                        <div class="dropdown dropup table_dropdown">
                            <button class="dropdowntoggle bg-transparent border-0 shadow-none" type="button" data-toggle="dropdown" data-boundary="window" aria-expanded="false">
                                <img src="/images/more-icon.svg" alt="more-icon" />
                            </button>
                            <div class="dropdown-menu invoice_body_dropdown dropdown-menu-area dropdown-menu-right">                            
                                ${buttons}                                
                            </div>
                        </div>`;
                    }
                }
            ],
            initComplete: function(settings, json) {
                applySavedSort(this.api(),'transactions-sort-dropdown',TRANS_SORT_STORAGE_KEY);
            }
        });

        studentTransactionTable.on('order.dt', function () {
            const order = studentTransactionTable.order();
            if (order.length) {
                const colIndex = order[0][0];
                const direction = order[0][1];
                const colMap = { 0: 'date' }; 
                const columnName = colMap[colIndex];
                if (columnName) {
                    localStorage.setItem(TRANS_SORT_STORAGE_KEY, JSON.stringify({ columnName, direction }));
                    $(`#transactions-sort-dropdown .sort-trigger`).removeClass('sort-asc sort-desc');
                    $(`#transactions-sort-dropdown .sort-trigger[data-column-name="${columnName}"]`).addClass(`sort-${direction}`);
                }
            }
        });
    
        
        $('#familyTransactionsTable').on('xhr.dt', function (e, settings, json, xhr) {
            const currency = json.currency || '$';
            $('.balance-total strong').text(`${currency}${Math.abs(json.owed)}`);
        });
    }

    // Function to show the correct tab based on URL hash
    function showActiveTab(hash = "#account") {
        const normalizedHash = hash.toLowerCase();
        const tabMap = {
            "#account": {
                el: $('[href="#account"]'),
                handler: () => transactionTable()
            },
            "#invoices": {
                el: $('[href="#invoices"]'),
                handler: () => loadInvoices('<%= studentId %>')
            }
        };

        const tabEntry = tabMap[normalizedHash] || tabMap["#account"];

        if (tabEntry?.el) {
            tabEntry.el.tab('show');

            // ✅ Trigger associated logic explicitly
            setTimeout(() => {
                tabEntry.handler?.();
            }, 10); // allow Bootstrap's tab transition to complete
        }
    }

    $(function () {
        const currentHash = window.location.hash || "#account";
        
        try {
            showActiveTab(currentHash);

            $('#date_range_block').daterangepicker({
                autoUpdateInput: false,
                singleDatePicker: false,
                showDropdowns: true,
                minYear: 1901,
                maxYear: parseInt(moment().format('YYYY'), 10),
                //parentEl: '#invoicesDropdown',
                locale: {
                    format: 'DD-MM-YYYY'
                }
            });
            $('#date_range_block').on('show.daterangepicker', function(ev, picker) {
                picker.container.addClass('add-invoice-daterangepicker');
            });

            $(document).on('click', '.daterangepicker.add-invoice-daterangepicker', function (e) {
                e.stopPropagation();
            });

            // Initially disable it
            $('#date_range_block').prop('disabled', true).val('');

            // Checkbox toggle
            $('#filter_invoice_date').on('change', function () {
                if ($(this).is(':checked')) {
                    // Enable input
                    $('#date_range_block').prop('disabled', false);

                    // Set to current month range
                    let startOfMonth = moment().startOf('month');
                    let endOfMonth = moment().endOf('month');

                    $('#date_range_block').data('daterangepicker').setStartDate(startOfMonth);
                    $('#date_range_block').data('daterangepicker').setEndDate(endOfMonth);

                    $('#date_range_block').val(
                        startOfMonth.format('DD-MM-YYYY') + ' - ' + endOfMonth.format('DD-MM-YYYY')
                    );
                } else {
                    // Disable and clear
                    $('#date_range_block').prop('disabled', true).val('');
                }
            });

            // Load saved filters
            loadSearchFilters(familyDetailSearchformId,TRANS_SEARCH_STORAGE_KEY);

            // Update count after loading
            updateSearchCount(familyDetailSearchformId);

            // Load saved filters
            loadSearchFilters(invoiceSearchformId,INV_SEARCH_STORAGE_KEY);

            // Update count after loading
            updateSearchCount(invoiceSearchformId);            
        } catch (e) {
            console.error("Initialization error:", e);
        }

        $(document).on("click", ".download-receipt", function (e) {
            e.preventDefault();
            const id = $(this).data("id");
            $.ajax({
                url: `/families-invoices/transaction-details/${id}/download-receipt`,
                method: "GET",
                xhrFields: { responseType: 'blob' }, // expect PDF
                success: function (data, status, xhr) {
                const blob = new Blob([data], { type: "application/pdf" });
                const link = document.createElement("a");
                link.href = window.URL.createObjectURL(blob);
                link.download = `receipt-${id}.pdf`;
                link.click();
                },
                error: function (err) {
                Swal.fire("Error", "Failed to download receipt", "error");
                },
            });
        });

       
        $('#familyInvoiceTable').on('change', 'input[type="checkbox"]', function () {
            toggleActionButtons('familyInvoiceTable','invoices');
        });

        // Listen to 'select all' checkbox
        $('#family_select_all').on('change', function () {
            const isChecked = $(this).prop('checked');
            $('#familyInvoiceTable tbody input[type="checkbox"]').prop('checked', isChecked);
            toggleActionButtons('familyInvoiceTable','invoices');
        });

        $(`#${invoiceSearchformId}`).on("click", ".cancel-event", function () {
            const form = $(this).closest("form")[0];
            form.reset();
            updateSearchCount(invoiceSearchformId);   
            invoiceDataTable.ajax.reload();
            $(this).closest(".dropdown").find(".dropdown-toggle").dropdown("toggle");
        });

        $(`#${familyDetailSearchformId}`).on("click", ".cancel-event", function () {
            const form = $(this).closest("form")[0];
            form.reset();
            updateSearchCount(familyDetailSearchformId);
            studentTransactionTable.ajax.reload();
            $(this).closest(".dropdown").find(".dropdown-toggle").dropdown("toggle");
        });

        $(".drop-down .selected").on("click", function() {
            $(this).next(".drop-options").toggle();
        });

        // Handle tab change and update hash in URL
        $('a[data-toggle="pill"]').on('shown.bs.tab', async function (e) {
            const hash = $(e.target).attr('href'); // e.g., #pills-general
            let section = '';
            switch (hash) {
                case '#account':
                    section = 'account';
                    await transactionTable();
                break;
                case '#invoices':
                    section = 'invoices';
                    await loadInvoices('<%= studentId %>');
                break;
            }
            if (history.pushState) {
                history.pushState(null, null, '#' + section);
            } else {
                window.location.hash = '#' + section;
            }
        });
        
        $('#transactions-sort-dropdown .sort-trigger').on('click', function (e) {
            const $btn = $(this);
            triggerSortClick(studentTransactionTable, $btn,'transactions-sort-dropdown', TRANS_SORT_STORAGE_KEY);
        });
        
        // Search button click
        $(`#${familyDetailSearchformId}`).on('submit', function (e) {
            e.preventDefault();
            saveSearchFilters(familyDetailSearchformId, TRANS_SEARCH_STORAGE_KEY);
            updateSearchCount(familyDetailSearchformId, TRANS_SEARCH_STORAGE_KEY);
            studentTransactionTable.ajax.reload();
            $(this).closest(".dropdown").find(".dropdown-toggle").dropdown("toggle");
        });

        // Clear button
        $('#familyTransactionDropdown .cancel-btn').on('click', function () {
            $(`#${familyDetailSearchformId}`)[0].reset();
            $('.search-input:checkbox').prop('checked', false);
            localStorage.removeItem(TRANS_SEARCH_STORAGE_KEY);
            updateSearchCount(familyDetailSearchformId, TRANS_SEARCH_STORAGE_KEY);
            studentTransactionTable.ajax.reload();
            //$(this).closest(".dropdown").find(".dropdown-toggle").dropdown("toggle");
        });


        $('#invoices-sort-dropdown .sort-trigger').on('click', function (e) {
            const $btn = $(this);
            triggerSortClick(invoiceDataTable, $btn,'invoices-sort-dropdown', INV_SORT_STORAGE_KEY);
        });

        // Search button click
        $(`#${invoiceSearchformId}`).on('submit', function (e) {
            e.preventDefault();
            saveSearchFilters(invoiceSearchformId, INV_SEARCH_STORAGE_KEY);
            updateSearchCount(invoiceSearchformId, INV_SEARCH_STORAGE_KEY);
            invoiceDataTable.ajax.reload();
            $(this).closest(".dropdown").find(".dropdown-toggle").dropdown("toggle");
        });

        // Clear button
        $('#invoicesDropdown .cancel-btn').on('click', function () {
            $(`#${invoiceSearchformId}`)[0].reset();
            $('.search-input:checkbox').prop('checked', false);
            localStorage.removeItem(INV_SEARCH_STORAGE_KEY);
            updateSearchCount(invoiceSearchformId, INV_SEARCH_STORAGE_KEY);
            invoiceDataTable.ajax.reload();
        });
    });

    // Options dropdown functionality
    $(document).on("click", ".dropdown-item.download-selected", function () {
        let selectedIds = [];
        $("#familyInvoiceTable tbody input[type='checkbox']:checked").each(function () {
            let rowId = $(this).closest("tr").find("td._id input").val() || $(this).val();
            if (rowId) selectedIds.push(rowId);
        });

        if (selectedIds.length === 0) {
            alert("Please select at least one invoice.");
            return;
        }
        window.location.href = `/families-invoices/invoice/download-zip?ids=${selectedIds.join(",")}`;
    });

    $(document).on("click", ".dropdown-item.download-invoice-details", function () {
        let selectedIds = [];
        $("#familyInvoiceTable tbody input[type='checkbox']:checked").each(function () {
            let rowId = $(this).closest("tr").find("td._id input").val() || $(this).val();
            if (rowId) selectedIds.push(rowId);
        });

        if (selectedIds.length === 0) {
            alert("Please select at least one invoice.");
            return;
        }
        window.location.href = `/families-invoices/invoice/download-excel?ids=${selectedIds.join(",")}`;
    });

    // Archive/Unarchive functionality
    $(document).on("click", ".archive-action", function (e) {
            e.preventDefault();
            const ids = [];
            const id = $(this).data("id"); // Single row
            const action = $(this).data("action"); // archive / unarchive

            if (id) ids.push(id);

            // Collect selected checkboxes for bulk actions
           $(".invoice-checkbox:checked").each(function () {
            ids.push($(this).val());
            });


            if (ids.length === 0) {
            Swal.fire("Warning", "No invoices selected", "warning");
            return;
            }

            Swal.fire({
            title: "Are you sure?",
            text: `Do you want to ${action} the selected invoices?`,
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: `Yes, ${action}`,
            cancelButtonText: "Cancel",
            }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                url: `/families-invoices/invoices/change-archive-status`,
                type: "POST",
                data: { invoice_ids: ids, action },
                success: function (res) {
                    Swal.fire("Success", `Invoices ${action}d successfully`, "success");
                    invoiceDataTable.ajax.reload();
                },
                error: function (err) {
                    Swal.fire("Error", `Failed to ${action} invoices`, "error");
                },
                });
            }
            });
    });

    

    $(document).on("click", ".delete-invoice", function (e) {
        e.preventDefault();
        const ids = [];
        const id = $(this).data("id"); // Single row delete
        if (id) ids.push(id);

        // Collect selected checkboxes for bulk actions
        $(".invoice-checkbox:checked").each(function () {
        ids.push($(this).val());
        });

        if (ids.length === 0) {
        Swal.fire("Warning", "No invoices selected", "warning");
        return;
        }
        Swal.fire({
        title: "Are you sure?",
        text: `Do you want to delete the selected invoice(s)?`,
        icon: "warning",
        showCancelButton: true,
        confirmButtonText: `Yes, Delete`,
        cancelButtonText: "Cancel",
        }).then((result) => {
        if (result.isConfirmed) {
            $.ajax({
            url: `/families-invoices/invoices/delete`,
            type: "POST", // POST as you wrote
            data: JSON.stringify({ invoice_ids: ids }),
            contentType: "application/json",
            success: function (res) {
                if (res.success) {
                Swal.fire("Success", res.message || "Invoice(s) deleted successfully", "success");
                invoiceDataTable.ajax.reload();
                } else {
                Swal.fire("Warning", res.message || "Failed to delete invoices.", "warning");
                }
            },
            error: function () {
                Swal.fire("Error", "Something went wrong while deleting invoices.", "error");
            }
            });
        }
        });
    });
    
    // Email multiple invoices
    $(document).on("click", ".email-invoice-btn", function () {
        let selectedIds = [];
        $("#familyInvoiceTable tbody input[type='checkbox']:checked").each(function () {
            let rowId = $(this).closest("tr").find("td._id input").val() || $(this).val();
            if (rowId) selectedIds.push(rowId);
        });

        if (selectedIds.length === 0) {
            alert("Please select at least one invoice.");
            return;
        }

        // Store selected IDs for use in the modal
        $('#sendEmailInvoice').data('selected-invoices', selectedIds);
        
        // You might want to modify the modal to handle multiple invoices
        // For now, we'll just show the modal for the first selected invoice
        if (selectedIds.length > 0) {
            $('#invoiceIdField').val(selectedIds[0]);
            $('#sendEmailInvoice').modal('show');
        }
    });

    // Toggle action buttons based on checkbox selection
    function toggleActionButtons() {
        const anyChecked = $("#familyInvoiceTable tbody input[type='checkbox']:checked").length > 0;
        $(".action-btn").prop('disabled', !anyChecked);
    }

    // Listen to checkbox changes
    $('#familyInvoiceTable').on('change', 'input[type="checkbox"]', function () {
        toggleActionButtons();
    });

    // Listen to 'select all' checkbox
    $('#family_select_all').on('change', function () {
        const isChecked = $(this).prop('checked');
        $('#familyInvoiceTable tbody input[type="checkbox"]').prop('checked', isChecked);
        toggleActionButtons();
    });
    
</script>

