<script>
    // Dropdown move in body when I click on action button
    $(document).on('show.bs.dropdown', '.table .dropdown.table_dropdown', function () {
        var $menu = $(this).find('.dropdown-menu.invoice_body_dropdown');
        $('body').append($menu.detach());

        var $btn = $(this).find('[data-toggle="dropdown"]');
        var offset = $btn.offset();
        $menu.css({
        'display': 'block',
        'position': 'absolute',
        'top': offset.top + $btn.outerHeight(),
        'left': offset.left,
        'z-index': 1050
        });
    });

    $(document).on('hide.bs.dropdown', '.table .dropdown.table_dropdown', function () {
        var $menu = $('body > .dropdown-menu.invoice_body_dropdown');
        $(this).append($menu.detach().css({
        'display': '',
        'position': '',
        'top': '',
        'left': '',
        'z-index': ''
        }));                
    });
</script>