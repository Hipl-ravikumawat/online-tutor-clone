      ],
      initComplete: function (settings, json) {
        applySavedSort(this.api(), 'staff-invoices-sort-dropdown', INVOICE_SORT_STORAGE_KEY);
      },
      select: {
        style: "multi",
        selector: ".invoice-select-checkbox"
      },
      columnDefs: [
        {
          targets: 0,
          data: "select",
          searchable: false,
          orderable: false,
          width: "3%"
        },
        {
          targets: [2, 3, 6] /* column index */,
          orderable: false /* true or false */,
        }
      ],
      order: [[1, 'desc']],
      drawCallback: function (settings) {
        const order = settings.aaSorting;
        // console.log("drawCallback: New sort", order);
        $('[data-toggle="tooltip"]').tooltip();
      }
    });
    invoiceTableInitialized = true;

    //select all checkbox
    $("#select_all").on("click", function (e) {
      if ($(this).is(":checked")) {
        invoiceTable.rows().select();
        $('.invoice-select-checkbox').prop('checked', true);
      } else {
        invoiceTable.rows().deselect();
        $('.invoice-select-checkbox').prop('checked', false);
      }
    });

    setTimeout(() => {
      initColumnVisibilityControls({
        table: invoiceTable, // your DataTable instance
        storageKey: INVOICE_STORAGE_KEY,
        defaultCols: ['invoice-date', 'staff', 'date-range', 'invoice-amount'],
        checkboxSelector: '#invoice-colvis-dropdown .column-checkbox',
        showAllSelector: '#invoice-colvis-dropdown .show-all',
        showDefaultSelector: '#invoice-colvis-dropdown .show-default'
      });
    }, 200);

  }

  // Dropdown move in body when I click on action button
  $(document).on('show.bs.dropdown', '.table .dropdown.table_dropdown', function () {
    var $menu = $(this).find('.dropdown-menu.invoice_body_dropdown');
    $('body').append($menu.detach());

    var $btn = $(this).find('[data-toggle="dropdown"]');
    var offset = $btn.offset();
    $menu.css({
      'display': 'block',
      'position': 'absolute',
      'top': offset.top + $btn.outerHeight(),
      'left': offset.left,
      'z-index': 1050
    });
  });

  $(document).on('hide.bs.dropdown', '.table .dropdown.table_dropdown', function () {
    var $menu = $('body > .dropdown-menu.invoice_body_dropdown');
    $(this).append($menu.detach().css({
      'display': '',
      'position': '',
      'top': '',
      'left': '',
      'z-index': ''
    }));
  });
</script>

<script>
  $(function () {
    // Mark as Paid
    $(document).on("click", ".mark-as-paid", function (e) {
      e.preventDefault();
      const id = $(this).data("id");

      Swal.fire({
        title: "Are you sure?",
        text: "Do you want to mark this invoice as Paid?",
        icon: "warning",
        showCancelButton: true,
        confirmButtonText: "Yes, mark as Paid",
        cancelButtonText: "Cancel",
      }).then((result) => {
        if (result.isConfirmed) {
          $.ajax({
            url: `/staff-invoices/invoices/${id}/mark-paid`,
            type: "POST",
            success: function (res) {
              Swal.fire("Success", "Invoice marked as Paid", "success");
              invoiceTable.ajax.reload();
            },
            error: function (err) {
              Swal.fire("Error", "Failed to update invoice", "error");
            },
          });
        }
      });
    });

    // Mark as Void
    $(document).on("click", ".mark-as-void", function (e) {
      e.preventDefault();
      const id = $(this).data("id");

      Swal.fire({
        title: "Are you sure?",
        text: "Do you want to mark this invoice as Void?",
        icon: "warning",
        showCancelButton: true,
        confirmButtonText: "Yes, mark as Void",
        cancelButtonText: "Cancel",
      }).then((result) => {
        if (result.isConfirmed) {
          $.ajax({
            url: `/staff-invoices/invoices/${id}/mark-void`,
            type: "POST",
            success: function (res) {
              Swal.fire("Success", "Invoice marked as Void", "success");
              invoiceTable.ajax.reload();
            },
            error: function (err) {
              Swal.fire("Error", "Failed to update invoice", "error");
            },
          });
        }
      });
    });

    // Mark Archive / Unarchive
    $(document).on("click", ".archive-action", function (e) {
      e.preventDefault();
      const ids = [];
      const id = $(this).data("id"); // Single row
      const action = $(this).data("action"); // archive / unarchive

      if (id) ids.push(id);

      // Collect selected checkboxes for bulk actions
      $(".invoice-select-checkbox:checked").each(function () {
        ids.push($(this).val());
      });

