<script>
  let invoiceTable;
  let invoiceTableInitialized = false;
  const invoiceSearchformId = 'invoicesSearchForm';
  const INVOICE_STORAGE_KEY = 'staffInvoiceTable_columns';
  const INVOICE_SORT_STORAGE_KEY = 'staffInvoiceTable_Sort';
  const INVOICE_SEARCH_STORAGE_KEY = 'staffInvoiceTableSearch_Filters';

  async function loadInvoicesDatatable() {
    if ($.fn.DataTable.isDataTable("#staffInvoiceTable")) {
      $("#staffInvoiceTable").DataTable().destroy();
    }

    invoiceTable = $('#staffInvoiceTable').DataTable({
      processing: true,
      serverSide: true,
      ordering: true,
      responsive: false,
      // scrollX: true,
      autoWidth: false,
      dom: '<"table-responsive staff-invoices-responsive"t><"bottom_table_field"<""l><""i><""p>>r',
      ajax: {
        url: '/staff-invoices/invoices/dataTable',
        type: 'POST',
        data: function (d) {
          // Custom Search Filters
          let drp = $(`#${invoiceSearchformId} #date_range_block`).data('daterangepicker');
          d.filter_invoice_start_date = drp.startDate.format('YYYY-MM-DD') || '';
          d.filter_invoice_end_date = drp.endDate.format('YYYY-MM-DD') || '';
          d.family_or_invoice_number = $(`#${invoiceSearchformId} #family_or_invoice_number`).val()?.trim() || '';
          d.filter_invoice_date = $(`#${invoiceSearchformId} #filter_invoice_date`).prop("checked") || '';
          d.hide_emailed = $(`#${invoiceSearchformId} #hide_emailed`).is(':checked') ? 1 : 0;
          d.hide_voided = $(`#${invoiceSearchformId} #hide_voided`).is(':checked') ? 1 : 0;
          d.hide_due_invoices = $(`#${invoiceSearchformId} #hide_due_invoices`).is(':checked') ? 1 : 0;
          d.archive_status = $(`#${invoiceSearchformId} #archive_status`).val() || '';

          // Send current sort info from dropdown if exists
          // let sortInfo = $('#staff-invoices-sort-dropdown').data('sort-info');
          // if (sortInfo) {
          //     d.order = [
          //         { column: sortInfo.column, dir: sortInfo.direction }
          //     ];
          // }else{
          //     d.order = [
          //         { column: 1, dir: 'desc' }
          //     ];
          // }
        },
        dataSrc: function (json) {
          // console.log("Server Response:", json);
          return json.data;
        }
      },
      columns: [
        { data: "_id", render: id => `<input class="invoice-select-checkbox" type="checkbox" value="${id}" />`, orderable: false },
        //{ data: 'invoice_date', orderable: true, },
        {
          data: 'invoice_date',
          render: function (data, type, row) {
            const badges = [];
            const formattedDate = moment(new Date(data)).format("DD-MM-YYYY");

            if (row.is_void) {
              badges.push(`<span class="badge background-danger" data-toggle="tooltip" data-placement="bottom" title="This invoice has been voided.">Void</span>`);
            } else if (row.is_paid) {
              badges.push(`<span class="badge background-success" data-toggle="tooltip" data-placement="bottom" title="This invoice is paid in full.">Paid</span>`);
            }

            if (row.is_emailed) {
              const emailedAt = row.email_sent_at ? moment(row.email_sent_at).format("DD-MM-YYYY HH:mm:ss") : null;
              const tooltip = emailedAt ? `This invoice was emailed on ${emailedAt}.` : "This invoice has been emailed.";
              badges.push(`<span class="badge background-email" data-toggle="tooltip" data-placement="bottom" title="${tooltip}">Emailed</span>`);
            }

            if (row.is_archived) {
              badges.push(`<span class="badge background-neutral" data-toggle="tooltip" data-placement="bottom" title="This invoice is archived.">Archived</span>`);
            }

            return `
              <div class="invoices_table_data">
                <span>${formattedDate}</span>
              </div>
              <div class="invoices_table_info">
                ${badges.join(" ")}
              </div>
            `;
          }
        },
        { data: 'invoice_number', orderable: false },
        {
          data: 'due_date',
          orderable: false,
          render: function (data, type, row) {
            return (data) ? `${moment(new Date(data)).format('DD/MM/YYYY')}` : '-';
          }
        },
        {
          data: 'staff',
          orderable: true,
        },
        {
          data: 'date_range',
          orderable: false,
          render: (data) => {
            if (!data) return '';
            return data
              .replace(/<[^>]*>/g, '')
              .split('-')
              .map(d => d.trim() ? moment(d.trim(), "DD/MM/YYYY").format("DD-MM-YYYY") : '')
              .join(' - ');
          }
        },
        {
          data: 'private_note',
          orderable: false,
        },
        {
          data: 'invoice_amount',
          render: function (data, type, row) {
            return `${row.currency}${data}`;
          },
          orderable: true,
        },
        {
          data: 'status', 
          render: function (data, type, row) {
            const status = data || 'pending';
            const loggedUserRole = '<%= loggedUserInfo.role %>';
            
            // Show action buttons only for admin/role 1 and pending status
            if (loggedUserRole == 1 && status === 'pending') {
              return `
                <div class="d-flex align-items-center gap-10">
                  <a href="javascript:void(0)" class="approve-invoice" data-id="${row._id}" data-value="approved" data-toggle="tooltip" data-placement="top" title="Approve Invoice">
                    <img src="/images/check-icon.svg" width="20" height="20" style="cursor: pointer;">
                  </a>
                  <a href="javascript:void(0)" class="reject-invoice" data-id="${row._id}" data-value="rejected" data-toggle="tooltip" data-placement="top" title="Reject Invoice">
                    <img src="/images/close-icon.svg" width="20" height="20" style="cursor: pointer;">
                  </a>
                </div>
              `;
            } else {
              // Show status badge for approved/rejected
              const statusClass = {
                'approved': 'badge badge-success',
                'rejected': 'badge badge-danger'
              };
              const statusText = {
                'approved': 'Approved',
                'rejected': 'Rejected'
              };
              
              // For rejected status, add View Reason link
              if (status === 'rejected') {
                const comment = (row.status_comment || 'No reason provided').replace(/'/g, "\\'").replace(/"/g, '&quot;');
                const invoiceNumber = row.invoice_number || '-';
                
                return `
                  <div>
                    <span class="${statusClass[status]}">${statusText[status]}</span>
                    <br>
                    <a href="javascript:void(0);" 
                      class="view-reason-link" 
                      data-invoice-number="${invoiceNumber}"
                      data-reason='${comment}'
                    >
                        View Reason
                    </a>
                  </div>
                `;
              }
              
              return `<span class="${statusClass[status]}">${statusText[status]}</span>`;
            }
          },
          orderable: true
        },
        {
          data: null,
          orderable: false,
          name: 'actions',
          searchable: false,
          defaultContent: '',
          render: function (data, type, row) {
            return `
        <div class="dropdown dropup table_dropdown">
          <button class="dropdowntoggle bg-transparent border-0 shadow-none" type="button" data-toggle="dropdown" data-boundary="window" aria-expanded="false">
            <img src="/images/more-icon.svg" alt="more-icon" />
