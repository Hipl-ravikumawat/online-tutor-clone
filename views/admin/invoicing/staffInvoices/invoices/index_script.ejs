<script>
  let emailTemplateDataList = []; // Store all email data if multiple rows selected
  let currentInvoiceIds = []; // Store current invoice IDs being processed
  let currentTemplateType = ''; // Store current template type

  $(document).on("click", ".sendSingleEmailInvoice", function () {
    const selectedTemplate = $('input[name="template_type"]:checked').val();
    const selectedValues = $(this).data('id');
    currentInvoiceIds = [selectedValues];
    currentTemplateType = selectedTemplate;
    loadInvoiceEmailDataMultiple([selectedValues], selectedTemplate);
    $("#sendEmailInvoice").modal('show');
  });

  function loadInvoiceEmailDataMultiple(invoiceIds, templateType, flag = false) {
    /* console.log("loadInvoiceEmailDataMultiple called with:", {
      invoiceIds: invoiceIds,
      templateType: templateType,
      flag: flag
    }); */

    // Store current state
    currentInvoiceIds = invoiceIds;
    currentTemplateType = templateType;

    $('#invoiceIdField').val(invoiceIds.join(','));
    let selectedValueEmailTo = $("#to_mail").val();

    $.ajax({
      url: `/staff-invoices/invoices/get-email`,
      type: 'POST',
      contentType: 'application/json',
      data: JSON.stringify({
        invoiceIds,
        templateType,
        selectedValueEmailTo
      }),
      dataType: 'json'
    })
      .then(results => {
        // console.log("Server response:", results);
        // console.log("isDropdown:", results.isDropdown);
        // console.log("sendTo data:", results.sendTo);

        // Store the email template data for later use
        emailTemplateDataList = results.emailData || [results];

        $("#sendEmailInvoice").modal("show");
        $("#subject_field").val(results.subject || '');

        if (tinymce.get("message-notes")) {
          tinymce.get("message-notes").setContent(results.message || '');
        }

        if (!flag) {
          // FORCE dropdown for multiple invoices, even if server says no
          if (invoiceIds.length > 1) {
            console.log("Multiple invoices selected - FORCING dropdown");
            showDropdownForMultipleInvoices(results.sendTo);
          } else {
            // Single invoice - follow server's isDropdown flag
            if (results.isDropdown && results.sendTo && results.sendTo.length > 0) {
              showEmailDropdown(results.sendTo);
            } else {
              showCommaSeparatedList(results.sendTo);
            }
          }
        }
      })
      .catch(err => {
        console.error("Error fetching email info:", err);
      });
  }


  // New function to force dropdown for multiple invoices
  function showDropdownForMultipleInvoices(sendToData) {
    $(".select-box-user, .select-comma-user").hide();

    if (sendToData && sendToData.length > 0) {
      // console.log("Showing dropdown for multiple invoices with options:", sendToData);

      // Clear old options and destroy Select2
      $("#to_mail").empty().select2('destroy');

      // Append new options
      sendToData.forEach(item => {
        const option = new Option(item.label, item.value, true, true);
        $("#to_mail").append(option);
      });

      // Reinitialize Select2 with multiple selection enabled
      $("#to_mail").select2({
        width: '100%',
        multiple: true,
        placeholder: "Select recipients",
        allowClear: true
      });

      $(".select-box-user").show();

      // Make editor editable for multiple selections
      if (tinymce.get('message-notes')) {
        tinymce.get('message-notes').setMode('design');
      }
    } else {
      showCommaSeparatedList(sendToData);
    }
  }

  // Function to show dropdown (for single invoices)
  function showEmailDropdown(sendToData) {
    $(".select-box-user, .select-comma-user").hide();

    // console.log("Showing dropdown with options:", sendToData);

    // Clear old options and destroy Select2
    $("#to_mail").empty().select2('destroy');

    // Append new options
    sendToData.forEach(item => {
      const option = new Option(item.label, item.value, true, true);
      $("#to_mail").append(option);
    });

    // Reinitialize Select2
    $("#to_mail").select2({
      width: '100%',
      multiple: true,
      placeholder: "Select recipients",
      allowClear: true
    });

    $(".select-box-user").show();
  }

  // Function to show comma-separated list
  function showCommaSeparatedList(sendToData) {
    console.log("Showing comma-separated list");
    const commaSeparated = sendToData ?
      sendToData.map(item => item.label).join(", ") :
      "No recipients found";

    $(".select-comma-user").text(commaSeparated);
    $(".select-comma-user").show();
    $(".select-box-user").hide();

    // Make the editor readonly
    if (tinymce.get('message-notes')) {
      tinymce.get('message-notes').setMode('readonly');
    }
  }

  // When subject/message should be updated
  function updateSubjectAndMessage(label) {
    const firstData = emailTemplateDataList[0];
    if (!firstData || !firstData.subject || !firstData.message) return;

    const selectedInvoiceCount = emailTemplateDataList.length;
    let subject = '';
    let message = '';

    if (selectedInvoiceCount === 1) {
      subject = firstData.subject.replace(/^(.*?)(?=\s\d{1,2}\/\d{1,2}\/\d{4})/, label);
      message = firstData.message.replace(/Dear (.*?),/, `Dear ${label},`);
    } else {
      subject = `<< Parent Last Name >> << Invoice Date >> Invoice`;
      message = firstData.message.replace(/Dear (.*?),/, `Dear << Parent First Name >>,`)
        .replace(/\d{1,2}\/\d{1,2}\/\d{4}/, '<< Invoice Date >>')
        .replace(/₹\s?[-]?\d+(?:\.\d{1,2})?/, '₹ 123.45');
    }

    $('#subject_field').val(subject);
    if (tinymce.get('message-notes')) {
      tinymce.get('message-notes').setContent(message);
    } else {
      $('#message-notes').val(message);
    }
  }

  // When action button is clicked
  $(document).on("click", '.email-invoice-btn', function () {
    const selectedTemplate = $('input[name="template_type"]:checked').val();
    const selectedValues = [];

    $(".invoice-select-checkbox:checked").each(function () {
      selectedValues.push($(this).val());
    });

    if (selectedValues.length === 0) {
      sweetAlertMsg("Please select at least one invoice.");
      return;
    }

    currentInvoiceIds = selectedValues;
    currentTemplateType = selectedTemplate;
    loadInvoiceEmailDataMultiple(selectedValues, selectedTemplate);
  });

  // Template changed (radio)
  $(document).on("change", 'input[name="template_type"]', function () {
    const selectedTemplate = $('input[name="template_type"]:checked').val();

    if (currentInvoiceIds.length === 0) {
      const selectedValues = $(".invoice-select-checkbox:checked").map(function () {
        return $(this).val();
      }).get();
      const invoiceValue = $("#invoiceIdField").val();

      if (selectedValues.length > 0) {
        currentInvoiceIds = selectedValues;
      } else if (invoiceValue) {
        currentInvoiceIds = invoiceValue.split(',');
      }
    }

    if (currentInvoiceIds.length === 0) {
      sweetAlertMsg("Please select at least one invoice.");
      return;
    }

    // Only call API if we have invoice IDs
    loadInvoiceEmailDataMultiple(currentInvoiceIds, selectedTemplate);
  });
  // When TO email is changed
  $(document).on("change", '#to_mail', function () {
    const selectedLabel = $(this).find('option:selected').data('label');
    const selectedValues = $(this).val(); // Get selected email values

    // console.log("Email selection changed to:", selectedValues);

    // Update subject and message based on current stored data
    updateSubjectAndMessageForSelection(selectedLabel, selectedValues);
  });

</script>

<script>
  $('.form-design').on('submit', function (e) {
    e.preventDefault();
    $('.error-message').text('');
    $('.form-control, .select2').removeClass('is-invalid');

    const $btn = $('.send-email-btn');
    $btn.text('Sending...').prop("disabled", true);

    if (tinymce.get('message-notes')) {
      tinymce.triggerSave();
    }

    // Prepare data for JSON
    const formData = {
      invoiceId: $('#invoiceIdField').val(),
      from_mail: $('#from_mail').val(),
      template_type: $('input[name="template_type"]:checked').val(),
      subject: $('#subject_field').val(),
      message: $('#message-notes').val(),
      bcc_email: $('#bcc_email').is(':checked') ? 1 : 0
    };

    // Handle to_mail based on whether dropdown or comma-separated is visible
    if ($(".select-box-user").is(":visible")) {
      // Dropdown is visible - get selected values as array
      formData.to_mail = $('#to_mail').val() || [];
    } else {
      // Comma-separated is visible - get the text
      formData.to_mail = $(".select-comma-user").text();
    }

    // console.log("Sending data:", formData);

    $.ajax({
      type: 'POST',
      url: '/staff-invoices/invoices/send-email',
      data: JSON.stringify(formData),
      contentType: 'application/json',
      success: function (res) {
        $('#sendEmailInvoice').modal('hide');
        $btn.text('Send').prop("disabled", false);
        invoiceTable.ajax.reload();
      },
      error: function (xhr) {
        $btn.text('Send').prop("disabled", false);

        if (xhr.status === 422 && xhr.responseJSON?.errors) {
          console.log("Validation errors:", xhr.responseJSON.errors);
          xhr.responseJSON.errors.forEach(err => {
            const errorField = `#error-${err.param}`;
            $(errorField).text(err.msg);

            const inputField = $(`[name="${err.param}"]`);
            inputField.addClass('is-invalid');

            if (inputField.hasClass('select2')) {
              inputField.next('.select2').find('.select2-selection')
                .addClass('is-invalid');
            }
          });
        } else {
          console.error("Unexpected error", xhr);
          alert("Something went wrong while sending the email.");
        }
      }
    });
  });
</script>


