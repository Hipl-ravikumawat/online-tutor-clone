              View</a>
            <a class="dropdown-item sendSingleEmailInvoice " href="javascript:void(0);" data-id="${row._id}">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="#4a4674" xmlns="http://www.w3.org/2000/svg"> <path fill-rule="evenodd" clip-rule="evenodd" d="M14.1946 19.4863C13.9814 20.0338 13.2783 20.1721 12.8692 19.7629L10.207 17.1122C9.91884 16.8241 9.88426 16.3631 10.1321 16.0346L17.1911 6.80895L7.9596 13.8622C7.63691 14.1157 7.17591 14.0812 6.88779 13.793L4.23706 11.1308C3.82792 10.7217 3.96622 10.0186 4.51366 9.80543L18.8795 4.06026C19.0211 4.0041 19.3733 3.86471 19.7258 3.72522C19.8229 3.68681 19.92 3.6484 20.0127 3.61171L20.2096 3.53382C20.3727 3.46929 20.5338 3.63083 20.4687 3.79375L20.3902 3.9904C20.3533 4.08297 20.3146 4.17992 20.2759 4.27691C20.1372 4.6244 19.9985 4.97233 19.9397 5.12055L14.1946 19.4863ZM3.77718 7.94595L18.1422 2.20109C18.3238 2.1291 18.8479 1.92173 19.277 1.75196L19.4739 1.67405C21.2681 0.964265 23.0415 2.74326 22.3262 4.53525L22.2477 4.73177C22.078 5.15708 21.8731 5.67081 21.7989 5.8578L21.7968 5.86321L16.054 20.223C15.3032 22.129 12.8677 22.5857 11.4581 21.1802L11.455 21.1772L8.79274 18.5264C8.10981 17.8435 7.84133 16.8806 8.02036 15.9783C7.11319 16.1604 6.14905 15.8827 5.47357 15.2073L5.47051 15.2042L2.82285 12.545L2.82107 12.5432C1.41397 11.1337 1.87048 8.69693 3.77718 7.94595Z"></path> </svg>
              Email</a>
            <a class="dropdown-item download-btn bottom-border" href="javascript:void(0);" data-txn-id="${row._id}">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="#4a4674" xmlns="http://www.w3.org/2000/svg"> <path d="M12 15.575C11.8667 15.575 11.7417 15.5542 11.625 15.5125C11.5083 15.4708 11.4 15.4 11.3 15.3L7.7 11.7C7.5 11.5 7.40417 11.2667 7.4125 11C7.42083 10.7333 7.51667 10.5 7.7 10.3C7.9 10.1 8.1375 9.99583 8.4125 9.9875C8.6875 9.97917 8.925 10.075 9.125 10.275L11 12.15V4C11 3.71667 11.0958 3.47917 11.2875 3.2875C11.4792 3.09583 11.7167 3 12 3C12.2833 3 12.5208 3.09583 12.7125 3.2875C12.9042 3.47917 13 3.71667 13 4V12.15L14.875 10.275C15.075 10.075 15.3125 9.97917 15.5875 9.9875C15.8625 9.99583 16.1 10.1 16.3 10.3C16.4833 10.5 16.5792 10.7333 16.5875 11C16.5958 11.2667 16.5 11.5 16.3 11.7L12.7 15.3C12.6 15.4 12.4917 15.4708 12.375 15.5125C12.2583 15.5542 12.1333 15.575 12 15.575ZM5 21C4.45 21 3.97917 20.8042 3.5875 20.4125C3.19583 20.0208 3 19.55 3 19V17C3 16.7167 3.09583 16.4792 3.2875 16.2875C3.47917 16.0958 3.71667 16 4 16C4.28333 16 4.52083 16.0958 4.7125 16.2875C4.90417 16.4792 5 16.7167 5 17V19H19V17C19 16.7167 19.0958 16.4792 19.2875 16.2875C19.4792 16.0958 19.7167 16 20 16C20.2833 16 20.5208 16.0958 20.7125 16.2875C20.9042 16.4792 21 16.7167 21 17V19C21 19.55 20.8042 20.0208 20.4125 20.4125C20.0208 20.8042 19.55 21 19 21H5Z"></path> </svg> 
                Download PDF</a>
              <hr style="margin:0px">
            <div class="override my-2 py-1">
              <h6 style="color:var(--dblue);">Override Status</h6>
              <div class="d-flex align-items-center gap-10">
                <button type="button" class="dropdown-item text-center rounded background-success mark-as-paid" data-id="${row._id}">Paid</button>
                <button type="button" class="dropdown-item text-center rounded background-danger mark-as-void" data-id="${row._id}">Void</button>
              </div>
            </div>
            <hr style="margin:0px">
            <a class="dropdown-item" href="/staff-invoices/transaction-details/${row.tutor_id}">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="#4a4674" xmlns="http://www.w3.org/2000/svg"> <path d="M19 13H13V19C13 19.55 12.55 20 12 20C11.45 20 11 19.55 11 19V13H5C4.45 13 4 12.55 4 12C4 11.45 4.45 11 5 11H11V5C11 4.45 11.45 4 12 4C12.55 4 13 4.45 13 5V11H19C19.55 11 20 11.45 20 12C20 12.55 19.55 13 19 13Z"></path> </svg>
              Add A Payment</a>
            <a class="dropdown-item" href="/staff-invoices/staff/${row.tutor_id}#Account">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="#4a4674" xmlns="http://www.w3.org/2000/svg"> <path d="M18 19H6C5.45 19 5 18.55 5 18V6C5 5.45 5.45 5 6 5H11C11.55 5 12 4.55 12 4C12 3.45 11.55 3 11 3H5C3.89 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V13C21 12.45 20.55 12 20 12C19.45 12 19 12.45 19 13V18C19 18.55 18.55 19 18 19ZM14 4C14 4.55 14.45 5 15 5H17.59L8.46 14.13C8.07 14.52 8.07 15.15 8.46 15.54C8.85 15.93 9.48 15.93 9.87 15.54L19 6.41V9C19 9.55 19.45 10 20 10C20.55 10 21 9.55 21 9V4C21 3.45 20.55 3 20 3H15C14.45 3 14 3.45 14 4Z"></path> </svg>
              Go To Staff Account</a>
              <hr style="margin:0px">
           <a class="dropdown-item archive-action" href="javascript:void(0);" data-id="${row._id}" data-action="${row.is_archived ? 'unarchive' : 'archive'}">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="#4a4674" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 10C11.7167 10 11.4792 10.0958 11.2875 10.2875C11.0958 10.4792 11 10.7167 11 11V14.2L10.1 13.3C9.91667 13.1167 9.68333 13.025 9.4 13.025C9.11667 13.025 8.88333 13.1167 8.7 13.3C8.51667 13.4833 8.425 13.7167 8.425 14C8.425 14.2833 8.51667 14.5167 8.7 14.7L11.3 17.3C11.5 17.5 11.7333 17.6 12 17.6C12.2667 17.6 12.5 17.5 12.7 17.3L15.3 14.7C15.4833 14.5167 15.575 14.2833 15.575 14C15.575 13.7167 15.4833 13.4833 15.3 13.3C15.1167 13.1167 14.8833 13.025 14.6 13.025C14.3167 13.025 14.0833 13.1167 13.9 13.3L13 14.2V11C13 10.7167 12.9042 10.4792 12.7125 10.2875C12.5208 10.0958 12.2833 10 12 10ZM5 8V19H19V8H5ZM5 21C4.45 21 3.97917 20.8042 3.5875 20.4125C3.19583 20.0208 3 19.55 3 19V6.525C3 6.29167 3.0375 6.06667 3.1125 5.85C3.1875 5.63333 3.3 5.43333 3.45 5.25L4.7 3.725C4.88333 3.49167 5.1125 3.3125 5.3875 3.1875C5.6625 3.0625 5.95 3 6.25 3H17.75C18.05 3 18.3375 3.0625 18.6125 3.1875C18.8875 3.3125 19.1167 3.49167 19.3 3.725L20.55 5.25C20.7 5.43333 20.8125 5.63333 20.8875 5.85C20.9625 6.06667 21 6.29167 21 6.525V19C21 19.55 20.8042 20.0208 20.4125 20.4125C20.0208 20.8042 19.55 21 19 21H5ZM5.4 6H18.6L17.75 5H6.25L5.4 6Z"></path>
            </svg>
             ${row.is_archived ? 'Unarchive' : 'Archive'}
