        icon: "warning",
        showCancelButton: true,
        confirmButtonText: `Yes, Delete`,
        cancelButtonText: "Cancel",
      }).then((result) => {
        if (result.isConfirmed) {
          $.ajax({
            url: `/staff-invoices/invoices/delete`,
            type: "POST", // POST as you wrote
            data: JSON.stringify({ invoice_ids: ids }),
            contentType: "application/json",
            success: function (res) {
              if (res.success) {
                Swal.fire("Success", res.message || "Invoice(s) deleted successfully", "success");
                invoiceTable.ajax.reload();
              } else {
                Swal.fire("Warning", res.message || "Failed to delete invoices.", "warning");
              }
            },
            error: function () {
              Swal.fire("Error", "Something went wrong while deleting invoices.", "error");
            }
          });
        }
      });
    });


    $('#date_range_block').daterangepicker({
      autoUpdateInput: false,
      singleDatePicker: false,
      showDropdowns: true,
      minYear: 1901,
      maxYear: parseInt(moment().format('YYYY'), 10),
      locale: {
        format: 'DD-MM-YYYY',
        cancelLabel: 'Clear'
      }
    });

    // Initially disable it
    $('#date_range_block').prop('disabled', true).val('');

    // Checkbox toggle
    $('#filter_invoice_date').on('change', function () {
      if ($(this).is(':checked')) {
        // Enable input
        $('#date_range_block').prop('disabled', false);

        // Set to current month range
        let startOfMonth = moment().startOf('month');
        let endOfMonth = moment().endOf('month');

        $('#date_range_block').data('daterangepicker').setStartDate(startOfMonth);
        $('#date_range_block').data('daterangepicker').setEndDate(endOfMonth);

        $('#date_range_block').val(
          startOfMonth.format('DD-MM-YYYY') + ' - ' + endOfMonth.format('DD-MM-YYYY')
        );
      } else {
        // Disable and clear
        $('#date_range_block').prop('disabled', true).val('');
      }
    });

    // Show value when applied
    $('#date_range_block').on('apply.daterangepicker', function (ev, picker) {
      $(this).val(picker.startDate.format('DD-MM-YYYY') + ' - ' + picker.endDate.format('DD-MM-YYYY'));
    });

    // Clear on cancel
    $('#date_range_block').on('cancel.daterangepicker', function (ev, picker) {
      $(this).val('');
    });

    // Prevent dropdown close when clicking anywhere inside search form
    $('#invoicesDropdown .dropdown-menu').on('click', function (e) {
      e.stopPropagation();
    });

    // ✅ Prevent close when clicking Apply/Cancel on date range picker
    $(document).on('click', '.daterangepicker .applyBtn, .daterangepicker .cancelBtn', function (e) {
      e.stopPropagation();
    });


    // Load saved filters
    loadSearchFilters(invoiceSearchformId, INVOICE_SEARCH_STORAGE_KEY);

    // Update count after loading
    updateSearchCount(invoiceSearchformId);

    $(`#${invoiceSearchformId}`).on("click", ".cancel-event", function () {
      const form = $(this).closest("form")[0];
      form.reset();
      updateSearchCount(invoiceSearchformId);
      transactionsTable.ajax.reload();
    });

    // Handle Show All
    $('.select-all').on('click', function (e) {
      const table = $('#staffInvoiceTable').DataTable();
      if ($(this).is(':checked')) {
        $('.show-default').prop('checked', false);
        $('.column-checkbox').each(function () {
          $(this).prop('checked', true);
          table.column($(this).data('column')).visible(true);
        });
      } else {
        // Prevent deselect if other not selected
        if (!$('.show-default').is(':checked')) {
          e.preventDefault();
          $(this).prop('checked', true);
        }
      }
    });

    $('#staff-invoices-sort-dropdown .sort-trigger').on('click', function (e) {
      const $btn = $(this);
      triggerSortClick(invoiceTable, $btn, 'staff-invoices-sort-dropdown', INVOICE_SORT_STORAGE_KEY);
    });

    // Search button click
    $(`#${invoiceSearchformId}`).on('submit', function (e) {
      e.preventDefault();
      saveSearchFilters(invoiceSearchformId, INVOICE_SEARCH_STORAGE_KEY);
      updateSearchCount(invoiceSearchformId, INVOICE_SEARCH_STORAGE_KEY);
      invoiceTable.ajax.reload();
      $(this).closest(".dropdown").find(".dropdown-toggle").dropdown("toggle");
    });

    // Clear button
    $('#invoicesDropdown .cancel-btn').on('click', function () {
      $(`#${invoiceSearchformId}`)[0].reset();
      $('.search-input:checkbox').prop('checked', false);
      localStorage.removeItem(INVOICE_SEARCH_STORAGE_KEY);
      updateSearchCount(invoiceSearchformId, INVOICE_SEARCH_STORAGE_KEY);
      invoiceTable.ajax.reload();
    });

    // Approve Invoice
    $(document).on("click", ".approve-invoice", function (e) {
      e.preventDefault();
      const id = $(this).data("id");
      
      Swal.fire({
        title: "Approve Invoice",
        text: "Are you sure you want to approve this invoice?",
        icon: "question",
        showCancelButton: true,
        confirmButtonText: "Yes, Approve",
        cancelButtonText: "Cancel",
        confirmButtonColor: "#28a745",
        cancelButtonColor: "#d33"
      }).then((result) => {
        if (result.isConfirmed) {
          $.ajax({
            url: `/staff-invoices/invoices/${id}/approve`,
            type: "POST",
            data: JSON.stringify({ status: 'approved' }),
            contentType: "application/json",
            success: function (res) {
              Swal.fire("Success", "Invoice approved successfully", "success");
              invoiceTable.ajax.reload();
            },
            error: function (err) {
              Swal.fire("Error", err.responseJSON?.message || "Failed to approve invoice", "error");
            }
          });
        }
      });
    });

    // Reject Invoice with Comment Popup
    $(document).on("click", ".reject-invoice", function (e) {
      e.preventDefault();
      const id = $(this).data("id");
      
      Swal.fire({
        title: "Reject Invoice",
        html: `
          <div style="text-align: left;" class="invoice_reject">
            <p>Are you sure you want to reject this invoice?</p>
            <label for="rejection-reason" style="font-weight: 500;">Reason for rejection:</label>
            <textarea id="rejection-reason" class="swal2-textarea" placeholder="Please provide a reason for rejection..." rows="4"></textarea>
          </div>
        `,
        icon: "warning",
        showCancelButton: true,
        confirmButtonText: "Yes, Reject",
        cancelButtonText: "Cancel",
        confirmButtonColor: "#dc3545",
        cancelButtonColor: "#6c757d",
        preConfirm: () => {
          const reason = document.getElementById('rejection-reason').value;
          if (!reason.trim()) {
            Swal.showValidationMessage('Please provide a reason for rejection');
            return false;
          }
          return { reason: reason };
        }
      }).then((result) => {
        if (result.isConfirmed) {
          $.ajax({
            url: `/staff-invoices/invoices/${id}/reject`,
            type: "POST",
            data: JSON.stringify({ 
              status: 'rejected',
              comment: result.value.reason 
            }),
            contentType: "application/json",
            success: function (res) {
              Swal.fire("Success", "Invoice rejected successfully", "success");
              invoiceTable.ajax.reload();
            },
            error: function (err) {
              Swal.fire("Error", err.responseJSON?.message || "Failed to reject invoice", "error");
            }
          });
        }
      });
    });

  });
</script>

