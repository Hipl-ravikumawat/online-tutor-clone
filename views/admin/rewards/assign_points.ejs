<div class="right_col mt-sm-3" role="main">
    <div class="back-page">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="javascript:void(0)">Rewards</a>
            </li>
            <li class="breadcrumb-item active">Assign Points</li>
        </ol>
    </div>

    <div class="bussniess_setting">
        <h2 class="titleheading"></h2>
        <div class="row">
            <div class="col-md-12 col-sm-12">
                <div class="x_panel">
                    <div class="x_content">
                        <div class="row">
                            <div class="col-md-6 col-sm-12">
                                <form id="assign-points-form">
                                    <input type="hidden" name="eventId" id="eventId" value="<%=eventId%>">
                                    <div class="form-group mt-3">
                                        <h2 class="title-text">Students</h2>
                                        <select class="form-control" name="attendees[]" id="attendees" multiple>
                                            <% for(let attendee of eventAttendees) { %>
                                                <option value="<%=attendee.student_id%>">
                                                    <%= `${attendee.first_name} ${attendee.last_name}` %>
                                                </option>
                                                <% } %>
                                        </select>
                                        <div class="wizard-form-error"></div>
                                    </div>
                                    <div class="card-box table-responsive allselect-table table-text-center">
                                        <h2 class="title-text">Points Table </h2>
                                        <table id="studentPoints"
                                            class="table table-striped table-bordered dt-responsive nowrap"
                                            cellspacing="0" width="100%">
                                            <thead>
                                                <tr>
                                                    <th>Task</th>
                                                    <th>Value</th>
                                                    <th>Earned</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td>Attending Class On Time</td>
                                                    <td><span class="studants-points">
                                                            <%= `${pointSystem.attendingClassOnTime}` %> Points
                                                        </span></td>
                                                    <td class="select-points">
                                                        <div class="studants-points-check">
                                                            <input type="checkbox" name="attendingClassOnTime"
                                                                id="attendingClassOnTime">
                                                            <label for="attendingClassOnTime"></label>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>Asking Questions</td>
                                                    <td><span class="studants-points">
                                                            <%= `${pointSystem.askingQuestions}` %> Points
                                                        </span></td>
                                                    <td class="select-points">
                                                        <div class="studants-points-check">
                                                            <input type="checkbox" name="askingQuestions"
                                                                id="askingQuestions">
                                                            <label for="askingQuestions"></label>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>Home Work Submission</td>
                                                    <td><span class="studants-points">
                                                            <%= `${pointSystem.homeworkSubmission}` %> Points
                                                        </span></td>
                                                    <td class="select-points">
                                                        <div class="studants-points-check">
                                                            <input type="checkbox" name="homeworkSubmission"
                                                                id="homeworkSubmission">
                                                            <label for="homeworkSubmission"></label>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>Participating In Class Activities</td>
                                                    <td><span class="studants-points">
                                                            <%= `${pointSystem.participatingClassActivities}` %> Points
                                                        </span></td>
                                                    <td class="select-points">
                                                        <div class="studants-points-check">
                                                            <input type="checkbox" name="participatingClassActivities"
                                                                id="participatingClassActivities">
                                                            <label for="participatingClassActivities"></label>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>Bonus Points</td>
                                                    <td><span class="studants-points">
                                                            <%= `${pointSystem.bonusPoints}` %> Points
                                                        </span></td>
                                                    <td class="select-points">
                                                        <div class="studants-points-check">
                                                            <input type="checkbox" name="bonusPoints" id="bonusPoints">
                                                            <label for="bonusPoints"></label>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                            <tfoot>
                                                <tr>
                                                    <td>Maximum Points Per Week</td>
                                                    <td><span class="students-points-total">
                                                            <%=performanceMetricsSum%> Points
                                                        </span></td>
                                                    <td class="select-total-points">00 Points</td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                    <div class="form-btn-group">
                                        <button type="button" class="bus-outline-btn" id="resetForm">Cancel</button>
                                        <button type="submit" class="btn form-button theme-btn"
                                            id="assignPointBtn">Save</button>
                                    </div>
                                </form>
                            </div>

                            <!--Students Rewards Summary-->
                            <% if(pointsHistory.length> 0) { %>
                                <div class="col-md-6 col-sm-12">
                                    <h2 class="title-text">Students Rewards Summary</h2>
                                    <div class="card-box table-responsive allselect-table table-text-center">
                                        <table id="studentPointtable"
                                            class="table table-striped table-bordered dt-responsive nowrap"
                                            cellspacing="0" width="100%">
                                            <tbody>
                                                <% for(let history of pointsHistory) { %>
                                                    <tr>
                                                        <td>
                                                            <%= `${history.studentId.first_name}
                                                                ${history.studentId.last_name}` %>
                                                        </td>
                                                        <td><span class="studants-points">
                                                                <%= history.totalPoints %> Points
                                                            </span></td>
                                                        <td>
                                                            <div
                                                                class="d-flex align-items-center justify-content-center">
                                                                <a href="javascript:void(0)"
                                                                    data-history-id="<%= history._id %>"
                                                                    data-history-id="<%= history._id %>"
                                                                    data-history-id="<%= history._id %>"
                                                                    data-toggle="tooltip" rel="tooltip"
                                                                    data-placement="top" title=""
                                                                    data-original-title="Edit Points" id="edit_points">
                                                                    <img src="/images/edit.svg" alt="icon">
                                                                </a>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <% } %>
                                    <!--Students Rewards Summary-->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    $(document).ready(function () {
        $("#attendees").select2({
            placeholder: "Select Students",
            allowClear: false,
        });

        const checkboxes = $('.studants-points-check input[type="checkbox"]');
        const totalPointsCell = $('.select-total-points');

        function updateTotalPoints() {
            let total = 0;

            checkboxes.each(function () {
                if ($(this).prop('checked')) {
                    const pointsText = $(this).closest('tr').find('.studants-points').text().trim();

                    // Extract the numeric value from the text (e.g., "10 Points" -> 10)
                    const points = parseInt(pointsText.replace(/\D/g, ''), 10); // Remove non-digit characters

                    // Ensure points is a valid number before adding it to total
                    if (!isNaN(points)) {
                        total += points;
                    }
                }
            });

            totalPointsCell.text(total + ' Points');
        }

        checkboxes.on('change', updateTotalPoints);

        updateTotalPoints();
    });

    function resetForm() {
        $("#assign-points-form")[0].reset();
        $('#attendees').val(null).trigger('change');
    }

    $(document).on('click', '#edit_points', function (e) {
        e.preventDefault();
        // resetForm();
        $("#assign-points-form").trigger("reset");
        let pointHistoryId = $(this).data('history-id');
        $.ajax({
            type: "GET",
            url: "/rewards/fetch-assigned-points/" + pointHistoryId,
            success: function (response) {
                if (response.success === true) {
                    const selectedStudentId = response.record.studentId._id; // Get the student ID from the response
                    const pointsAssigned = response.record.pointsAssigned;
                    $('#attendees').val([selectedStudentId]).trigger('change');

                    if (pointsAssigned.attendingClassOnTime.marks > 0) {
                        $('#attendingClassOnTime').prop('checked', true);
                    }

                    if (pointsAssigned.askingQuestions.marks > 0) {
                        $('#askingQuestions').prop('checked', true);
                    }

                    if (pointsAssigned.homeworkSubmission.marks > 0) {
                        $('#homeworkSubmission').prop('checked', true);
                    }

                    if (pointsAssigned.participatingClassActivities.marks > 0) {
                        $('#participatingClassActivities').prop('checked', true);
                    }

                    if (pointsAssigned.bonusPoints.marks > 0) {
                        $('#bonusPoints').prop('checked', true);
                    }

                    $('.select-total-points').text(response.record.totalPoints + ' Points');
                }
            },
            error: function (jqXHR, textStatus, errorThrown) {
                let errorMessage;
                if (jqXHR.status === 404) {
                    errorMessage = "Points not found.";
                } else if (jqXHR.status === 500) {
                    errorMessage = "Internal server error. Please try again later.";
                } else {
                    errorMessage = "An unexpected error occurred: " + textStatus;
                }
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: errorMessage,
                });
            },
            complete: function () {
                $(".loader").hide();
            },
        });
    });

    $('#resetForm').on('click', function (e) {
        e.preventDefault();
        resetForm();
    });

    $('#assign-points-form').submit(function (e) {
        e.preventDefault();
        var formData = $('#assign-points-form').serialize();
        let url = `/rewards/store-assigned-points`;
        $('#assignPointBtn').prop('disabled', true);
        $.ajax({
            type: "post",
            url: url,
            dataType: "json",
            data: formData,
            success: function (response) {
                if (response.success === true) {
                    window.location.reload();
                }
            },
            error: function (response) {
                $(document).find('.text-danger').remove();
                if (response.responseJSON.errors) {
                    $.each(response.responseJSON.errors, function (index, error) {
                        if (error.param != '') {
                            $(document).find(`#${error.param}`).after(`<span class="help-block text-danger">${error.msg}</span>`);
                        } else {
                            $(document).find(`#studentPoints`).before(`<span class="help-block text-danger">${error.msg}</span>`);
                        }
                    });
                }

                if (response.responseJSON.message) {
                    $(document).find(`#studentPoints`).before(`<span class="help-block text-danger">${error.msg}</span>`);
                }

            },
            complete: function (response) {
                $('#assignPointBtn').prop('disabled', false);
            }
        });
    });
</script>