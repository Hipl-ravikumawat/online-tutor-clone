<!-- dropIfy-->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Dropify/0.2.2/js/dropify.js"></script>

<!-- intlTelInput -->
<script type="text/javascript" src="/vendors/intlTelInput/js/intlTelInput.js"></script>
<script type="text/javascript" src="/vendors/intlTelInput/js/utils.js"></script>

<script type="text/javascript">
  /**
   * tutor form script.
   * @script start
   */
  $(document).ready(function () {
    $("#title").select2({
      allowClear: false,
    });

    $("#subject_ids").select2({
      placeholder: "Select Subjects",
      allowClear: false,
    });

    $("#status").select2({
      placeholder: "Select Status",
      allowClear: false,
    });

    $("#gender").select2({
      placeholder: "Select Gender",
      allowClear: false,
    });

    $("#time_zone").select2({
      placeholder: "Select TimeZone",
      allowClear: false,
    });

    $('.dropify').dropify();
    
    $('.dropify-clear').on('click', function () {
      $('#is_image_removed').val('1');
      $('.dropify').attr('required', true);
    });

  });

  const errorMap = [  // Define errorMap outside the block
    "Invalid number",
    "Invalid country code",
    "Too short",
    "Too long",
    "Invalid number",
  ];

  var input = document.querySelector("#phone"),
  result = document.querySelector("#error-msg");

  window.addEventListener("load", function () {
    errorMsg = document.querySelector("#error-msg");
    function getIp(callback) {
      fetch("https://ipinfo.io", {
        headers: {
          Accept: "application/json",
        },
      })
        .then((resp) => resp.json())
        .catch(() => {
          return {
            country: "",
          };
        })
        .then((resp) => callback(resp.country));
    }

    let iso_code = $("#iso_code").val();
    let current_iso_code = iso_code ? iso_code : "Au";
    var iti = window.intlTelInput(input, {
      initialCountry: current_iso_code,
      separateDialCode: true,
    });
    var defaultNumber = "<%=data.phone%>"; 
    $('#phone').val(defaultNumber); 
    if (iso_code !== "" && iso_code !== undefined && iso_code !== null) {
      input.addEventListener("keyup", function () {
        reset();
        $("#updateTutorBtn").prop("disabled", false);
        if (input.value.trim()) {
          if (iti.isValidNumber()) {
            $("#updateTutorBtn").prop("disabled", false);
            $(input).addClass("is-valid");
          } else {
            $("#updateTutorBtn").prop("disabled", true);
            $(input).addClass("is-invalid");
            var errorCode = iti.getValidationError();
            errorMsg.innerHTML = errorCode > 4 ? 'Invalid number' : errorMap[errorCode];
            $(errorMsg).show();
          }
        }
      });
    } else {
      input.addEventListener("keyup", function () {
        reset();
        console.log(iti.isValidNumber(), 'Check number');
        if (input.value.trim()) {
          if (iti.isValidNumber()) {
            $("#storeTutorBtn").prop("disabled", false);
            $(input).addClass("is-valid");
          } else {
            $("#storeTutorBtn").prop("disabled", true);
            $(input).addClass("is-invalid");
            var errorCode = iti.getValidationError();
            errorMsg.innerHTML = errorCode > 4 ? 'Invalid number' : errorMap[errorCode];
            $(errorMsg).show();
          }
        }
      });
    }

    input.addEventListener("change", reset);
    input.addEventListener("keyup", reset);

    var reset = function () {
      $(input).removeClass("is-invalid");
      errorMsg.innerHTML = "";
      $(errorMsg).hide();
    };

    input.addEventListener(
      "keyup",
      function (e) {
        e.preventDefault();
        var num = iti.getNumber(),
          valid = iti.isValidNumber();
      },
      false
    );

    input.addEventListener(
      "focus",
      function () {
        result.textContent = "";
      },
      false
    );

    $(input).on("focusout", function (e, countryData) {
      var intlNumber = iti.getNumber();
      var countryData = iti.getSelectedCountryData();
      var dialCode = countryData.dialCode;
      var iso2 = countryData.iso2;
      $("#dial_code").val(dialCode); 
      $("#iso_code").val(iso2);
    });
  });

  $(document).ready(function() {
  // Select the color picker and color code span elements using jQuery
  var colorPicker = $('#colorPicker');
  var colorCodeSpan = $('#colorCode');

  // Update the color code span on initial load
  updateColorCode();

  // Bind the updateColorCode function to the color picker's 'input' event
  colorPicker.on('input', updateColorCode);

  function updateColorCode() {
    // Get the selected color value from the color picker
    var selectedColor = colorPicker.val();
    
    // Update the color code span text content
    colorCodeSpan.text(selectedColor);
    colorPicker.val(colorCodeSpan.text());

  }
  });
  /**
   * tutor form script.
   * @script end
   */
  
</script>