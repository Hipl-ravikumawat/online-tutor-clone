<script type="text/javascript">
 let loggedUserInfo = <%- JSON.stringify(loggedUserInfo) %>;
 

  function fetchWeekAgenda() {
    $.ajax({
      type: 'GET',
      url: '/dashboard/week-agenda',
      success: function (response) {
        // console.log(response, 'success');
        $('.week-agenda').html(response.contentHtml);
      },
      error: function (response) {
        Swal.fire({
          title: 'Oops...',
          text: response.responseJSON.message,
        });
      },
      complete: function () {
      }
    });
  }

  $(document).ready(function () {
    <% if (loggedUserInfo.role === 1 || loggedUserInfo.role === 3) { %>
      fetchWeekAgenda();
      <% } %>

      <% if (loggedUserInfo.role === 2) { %>
        // Get today's date in YYYY-MM-DD format
        let savedDate = localStorage.getItem('tutor_events_selected_date');

        let initialDate = (
          savedDate && savedDate !== ""
        )
          ? savedDate
          : moment().format('YYYY-MM-DD');

        fetchTutorEvents(initialDate);
      <% } %>
  });
  

  $(document).on('click', '.cancel-events', function () {
    let eventId = $(this).data('event-id');
    $("#eventId").val(eventId); $("#cancelEventReason").modal('show'); //
    cancelEventConfirmation(eventId, 'dashboard');
  }); $("#cancel-an-event").submit(function (e) {
    e.preventDefault();
    let eventId = $("#eventId").val(); let cancelNoteForTutor = $("#cancel-note-for-tutor").val(); $('.error').remove();
    if (cancelNoteForTutor.trim() === '') {
      $("#cancel-note-for-tutor").after('<span class="error" style="color:red;">This field is required</span > ');
      return false;
    }
    $.ajax({
      type: "POST",
      url: '/calendar/cancel-this-event',
      data: {
        eventId: eventId,
        status: 'Requested_To_Cancel',
        cancelNoteForTutor: cancelNoteForTutor,
        loggedUserInfo: loggedUserInfo,
      },
      success: function (response) {
        Swal.fire({
          title: "Requested To Cancel!",
          text: response.message,
          icon: "success"
        });
        $("#cancel-note-for-tutor").val("");
        $("#cancelEventReason").modal('hide');

        // Reload the page after a brief delay
        if (response.redirectUrl === 'page-reload') {
          setTimeout(() => {
            window.location.reload();
          }, 2000);
        }
      },
      error: function (response) {
        Swal.fire({
          icon: "error",
          title: "Oops..,",
          text: response.message,
        });
      },
      complete: function () {
      }
    })
  })

  



  // Jquery for bottom new section
  let defaultStart = moment();
  $('#hidden-date-input').daterangepicker({
    singleDatePicker: true,
    showDropdowns: true,
    startDate: defaultStart,
    // autoUpdateInput: false,
    locale: {
      format: 'DD-MM-YYYY'
    }
  }, function (start, end, label) {
    let formattedDate = start.format('YYYY-MM-DD');
    localStorage.setItem("family_account_filter_date", formattedDate);
    $('#hidden-date-input').val(start.format('DD-MM-YYYY'));
    $('#display-date').text(start.format('DD-MM-YYYY'));
  });
  $('#hidden-date-input').val(defaultStart.format('DD-MM-YYYY'));
  $('#display-date').text(defaultStart.format('DD-MM-YYYY'));
  localStorage.setItem("family_account_filter_date", defaultStart.format('YYYY-MM-DD'));

  // Tutor datepicker
  let savedDate = localStorage.getItem('tutor_events_selected_date');

  let tutorDefault = (
    savedDate && savedDate !== ""
  )
    ? moment(savedDate, 'YYYY-MM-DD')
    : moment();
    
  $('#tutor-date-input').daterangepicker({
    singleDatePicker: true,
    showDropdowns: true,
    startDate: tutorDefault,
    // autoUpdateInput: false,
    locale: {
      format: 'DD-MM-YYYY'
    }
  }, function (start, end, label) {
    let formattedDate = start.format('YYYY-MM-DD');
    $('#tutor-date-input').val(start.format('DD-MM-YYYY'));
    $('#tutor-display-date').text(start.format('DD-MM-YYYY'));

    localStorage.setItem('tutor_events_selected_date',formattedDate);

    fetchTutorEvents(formattedDate);
  });

  $('#tutor-date-input').val(tutorDefault.format('DD-MM-YYYY'));
  $('#tutor-display-date').text(tutorDefault.format('DD-MM-YYYY'));


  function fetchTutorEvents(date) {
    $.ajax({
      type: 'GET',
      url: '/dashboard/tutor-events?date=' + date,
      success: function (response) {
        $('.scheduled_event_card').html(response.contentHtml);
      },
      error: function (response) {
        Swal.fire({
          title: 'Oops...',
          text: response.responseJSON.message,
        });
      }
    });
  }

  // 
  $('.dropdown-header').click(function () {
    $('.dropdown-list').slideToggle(150);
  });

  $('.dropdown-item-block').click(function () {
    $('.dropdown-item-block').removeClass('selected');
    $('.dropdown-item-block .check').remove();
    $(this).addClass('selected');
    $(this).append('<span class="check">✔</span>');
    let text = $(this).clone().children().remove().end().text().trim();
    $('.dropdown-header .drop_value').text(text);
    $('.dropdown-list').slideUp(150);
  });

  $(document).click(function (e) {
    if (!$(e.target).closest('.custom-dropdown').length) {
      $('.dropdown-list').slideUp(150);
    }
  });


// Date navigation - Previous day
$('.prev-day').on('click', function() {
    const currentDate = $('#tutor-date-input').val(); // Format: DD-MM-YYYY
    const currentMoment = moment(currentDate, 'DD-MM-YYYY');
    const newDate = currentMoment.subtract(1, 'day');
    
    const formattedDate = newDate.format('DD-MM-YYYY');
    const apiDate = newDate.format('YYYY-MM-DD');
    
    // Update the date input and display
    $('#tutor-date-input').val(formattedDate);
    $('#tutor-display-date').text(formattedDate);
    
    // Fetch events for the new date
    fetchTutorEvents(apiDate);
});

// Date navigation - Next day
$('.next-day').on('click', function() {
    const currentDate = $('#tutor-date-input').val(); // Format: DD-MM-YYYY
    const currentMoment = moment(currentDate, 'DD-MM-YYYY');
    const newDate = currentMoment.add(1, 'day');
    
    const formattedDate = newDate.format('DD-MM-YYYY');
    const apiDate = newDate.format('YYYY-MM-DD');
    
    // Update the date input and display
    $('#tutor-date-input').val(formattedDate);
    $('#tutor-display-date').text(formattedDate);
    
    // Fetch events for the new date
    fetchTutorEvents(apiDate);
});

// Optional: Click on "Today" text to go back to current date
$('.sche_day').on('click', function() {
    const today = moment();
    const formattedDate = today.format('DD-MM-YYYY');
    const apiDate = today.format('YYYY-MM-DD');
    
    $('#tutor-date-input').val(formattedDate);
    $('#tutor-display-date').text(formattedDate);
    
    fetchTutorEvents(apiDate);
});

