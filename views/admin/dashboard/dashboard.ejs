<div class="modal fade common-modal modal-label-style" data-backdrop="static" id="cancelEventReason" tabindex="-1" role="dialog" aria-labelledby="cancelModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title" id="cancelModalLabel">Cancel An Event</h3>
      </div>
      <form id="cancel-an-event" class="modal-form-area" method="post" >
        <div class="modal-body">
          <div class="common-form settings_content">
            <input type="hidden" name="eventId" id="eventId" required>
            <div class="form-group position-relative">
              <label for="Note to Tutor">Note to Tutor</label>
                <div class="form-floating">
                  <textarea class="form-control" placeholder="Leave a comment here" id="cancel-note-for-tutor"></textarea>
                </div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <div class="btn-leftarea"></div>
          <div class="btn-rightarea d-flex flex-wrap">
            <button type="submit" class="bus-outline-btn mb-2 mr-2">Submit</button>
            <button type="button" class="bus-outline-btn mb-2 mr-2" data-dismiss="modal">Cancel</button>
            <div class="delete-event-btn"></div>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<div class="modal fade common-modal" id="pendingLeaves" data-backdrop="static" data-keyboard="false" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-none">
      <div class="modal-header">
        <h5 class="modal-title title_style">Tutor Pending Leave</h5>
        <button type="button" class="close p-0 m-0 opacity-100" data-dismiss="modal" aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M18 6L6 18" stroke="#4A4674" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            <path d="M6 6L18 18" stroke="#4A4674" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <div class="pending-leave-dropdown">
          <% if (staticesData?.pendingLeaveTutors?.length > 0) { %>
            <ul>
              <% staticesData.pendingLeaveTutors.forEach(function(item) { %>
                <li>
                  <a href="/tutor-preferences/<%= item.tutor_id?._id %>#tutor-leaves" class="pending-leave-item">
                      <%= item.tutor_id?.first_name %>
                      <%= item.tutor_id?.last_name %>
                      <br>
                      <small class="text-muted">
                       <%= moment(item.start_date).format('DD MMM YYYY') %>
                        -
                        <%= moment(item.end_date).format('DD MMM YYYY') %>
                      </small>
                  </a>
                </li>
              <% }) %>
            </ul>
          <% } else { %>
            <p class="mb-0 not_pending_leave_text">
              No pending leave requests
            </p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

