<div class="right_col" role="main">
  <div class="max-w-1440">
    <div class="row">
      <div class="col-sm-12 col-md-6 col-lg-4 col-xl-3">
        <div class="stcard-box">
          <span class="shade5">
            <%=assessmentObject.total%>
          </span>
          <h3 class="title-text mb-0">Total</h3>
          <img src="/images/favicon-32x32.png" class="hidden-bg">
        </div>
      </div>
      <div class="col-sm-12 col-md-6 col-lg-4 col-xl-3">
        <div class="stcard-box">
          <span class="shade1">
            <%=assessmentObject.completed%>
          </span>                 
          <h3 class="title-text mb-0">Completed</h3>
          <img src="/images/favicon-32x32.png" class="hidden-bg">
        </div>
      </div>
      <div class="col-sm-12 col-md-6 col-lg-4 col-xl-3">
        <div class="stcard-box">
          <span class="shade2">
            <%=assessmentObject.pending%>
          </span>
          <h3 class="title-text mb-0">Pending</h3>
          <img src="/images/favicon-32x32.png" class="hidden-bg">
        </div>
      </div>
      <div class="col-sm-12 col-md-6 col-lg-4 col-xl-3">
        <div class="stcard-box">
          <span class="shade3">
            <%=assessmentObject.not_completed%>
          </span>
          <h3 class="title-text mb-0">Not Completed</h3>
          <img src="/images/favicon-32x32.png" class="hidden-bg">
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-md-12 col-sm-12">
        <div class="x_panel">
          <div class="filter_top">
            <h2 class="title-text">Filter Homework</h2>
            <ul class="filter-row">
              <li class="filter-col">
                <select class="form-control select2" id="assessment" tabindex="-1" data-placeholder="Select An Homework">
                  <option value="">Select An Assessment</option>
                  <% for(assessment of assessments) { %>
                    <option value="<%=assessment.id%>">
                      <%=assessment.name %>
                    </option>
                    <% } %>
                </select>
              </li>
              <%if(loggedUserInfo.role !=2) { %>
              <li class="filter-col">
                <select class="form-control select2" id="tutor" tabindex="-1" data-placeholder="Select Tutor">
                  <option value="">Select Tutor</option>
                  <% for(tutor of tutors) { %>
                    <option value="<%=tutor.id%>">
                      <%=tutor.first_name+' '+tutor.last_name %>
                    </option>
                    <% } %>
                </select>
              </li>
              <% } %>
              <%if(loggedUserInfo.role !=3) { %>
              <li class="filter-col">
                <select class="form-control select2" id="status" tabindex="-1" data-placeholder="Select Status">
                  <option value="">Select Status</option>
                    <option value="N/A">N/A</option>
                    <option value="Processing">Processing</option>
                    <option value="Completed">Completed</option>
                </select>
              </li>
              <% } %>
              <li class="filter-col filter-col-btn">
                <button class="btn theme-btn filter">Filter</button>
                <button class="btn theme-btn reset">Reset</button>
              </li>
            </ul>
          </div>
          <div class="x_title">
            <h2 class="title-text mb-0">Homework List</h2>

            <%if(loggedUserInfo.role !=3) { %>
            <ul class="right-btns">
              <li> <a href="/assessments/create" class="btn theme-btn" data-toggle="tooltip" rel="tooltip"
                  data-placement="top" title="Assign Homework">+ Assign</a>
              </li>
            </ul>
            <% } %>
          </div>
          <div class="x_content">
            <div class="row">
              <div class="col-sm-12">
                <div class="card-box table-responsive">
                  <table id="assessmentTable" class="table table-striped table-bordered dt-responsive nowrap" cellspacing="0"
                  width="100%">
                    <thead>
                      <tr>
                        <th>Homework Title</th>
                        <th>Assigned Tutor</th>
                        <th>Apply Duration</th>
                        <th>Status</th>
                        <th>Assessment Period</th>
                        <th>Created At</th>
                        <th class="text-center action-btn">Action</th>
                      </tr>
                    </thead>
                  <tbody> 
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('./partials/model_assessment_lessons'); %>

<%- include('./partials/model_assessment_lessons_content'); %>

<%- include('./index_script'); %>
