<div class="modal fade bussiness-setting-modal" id="salesTax" tabindex="-1" role="dialog" aria-labelledby="salesTaxLabel" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h3 class="modal-title" id="salesTaxLabel">Add Sales Tax</h3>
          <button type="button" class="modal_close" data-dismiss="modal">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M6.04289 16.5413C5.65237 16.9318 5.65237 17.565 6.04289 17.9555C6.43342 18.346 7.06658 18.346 7.45711 17.9555L11.9987 13.4139L16.5408 17.956C16.9313 18.3466 17.5645 18.3466 17.955 17.956C18.3455 17.5655 18.3455 16.9323 17.955 16.5418L13.4129 11.9997L17.955 7.4576C18.3455 7.06707 18.3455 6.43391 17.955 6.04338C17.5645 5.65286 16.9313 5.65286 16.5408 6.04338L11.9987 10.5855L7.45711 6.0439C7.06658 5.65338 6.43342 5.65338 6.04289 6.0439C5.65237 6.43442 5.65237 7.06759 6.04289 7.45811L10.5845 11.9997L6.04289 16.5413Z" fill="currentColor"></path></svg>
          </button>
        </div>
        <form method="post" action="/business-settings/store-sales-tax">
            <input type="hidden" name="uniqueId" value="<%=businessSetting?.id%>" />
            <div class="modal-body">
                <div class="form-area">
                    <div class="form-group">
                        <label>Tax Name*</label>
                        <input type="text" placeholder="Tax Name" name="tax_name" class="title" />
                    </div>
                    <div class="form-group">
                        <label>Tax Rate(%)*</label>
                        <input type="number" placeholder="Tax Rate" name="tax_rate" class="title" step="any" max="100" min="0"
                         oninput="if(this.value > 100) this.value = 100; if(this.value < 0) this.value = 0;"
                        />
                    </div>
                </div>
            </div>
          <div class="modal-footer">
            <div class="btn-leftarea">
              <!-- <button type="button" class="restore-btn">Restore Default Template</button> -->
            </div>
            <div class="btn-rightarea">
              <button type="button" data-dismiss="modal" class="btn theme-btn hide-btnss cancel-btn">Cancel</button>
              <button type="button" class="btn theme-btn hide-btnss submit-custum">Save</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>