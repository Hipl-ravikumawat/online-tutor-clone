$(document).ready(function() {
  $("input[name=balance_date_type]").on('change', function(){
    let selectedVal = $("input[name=balance_date_type]:checked").val();
    if(selectedVal == "day_of_month"){
      $('#specific_day_box').show();
      $('#specific_date_box').hide();
      $('#specific_date_box').find('#specific_date').val('');
    }else if(selectedVal == "specific_date"){
      $('#specific_date_box').show();
      $('#specific_day_box').hide();
      $('#specific_day_box').find('#specific_day').val('');
    }else{
      $('#specific_date_box').hide();
      $('#specific_day_box').hide();
      $('#specific_date_box').find('#specific_date').val('');
      $('#specific_day_box').find('#specific_day').val('');
    }
  });

  $("input[name=balance_date_type]").trigger('change');

  $(".select2_multiple_with_tags").select2({
    width:'100%',
    placeholder: "e.g. Cash",
    allowClear: true,
    tags: true,
    tokenSeparators: [',']
  });
  
  // Handle click event for edit setting elements
  $(".editsetting").on("click", function() {
    var tabcardParent = $(this).closest(".tabcard");
    if (tabcardParent.length > 0) {
      tabcardParent.toggleClass("active");

      // Get all input fields within the tabcard
      var inputFields = tabcardParent.find("input,select,textarea");

      // Toggle disabled attribute on input fields
      inputFields.prop("disabled", !tabcardParent.hasClass("active"));
    }
  });

  // Handle click event for Cancel button
  $(".cancel-btn").on("click", function() {
    var tabcardParent = $(this).closest(".tabcard");
    if (tabcardParent.length > 0) {
      tabcardParent.removeClass("active");

      // Get all input fields within the tabcard
      var inputFields = tabcardParent.find("input,select,textarea");

      // Disable all input fields
      inputFields.prop("disabled", true);
    }
  });

  // Handle click event for Save button
  $(".save-btn").on("click", function() {
    let tabcardParent = $(this).closest(".tabcard");

    saveBusinessSettings($(this), function(success) {
        if (success && tabcardParent.length > 0) {
            tabcardParent.removeClass("active").addClass("change_value");
            var inputFields = tabcardParent.find("input,select,textarea");
            inputFields.prop("disabled", true);
        }
    });
  });
});

