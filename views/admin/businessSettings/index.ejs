function updateTemplateValidation(element){
  let editorId = element.find('.editorExplanation').attr('id');
  let editor = tinymce.get(editorId);

  // check validation for email template
  let isValid = true;
  $('.error').remove();
  if(editor){    
    let content = editor.getContent({format: "text"}).trim();
    let subject = element.find('.subject').val().trim();

    if(subject == ''){
      isValid = false;
      element.find('.subject').after('<p class="error" style="color:red;">This field is required</p>');
    }
    if(content ==''){
      isValid = false;
      element.find('.editorExplanation').after('<p class="error" style="color:red;">This field is required</p>');
    }
  }else{
    let content = element.find('#message').val();
    if(content ==''){
      isValid = false;
      element.find('#message').after('<p class="error" style="color:red;">This field is required</p>');
    }
  }
  return isValid;
}

