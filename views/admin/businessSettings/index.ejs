$('.cus-sms-default-editor').on('input', function() {
  let contentLength = this.value.length;
  let remainingLength = 140 - contentLength;
  $('.characters-len').text(contentLength);
  $('.remaining-characters-len').text(Math.max(0, remainingLength));
  $('.theme-btn.hide-btnss').prop('disabled', remainingLength < 0);
});

// Function to insert text at cursor position
function insertTextAtCursor(textarea, text) {
  let cursorPos = textarea.selectionStart;
  let content = textarea.value;
  let newText = content.substring(0, cursorPos) + text + content.substring(textarea.selectionEnd);
  textarea.value = newText;
  // Set the cursor position after insertion
  textarea.setSelectionRange(cursorPos + text.length, cursorPos + text.length);
}
// Keyup event for textarea
$(document).ready(function () {
  function updateCharCount() {
    let contentLength = $('.sms-default-editor').val().length;
    let remainingLength = 140 - contentLength;
    $('.characters-len').text(contentLength);
    $('.remaining-characters-len').text(Math.max(0, remainingLength));
    $('.theme-btn.hide-btnss').prop('disabled', remainingLength < 0);
  }

  // Run on input
  $(document).on('input', '.sms-default-editor', function () {
    updateCharCount();
  });

  // Run when modal opens
  $('#systemSMS').on('shown.bs.modal', function () {
    updateCharCount();
  });
});


// Function to update the invoice preview
function updateInvoicePreview() {
    const format = $('#invoicenumbers').val();
    const nextNum = $('#nextInvoiceNumbers').val();
    
    // Get current date components
    const now = new Date();
    const fullYear = now.getFullYear();
    const shortYear = fullYear.toString().substring(2);
    const month = (now.getMonth() + 1).toString().padStart(2, '0');
    const day = now.getDate().toString().padStart(2, '0');
    
    // Determine padding based on the token used
    const hasNNNN = format.includes('%NNNN%');
    const sequenceLength = hasNNNN ? 4 : 2;
    const sequence = nextNum.toString().padStart(sequenceLength, '0');
    
    // Replace tokens in the format
    let preview = format
        .replace(/%YYYY%/g, fullYear)
        .replace(/%YY%/g, shortYear)
        .replace(/%MM%/g, month)
        .replace(/%DD%/g, day)
        .replace(/%NNNN%/g, sequence)  // Handle 4-digit sequence first
        .replace(/%NN%/g, sequence.substring(0, 2)); // Then handle 2-digit sequence
    
    // Update the preview display
    $('#invoice_number_preview').text(preview);
}

updateInvoicePreview();
$('#invoicenumbers, #nextInvoiceNumbers').on('input', function() {
  updateInvoicePreview();
});



