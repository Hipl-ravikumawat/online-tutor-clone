function setCurrentTab(){
  let currentTab = $('.business-setting-tab.active').attr('id');
  sessionStorage.setItem('tabData', currentTab);
}
(function(){
  const storedUser = sessionStorage.getItem('tabData');
  let currentTab = storedUser;
  if(currentTab !='' && currentTab != null){
    $(`#${currentTab}`).trigger('click');
  }
})();
</script>