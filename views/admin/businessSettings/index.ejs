$(function() {
  $(".preview-btns").on("click", function(){
    $(this).toggleClass("preview-active");
    if($(this).hasClass("preview-active")){
      $(this).text("Close");
      tinymce.activeEditor.setMode('readonly');
      $(this).parents(".modal-footer").prev(".modal-body").find("label+input").attr('disabled', true);
      $(this).parents(".modal-footer").find(".btn-leftarea button, .btn-rightarea .hide-btnss").css("display", "none");
    } else {
      $(this).text("Preview");
      tinymce.activeEditor.setMode('design');
      $(this).parents(".modal-footer").prev(".modal-body").find("label+input").attr('disabled', false);
      $(this).parents(".modal-footer").find(".btn-leftarea button, .btn-rightarea .hide-btnss").css("display", "inline-block");
    }
  });
});


