<!-- location modal -->
<div class="modal fade common-modal" data-backdrop="static" id="addCalendarLocation" tabindex="-1" role="dialog" aria-labelledby="addCalendarLocationLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h3 class="modal-title" id="addCalendarLocationLabel">Location Form</h3>
        </div>
        <form class="modal-form-area common-form"  id="location-form" action="/location/store" method="post">
          <div class="modal-body settings_content">
            <input type="hidden" name="location_id" value="" class="location-id">
            <div class="pt-1">
                <div class="form-group">
                    <label class="mb-1">Name</label>
                    <input type="text" name="name" id="name" class="name" autocomplete="off" placeholder="Enter Location Name">
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="mb-1">Icon</label>
                            <div class="drop-down">
                                <input type="hidden" name="icons" id="icons" value="/images/locationIcons/default.svg" class="location-icons">
                                <div class="selected icons-selected">
                                    <img class="loc-icons"src="/images/locationIcons/default.svg"/> Default Icon
                                </div>
                                <div class="drop-options">
                                    <ul>
                                        <li>
                                            <a href="javascript: void(0)">
                                                <img class="loc-icons"src="/images/locationIcons/default.svg"/> Default Icon
                                            </a>
                                        </li>
                                        <li>
                                            <a href="javascript: void(0)">
                                                <img class="loc-icons" src="/images/locationIcons/home.svg"/>
                                            </a>
                                        </li>
                                        <li>
                                            <a href="javascript: void(0)">
                                                <img class="loc-icons" src="/images/locationIcons/building.svg"/>
                                            </a>
                                        </li>
                                        <li>
                                            <a href="javascript: void(0)">
                                                <img class="loc-icons" src="/images/locationIcons/car.svg"/>
                                            </a>
                                        </li>
                                        <li>
                                            <a href="javascript: void(0)">
                                                <img class="loc-icons" src="/images/locationIcons/star.svg"/>
                                            </a>
                                        </li>
                                        <li>
                                            <a href="javascript: void(0)">
                                                <img class="loc-icons" src="/images/locationIcons/camera.svg"/>
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="mb-1">Color</label>
                            <div class="drop-down">
                                <input type="hidden" name="color" id="color"value="purple" class="color location-color">
                                <div class="selected"><a href="javascript: void(0)" class="color-selected"><span class="color-block background-purple">Purple</span></a></div>
                                <div class="drop-options">
                                    <ul>
                                        <li><a href="javascript: void(0)"><span class="color-block background-purple">Purple</span></a></li>
                                        <li><a href="javascript: void(0)"><span class="color-block background-orange">Orange</span></a></li>
                                        <li><a href="javascript: void(0)"><span class="color-block background-blue">Blue</span></a></li>
                                        <li><a href="javascript: void(0)"><span class="color-block background-black">Black</span></a></li>
                                        <li><a href="javascript: void(0)"><span class="color-block background-red">Red</span></a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="form-group cselect-arrow">
                    <label class="mb-1">Location Type</label>
                    <select id="select_location_type" name="location_type" id="location_type">
                        <option>No Address</option>
                        <option value="student_address">Student's Address</option>
                        <option value="specify_address">Specify an Address</option>
                        <option value="virtual_meeting">Virtual Meeting</option>
                    </select>
                </div>
                <div class="form-group" id="specify_address_area" style="display: none;">
                    <label for="">Specify An Address</label>
                    <textarea name="specific_address_details" id="specific_address_details"></textarea>
                </div>
            </div>
          </div>
          <div class="modal-footer">
            <div class="btn-leftarea">
            </div>
            <div class="btn-rightarea">
              <button type="button" data-dismiss="modal" class="bus-outline-btn">Cancel</button>
              <button type="submit" class="btn theme-btn location-save">Save</button>
            </div>
          </div>
        </form>
      </div>
    </div>
</div>