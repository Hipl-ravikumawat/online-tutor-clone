<script src="https://cdn.jsdelivr.net/npm/fullcalendar-scheduler@6.1.15/index.global.min.js"></script>
<script>
  const allTutors = <%- JSON.stringify(tutors) %>;
    
    const getColorFromId = (id) => {
      const str = id.toString(); 

      let hash = 0;
      for (let i = 0; i < str.length; i++) {
        hash = str.charCodeAt(i) + ((hash << 5) - hash);
      }

      const hue = Math.abs(hash) % 360;
      return `hsl(${hue}, 65%, 55%)`;
    };

    const allUsers = allTutors.map((user) => {

      const userColor = user.calendar_color
        ? user.calendar_color.trim().toLowerCase()
        : "";

      const isWhiteColor =
        userColor === "#fff" ||
        userColor === "#ffffff" ||
        userColor === "white";

      return {
        id: user.id,
        title: user.title,
        color:
          userColor && !isWhiteColor
            ? user.calendar_color
            : getColorFromId(user.id)
      };
    });

    const selectAllTutors = document.getElementById("selectAllTutors");

    function syncSelectAllCheckbox() {
      selectAllTutors.checked = selectedUsers.length === allUsers.length;
    }

    let selectedUsers = JSON.parse(localStorage.getItem('availabilitySelectedTutors')) || (allUsers.length > 0 ? [allUsers[0].id] : []);
    let tutorColors = {};
    allUsers.forEach(function(user) {
      tutorColors[user.id] = user.color; 
    });
    let currentView = "resourceTimeGridDay";
    let currentDate = new Date();
    let calendar = null;
    let userSearchText = "";

    let selectedTimeFrom = "";
    let selectedTimeTo   = "";
    let excludedDays = [];

    const tooltip = document.getElementById("tooltip");
    const tooltip2 = document.getElementById("tooltip2");
    const userList = document.getElementById("userList");
    const viewSelect = document.getElementById("viewSelect");
    const calendarEl = document.getElementById("calendar");
    const userSearch = document.getElementById("userSearch");

    let activeEvent = null;
    let activeEventEl = null;
    let scrollContainers = [];

    document.querySelectorAll(".days-checkbox").forEach(function(checkbox) {
      checkbox.addEventListener("change", function() {
        const day = parseInt(this.value);
        if (this.checked) {
          excludedDays = excludedDays.filter(d => d !== day);
        } else {
          if (!excludedDays.includes(day)) excludedDays.push(day);
        }
        calendar.refetchEvents();
      });
    });

    const daysFilterRow = document.getElementById("daysFilterRow");

    function syncDaysFilterVisibility() {
      const isDayView = currentView === "resourceTimeGridDay";
      daysFilterRow.classList.toggle("visible", !isDayView);
    }

    function eventPassesFilters(startDate, endDate) {
      if (!startDate) return true;

      if (currentView !== "resourceTimeGridDay" && excludedDays.length > 0) {
        if (excludedDays.includes(startDate.getDay())) return false;
      }

      if (selectedTimeFrom || selectedTimeTo) {
        const evStartMins = startDate.getHours() * 60 + startDate.getMinutes();
        const evEndMins   = endDate ? (endDate.getHours() * 60 + endDate.getMinutes()) : evStartMins;

        if (selectedTimeFrom) {
          const [fh, fm] = selectedTimeFrom.split(":").map(Number);
          if (evEndMins <= fh * 60 + fm) return false;
        }
        if (selectedTimeTo) {
          const [th, tm] = selectedTimeTo.split(":").map(Number);
          if (evStartMins >= th * 60 + tm) return false;
        }
      }

      return true;
    }

    function getFilteredResources() {      
      return allUsers.filter(u => selectedUsers.includes(u.id));
    }

    function getVisibleUsersForSidebar() {
      const q = userSearchText.trim().toLowerCase();
      if (!q) return allUsers;

      return allUsers.filter(user =>
        user.title.toLowerCase().includes(q)
      );
    }

    function buildCalendar() {
      if (calendar) {
        currentDate = calendar.getDate();
        calendar.destroy();
      }

      const options = {
        schedulerLicenseKey: "GPL-My-Project-Is-Open-Source",
        initialView: currentView,
        initialDate: currentDate,
        height: "100%",
        nowIndicator: true,
        allDaySlot: true,
        dayMaxEvents: 4,
        moreLinkClick: "popover",
        slotMinTime: "00:00:00",
        slotMaxTime: "24:00:00",

        headerToolbar: {
          left: "prev,next today",
          center: "title",
          right: ""
        },

        events: function(info) {
          return $.ajax({
            type: "POST",
            url: '/calendar/fetch-availability-new',
            data: {
              tutors: selectedUsers,
              startDate: info.startStr,
              endDate: info.endStr
            }
          }).then(response => {
            console.log(response.availabilityArr);
            const events = Array.isArray(response.availabilityArr)
              ? response.availabilityArr
              : [];

            /** Reset colors */
            /** Always use tutor original calendar color */
            tutorColors = {};

            allUsers.forEach(function(user) {
              tutorColors[user.id] = user.color;
            });

            /** If API sends tutorColor then overwrite */
            events.forEach(event => {
              if (!event.resourceId) return;

              const tutorColor = event.tutorColor
                ? event.tutorColor.trim().toLowerCase()
                : "";

              const isWhiteColor =
                tutorColor === "#fff" ||
                tutorColor === "#ffffff" ||
                tutorColor === "white";

              if (tutorColor && !isWhiteColor) {
                tutorColors[event.resourceId] = event.tutorColor;
              } else {
                tutorColors[event.resourceId] = getColorFromId(event.resourceId);
              }
            });

            /** Re-render sidebar */
            renderUsers();

            return events.filter(ev => {
              const s = ev.start ? new Date(ev.start) : null;
              const e = ev.end   ? new Date(ev.end)   : null;
              return eventPassesFilters(s, e);
            });
          });
        },
        views: {
          timeGridWeek: {
            dayHeaderContent: function(args) {
              const day = args.date.getDate();
              const weekday = args.date.toLocaleDateString("en-US", { weekday: "short" });
              return day + " " + weekday;
            }
          },
          dayGridMonth: {
            dayMaxEvents: 4
          }
        },

        eventMouseEnter: function(info) {
          tooltip.style.display = "block";
          const startTime = info.event.start ? info.event.start.toLocaleTimeString() : '';
          const endTime = info.event.end ? info.event.end.toLocaleTimeString() : '';
          tooltip.innerHTML = `
            <strong>${info.event.title}</strong><br/>
            ${startTime} - ${endTime}
          `;
        },

        eventMouseLeave: function() {
          tooltip.style.display = "none";
        },

        eventContent: function(arg) {
          const startTime = arg.event.start
            ? arg.event.start.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true })
            : "";

          const endTime = arg.event.end
            ? arg.event.end.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true })
            : "";

          const extended = arg.event.extendedProps || {};
          // console.log("Event extended properties:", extended);
          const isAvailable = extended.isAvailable === true || extended.isAvailable === 'true' || extended.isAvailable === 1 || extended.isAvailable === '1';
          const isBooked = extended.isBooked === true || extended.isBooked === 'true' || extended.isBooked === 1 || extended.isBooked === '1';
          const startDate = arg.event.start
            ? `${arg.event.start.getFullYear()}-${String(arg.event.start.getMonth() + 1).padStart(2, '0')}-${String(arg.event.start.getDate()).padStart(2, '0')}`
            : '';
          const tutorId = extended.tutor_id || extended.resourceId || (arg.event.getResources ? (arg.event.getResources()[0]?.id || '') : '');
          const bookButton = isAvailable && !isBooked && tutorId && startDate && startTime
            ? `<button type="button" class="event-btn book-event-button" data-start-date="${startDate}" data-start-time="${startTime}" data-tutor-id="${tutorId}">Book an event</button>`
            : '';

          const currentCalendarView = calendar.view.type;
          const resourceId =
            extended.tutor_id ||
            extended.resourceId ||
            (arg.event.getResources ? (arg.event.getResources()[0]?.id || '') : '');

          const eventColor =
            tutorColors[resourceId] ||
            arg.event.backgroundColor ||
            "#22c55e";

          return {
            html: `
              <div 
                  class="custom-event"
                  style="
                    background:${eventColor};
                    border-left:4px solid ${eventColor};
                  "
              >
              ${
                currentCalendarView !== 'resourceTimeGridDay'
                  ? `
                    <div class="event-desc">
                     ${arg.event.extendedProps.tutorName || ''}
                    </div>
                  `
                  : ''
              }
              
                <div class="event-time">${startTime} - ${endTime}</div>
                <div class="event-title">${arg.event.title}</div>
                
                ${bookButton}
              </div>
            `
          };
        },

        eventDidMount: function(arg) {
          const button = arg.el.querySelector('.book-event-button');
          if (!button) return;

          button.addEventListener('click', function(event) {
            event.stopPropagation();
            const tutorId = button.dataset.tutorId;
            const startDate = button.dataset.startDate;
            const startTime = button.dataset.startTime;
            if (!tutorId || !startDate || !startTime) return;

            const url = `/calendar/add-new-event?start_date=${encodeURIComponent(startDate)}&start_time=${encodeURIComponent(startTime)}&tutor_id=${encodeURIComponent(tutorId)}`;
            window.location.href = url;
          });
        },


        // For Tooltip2
        eventClick: function(info) {
          if (calendar.view.type !== "timeGridWeek") return;

          activeEvent = info.event;
          activeEventEl = info.el;

          const extended = info.event.extendedProps || {};

          const startTime = info.event.start
            ? info.event.start.toLocaleTimeString('en-US', {
                hour: '2-digit',
                minute: '2-digit',
                hour12: true
              })
            : '';

          const endTime = info.event.end
            ? info.event.end.toLocaleTimeString('en-US', {
                hour: '2-digit',
                minute: '2-digit',
                hour12: true
              })
            : '';

          const isAvailable =
            extended.isAvailable === true ||
            extended.isAvailable === 'true' ||
            extended.isAvailable === 1 ||
            extended.isAvailable === '1';

          const isBooked =
            extended.isBooked === true ||
            extended.isBooked === 'true' ||
            extended.isBooked === 1 ||
            extended.isBooked === '1';

          const startDate = info.event.start
            ? `${info.event.start.getFullYear()}-${String(info.event.start.getMonth() + 1).padStart(2, '0')}-${String(info.event.start.getDate()).padStart(2, '0')}`
            : '';

          const tutorId =
            extended.tutor_id ||
            extended.resourceId ||
            (info.event.getResources
              ? (info.event.getResources()[0]?.id || '')
              : '');

          const bookButton =
            isAvailable && !isBooked && tutorId && startDate && startTime
              ? `
                <button
                  type="button"
                  class="event-btn book-event-button"
                  data-start-date="${startDate}"
                  data-start-time="${startTime}"
                  data-tutor-id="${tutorId}"
                >
                  Book an event
                </button>
              `
              : '';

          tooltip2.innerHTML = `
            <div class="custom-event-hover">

              ${extended.tutorName
                ? `<div class="event-desc">${extended.tutorName}</div>`
                : ''
              }

              <div class="event-time">${startTime} - ${endTime}</div>

              <div class="event-title">${info.event.title}</div>

              ${bookButton}

            </div>
          `;

          tooltip2.style.display = "block";

          const tooltipBookBtn = tooltip2.querySelector('.book-event-button');
          if (tooltipBookBtn) {
            tooltipBookBtn.addEventListener('click', function (e) {
              e.stopPropagation();
              const tId    = tooltipBookBtn.dataset.tutorId;
              const sDate  = tooltipBookBtn.dataset.startDate;
              const sTime  = tooltipBookBtn.dataset.startTime;
              if (!tId || !sDate || !sTime) return;

              const url = `/calendar/add-new-event?start_date=${encodeURIComponent(sDate)}&start_time=${encodeURIComponent(sTime)}&tutor_id=${encodeURIComponent(tId)}`;
              window.location.href = url;
            });
          }

          // wait for render
          setTimeout(() => {
            positionTooltip();
            bindScrollListeners();
          }, 0);
        },

        dayMinWidth: 150,
        stickyScrollbar: "bottom"
      };

      function positionTooltip() {
        if (!activeEventEl || tooltip2.style.display !== "block") return;
        const rect = activeEventEl.getBoundingClientRect();
        const tooltipWidth = tooltip2.offsetWidth || 200;
        let left = rect.left + (rect.width / 2) - (tooltipWidth / 2);
        let top = rect.bottom + 8;
        tooltip2.style.left = `${left}px`;
        tooltip2.style.top = `${top}px`;
      }

      function getScrollParents(element) {
        const parents = [];
        let parent = element?.parentElement;
        while (parent) {
          const style = window.getComputedStyle(parent);
          if (
            style.overflowY === "auto" ||
            style.overflowY === "scroll" ||
            style.overflowX === "auto" ||
            style.overflowX === "scroll"
          ) {
            parents.push(parent);
          }
          parent = parent.parentElement;
        }
        return parents;
      }

      function bindScrollListeners() {
        // remove old listeners
        scrollContainers.forEach(el => {
          el.removeEventListener("scroll", positionTooltip);
        });
        scrollContainers = getScrollParents(activeEventEl);
        // also include FullCalendar scrollers explicitly (important)
        document.querySelectorAll(".fc-scroller").forEach(el => {
          if (!scrollContainers.includes(el)) {
            scrollContainers.push(el);
          }
        });
        scrollContainers.forEach(el => {
          el.addEventListener("scroll", () => {
            requestAnimationFrame(positionTooltip);
          });
        });
      }
      

      if (currentView === "resourceTimeGridDay") {
        options.resources = getFilteredResources();
      }

      calendar = new FullCalendar.Calendar(calendarEl, options);
      calendar.render();
      viewSelect.value = currentView;
      syncDaysFilterVisibility();
    }

    document.addEventListener("click", function (e) {
      if (tooltip2.style.display !== "block") return;

      if (tooltip2.contains(e.target)) return;

      if (e.target.closest(".fc-event")) return;

      tooltip2.style.display = "none";
      activeEvent = null;
      activeEventEl = null;
    });

    
    

    viewSelect.addEventListener("change", function() {
      currentView = this.value;
      currentDate = new Date();

      calendar.changeView(currentView);
      syncDaysFilterVisibility();
    });

    function renderUsers() {
      syncSelectAllCheckbox();
      const visibleUsers = getVisibleUsersForSidebar();
      userList.innerHTML = "";

      if (visibleUsers.length === 0) {
        userList.innerHTML = `<div class="no-users">No users found</div>`;
        return;
      }

      visibleUsers.forEach(user => {
        const checked = selectedUsers.includes(user.id) ? "checked" : "";

        const row = document.createElement("label");
        row.className = "user-item";
        row.innerHTML = `
          <input type="checkbox" ${checked} data-id="${user.id}">
          <span class="user-dot" style="background:${tutorColors[user.id] || user.color}"></span>
          <span>${user.title}</span>
        `;

        row.querySelector("input").addEventListener("change", function() {
          const id = this.dataset.id;
          
          if (!this.checked && selectedUsers.length === 1) {
            this.checked = true;
            return;
          }

          if (this.checked) {
            if (!selectedUsers.includes(id)) selectedUsers.push(id);
          } else {
            selectedUsers = selectedUsers.filter(x => x !== id);
          }

          localStorage.setItem("availabilitySelectedTutors", JSON.stringify(selectedUsers));

          calendar.setOption('resources', getFilteredResources());
          calendar.refetchEvents();

          renderUsers();
        });

        userList.appendChild(row);
      });
    }

    userSearch.addEventListener("input", function() {
      userSearchText = this.value;
      renderUsers();
    });

    selectAllTutors.addEventListener("change", function() {

      if (this.checked) {
        selectedUsers = allUsers.map(user => user.id);
      } else {

        // keep at least one selected
        selectedUsers = allUsers.length > 0
          ? [allUsers[0].id]
          : [];
      }

      localStorage.setItem(
        "availabilitySelectedTutors",
        JSON.stringify(selectedUsers)
      );

      calendar.setOption('resources', getFilteredResources());
      calendar.refetchEvents();

      renderUsers();
    });

    initializeDateTimePicker();
    renderUsers();
    buildCalendar();

    function initializeDateTimePicker() {
      $('.time-range-picker').daterangepicker({
        timePicker: true,
        timePickerIncrement: 30,
        timePicker24Hour: false,
        locale: {
          format: 'hh:mm A'
        }
      });

      $('.time-range-picker').on('show.daterangepicker', function(ev, picker) {
        picker.container.addClass('TimeRangePicker');
      });

      $('.time-range-picker').on('apply.daterangepicker', function(ev, picker) {
        selectedTimeFrom = picker.startDate.format('HH:mm');
        selectedTimeTo   = picker.endDate.format('HH:mm');
        if (calendar) calendar.refetchEvents();
      });

      $('.time-range-picker').on('cancel.daterangepicker', function() {
        selectedTimeFrom = "";
        selectedTimeTo   = "";
        $(this).val('');
        if (calendar) calendar.refetchEvents();
      });
    }
   
    

    document.addEventListener("mousemove", function(e) {
      if (tooltip.style.display === "block") {
        tooltip.style.left = (e.clientX + 12) + "px";
        tooltip.style.top = (e.clientY + 12) + "px";
      }
    });
</script>