<script>
  $(function () {
    $('#tags-dropdown').on('click', 'button.dropdown-item', function () {
      let type = $(this).data('type');

      if (type === "all-families") {
        const allValues = $('#search-by-student option').map(function () {
          return $(this).val();
        }).get();
        $('#search-by-student').val(allValues).trigger('change');

      } else if (type === "family-tag") {
        let familyIds = $(this).data('families');
        if (familyIds) {
          const specificIds = familyIds.toString().split(",");
          $('#search-by-student').val(specificIds).trigger('change');
        }

      } else if (type === "clear") {
        $('#search-by-student').val(null).trigger('change');
      }

       $('#calendarGroupTag .dropdown-menu').slideUp(100).removeClass('show');
      $('#calendarGroupTag .dropdown-toggle').attr('aria-expanded', 'false');

      // Manage active class
      $('#tags-dropdown .dropdown-item').removeClass('active');
      if (type !== "clear") {
        $(this).addClass('active');
      }
    });
  });
</script>

