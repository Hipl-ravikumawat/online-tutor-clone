<!-- clone an event modal -->
<div class="modal fade common-modal modal-label-style" data-backdrop="static" id="cloneEventModal" tabindex="-1" role="dialog" aria-labelledby="cloneModalLabel" aria-hidden="true">
<div class="modal-dialog modal-lg modal-dialog-centered" role="document">
<div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title" id="cloneModalLabel">Clone An Event</h3>
    </div>
    <form id="clone-an-event" class="modal-form-area" method="post" action="/calendar/store-cloned-event">
      <div class="modal-body settings_content">
        <p>Are you sure you want to clone this event?</p>
        <div class="common-form">
          <input type="hidden" name="event_id_to_clone" id="event_id_to_clone" required>
          <div class="form-group position-relative dateRangeBlock mb-3 error-position">
            <label for="start_date">Event Date:</label>
            <input type="date" name="start_date" class="form-control dt-scheduling-conflict" value="<%=moment().add(0, 'days').format('YYYY-MM-D');%>" id="start_date">
            <span class="datecal-icons"><img src="/images/calendar.svg" alt=""></span>
          </div>
          <div class="form-group dateRangeBlock position-relative error-position">
            <label for="start_time">Event Time:</label>
            <input type="text" name="start_time" class="form-control clone-event-time dt-scheduling-conflict" id="start_time" autocomplete="off">
            <span class="datecal-icons"><img src="/images/timer.svg" alt=""></span>
          </div>
          <div class="col-md-12 conflict_area" id="conflict_area"></div>
        </div>
      </div>
      <div class="modal-footer">
        <div class="btn-leftarea"></div>
        <div class="btn-rightarea">
          <button type="button" class="bus-outline-btn" id="clone-event-cancel-btn" data-dismiss="modal">Cancel</button>
          <button type="submit" class="btn theme-btn" id="clone-event-save-btn">Submit</button>
        </div>
      </div>
    </form>
</div>
</div>
</div>
<!-- clone an event modal -->

