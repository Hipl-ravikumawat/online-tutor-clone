    $('.single-audio').dropify({
        tpl: {
            message: '<div class="dropify-message"><img src="/images/upload-video.svg"> <p class="text-dblue mt-4 mb-3">Drag & Drop here or <span class="text-orange fn-w600">Browse File</span></p><p class="text-dblue mt-4 mb-3">The max file size is 15MB</p><h6 class="mb-0 fn-12 text-dblue">Supported formats : (MP3,M4A)</h6></div>',
