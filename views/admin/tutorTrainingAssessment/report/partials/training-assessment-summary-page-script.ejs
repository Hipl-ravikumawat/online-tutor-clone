    optionDropIfy();

    window.onload = function () {
        interact(".drop-objects").draggable({
            // enable inertial throwing
            inertia: true,
            // keep the element within the area of it's parent
            autoScroll: true,
            // call this function on every drag move event
            onmove: dragMoveListener,
            // call this function on every dragend event
        });

        function dragMoveListener(event) {
            var target = event.target,
                // keep the dragged position in the data-x/data-y attributes
                x = (parseFloat(target.getAttribute("data-x")) || 0) + event.dx,
                y = (parseFloat(target.getAttribute("data-y")) || 0) + event.dy;

            // translate the element
            target.style.webkitTransform = target.style.transform =
                "translate(" + x + "px, " + y + "px)";

            // update the posiion attributes
            target.setAttribute("data-x", x);
            target.setAttribute("data-y", y);
        }

        // this is used later in the resizing and gesture demos
        window.dragMoveListener = dragMoveListener;
    };

    var helpers = {
        addZeros: function (n) {
            return (n < 10) ? '0' + n : '' + n;
        }
    };

     $(document).on('click', '.slide-anchor, .practice-anchor', function (event) {
        if(!$(this).hasClass("active")){
            $('.slide-anchor, .practice-anchor').removeClass('active');
            $('.slide-action li').removeClass('active');
            $(this).parents().addClass('active');
            $(this).addClass("active");
            currentTab = $(this).parent().data('position');          
            setPageCount();

            activeContentId = $(this).parent().data('uniqueid');
            activeContentLessonId = $(this).parent().data('lessonid');
            activeContentLessonSlug = $(this).parent().data('lessonslug');

            activeContentCourseId = $(this).parent().data('learningcontentid');
            activeContentCourseSlug = $(this).parent().data('learningcontentslug');

            renderSliderContent(activeContentCourseSlug, activeContentLessonSlug, activeContentLessonId, activeContentType, activeContentId);
        }  
    });

    function renderSliderContent(activeContentCourseSlug, activeContentLessonSlug, lessonId, activeContentType, activeContentId) {
        window.scrollTo(0, 0);
        $('.no-data-found').addClass('d-none');
        $('.unassign-nav').removeClass('d-none');
        $('.unassign-content').removeClass('preview-animation');
        $('.unassign-content').html('');
        if(activeContentId !== undefined){
            $.ajax({
            type: "POST",
            url: '/tutor-training-assessments/detailed-report/attempted-assessment-content-slider',
            data: {
                task_id : assessmentId,
                task_type : "assessment",
                tutor_id : tutorId,
                lesson_slug:activeContentLessonSlug,
                lesson_id: lessonId,
                type: activeContentType,
                content_id: activeContentId,
            },
            success: function (response) {              
                $('.unassign-content').addClass('preview-animation');
                $('.unassign-content').html(response.activeContentHtml);
                if ($(".para-gap").length > 0) {
                    let i = 1;
                    $(".para-gap").each(function () {
                        jQuery(this).attr("id", "answer-" + i);
                        jQuery(this).attr("data-index", i);
                        i++;
                    });  
                }                
            },
            error: function (response) {
                Swal.fire({
                    title: 'Oops...',
                    text: response.responseJSON.message,
                });
            },
            complete: function (result) {
                tinymce.init({
                    selector: '.editorExplanation',
                    content_style: 'body { font-family:Helvetica,Arial,sans-serif; font-size:16px }',
                    plugins: [
                        'advlist autolink lists link image charmap print preview anchor textcolor',
                        'searchreplace visualblocks code fullscreen',
                        'insertdatetime media table contextmenu paste code help wordcount,image code'
                    ],

                    mobile: {
                        theme: 'mobile'
                    },
                    toolbar: 'insert | undo redo  | code|  formatselect | bold italic strikethrough forecolor backcolor | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | removeformat | help|styleselect | fontsizeselect | underline ',
                    file_picker_types: 'file, image',

                    setup: function(editor) {
                    editor.on('Change Keyup', function () {
                        editor.save();
                    //tinyMCE.triggerSave() <-- also tried
                    });
                    }
                });
                   // DropIfy submit-attachment
                $('.submit-attachment').dropify({
                    tpl: {
                        message: '<div class="dropify-message"><span class="file-icon" /> <p class="text-dblue">Drag & Drop here size should be</p><p class="text-dblue mt-4 mb-3"> The max file size is 5MB</p><a class="d-inline-block mt-2 mb-3 theme-btn" href="javasript:void(0);">+ Attachments</a><h6 class="mb-0 fn-12 text-dblue">Supported formats : (PDF,PNG,JPG)</h6></div>',
                    },
                });

                let countPage = $('.total.pages').text();
                $('.tootip').css('cssText', '');
                $('[data-toggle="tooltip"]').tooltip('dispose'); 
                $('[data-toggle="tooltip"]').tooltip();            }
            });
        }else{
            $('.unassign-nav').addClass('d-none');
            $('.no-data-found').removeClass('d-none');
        }
    }

    function resetPreview(element, src = '', content = '', extension) {
        let wrapper = element.closest('.dropify-wrapper');
        let preview = wrapper.find('.dropify-preview');
        let filename = wrapper.find('.dropify-filename-inner');
        let fileExtension = wrapper.find('.dropify-extension');
        let render = wrapper.find('.dropify-render').html('');
        wrapper.removeClass('has-error').addClass('has-preview');
        if (src !== "" || extension == 'png') {
            src = window.location.origin + src;
            render.append($('<img class="previewfile"/>').attr('src', src).css('max-height', element.data('height') || ''));
            preview.fadeIn();
        } else {
            render.append($('<i class="dropify-font-file"></i><span class="dropify-extension">' + extension + '</span>'));
            preview.find('.dropify-filename-inner').html(content)
            preview.fadeIn();
        }
    }
    
    $(document).ready(function(){
        $(".courses-sidebar .card-header:first").addClass("arrow-active");
        $(".courses-sidebar .card-header").click(function(){
            $(".courses-sidebar .card-header").removeClass("arrow-active");
            $(this).addClass("arrow-active");
        });
    });
    /**
