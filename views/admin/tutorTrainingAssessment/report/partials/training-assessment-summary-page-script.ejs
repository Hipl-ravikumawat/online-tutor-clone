    // DropIfy video
    $('#video').dropify({
        tpl: {
            message: '<div class="dropify-message"><img src="/images/upload-video.svg"><p class="text-dblue mt-4 mb-3">Drag & Drop here or <span class="text-orange fn-w600">Browse File</span></p><p class="text-dblue mt-4 mb-3">The max file size is 5MB</p><h6 class="mb-0 fn-12 text-dblue">Supported formats : (MP4,MP3,M4A)</h6></div>',
        },
    });

    // DropIfy select-attachments
    $('.select-attachments').dropify({
        tpl: {
            message: '<div class="dropify-message"><a class="d-inline-block mt-2 mb-3 theme-btn" href="javasript:void(0);">+ Attachments</a><p class="text-dblue">Drag & Drop here size should be</p><p class="text-dblue mt-4 mb-3"> The max file size is 5MB</p><h6 class="mb-0 fn-12 text-dblue">Supported formats : (PDF,PNG)</h6></div>',
        },
    });
 
    // DropIfy select-attachment
    $('.single-img').dropify({
        tpl: {
            message: '<div class="dropify-message"><img src="/images/frame.svg" alt="img" width="40"> <p class="text-dblue">Drag & Drop here</p><h6 class="mb-0 mt-1 fn-12 text-dblue">Supported formats : (JPEG, PNG, SVG, etc.)</h6></div>',
        },
