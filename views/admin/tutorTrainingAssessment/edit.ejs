<!-- tutor-training-assessment creation page content starts-->
<div class="right_col" role="main">
    <div class="row main_row">
      <div class="x_panel form_panel">
        <div class="x_title">
          <h2 class="title-text">Edit Staff Course Assessment</h2>
        </div>
        <div class="x_content">

          <form id="storeTrainingContent" action="/tutor-training-assessments/update" method="post" class="form-horizontal form-label-left">
            <input type="hidden" name="tutor_assessment_id" value="<%=ObjectData.assessmentId%>">
            <div class="row">
              <div class="col-md-6 col-lg-6 col-xl-6">
                <div class="form-group">
                  <label class="col-form-label label-align" for="assessment">Assessment Name<span class="required">*</span>
                  </label>
                  <div class="input-group">
                    <span class="input-group-text"><img src="/images/assessment.svg" class="mCS_img_loaded"></span>
                    <input type="text" name="name" class="form-control" id="content_name" placeholder="Assessment Name" maxlength="200" value="<%=ObjectData.name%>">
                  </div>
                </div>
              </div>
              <div class="col-md-6 col-lg-6 col-xl-6">
                <div class="form-group">
                  <label class="col-form-label label-align" for="tutor_id">Tutors<span class="required">*</span>
                  </label>
                  <div class="input-group">
                    <span class="input-group-text"><img src="/images/student.svg" class="mCS_img_loaded"></span>
                    <select class="form-control select2" name="tutor_ids[]" id="tutor_ids" tabindex="-1"  data-placeholder="Select Tutor"  multiple>
                      <% for(tutor of tutors) { %>
                        <option value="<%=tutor.id%>" <% if (ObjectData.tutorIds.includes(tutor.id)) { %> selected <% } %>><%=tutor.first_name +" "+ tutor.last_name %></option>
                      <% } %>
                    </select>
                  </div>
                </div>
              </div>
            </div>
            <div class="row">
              <div class="col-md-12 mt-4">
                <h2 class="title-text fn-16">Staff Courses For Assessment</h2>
              </div>
              <div class="col-md-12 content_form" >  
                <div class="col-md-4">
                  <div class="form-group">
                    <label class="col-form-label label-align" for="topic">Topic <span class="required">*</span>
                    </label>
                    <div class="input-group">
                      <span class="input-group-text"><img src="/images/classes.svg" class="mCS_img_loaded"></span>
                      <select class="form-control select2 filter-content" id="sc_topic" tabindex="-1" single>
                        <option value="">Select A Topic</option>
                        <% for(topic of topics) { %>
                          <option value="<%=topic.id%>"><%=topic.name%></option>
                        <% } %>
                      </select>
                    </div>
                  </div>
                </div>      
                <div class="col-md-4">
                  <div class="form-group">
                    <label class="col-form-label label-align" for="sub_topic">Sub Topic</label>
                    <div class="input-group">
                      <span class="input-group-text"><img src="/images/classes.svg" class="mCS_img_loaded"></span>
                      <select class="form-control select2 filter-content" id="sc_sub_topic" tabindex="-1" single>
                        <option value="">Select A Sub Topic</option>
                      </select>
                    </div>
                  </div>
                </div>  
                <div class="col-md-4">
                  <div class="form-group">
                    <label class="col-form-label label-align" for="training_content">Staff Course <span
                        class="required">*</span>
                    </label>
                    <div class="input-group">
                      <span class="input-group-text"><img src="/images/courses.svg" class="mCS_img_loaded"></span>
                      <select class="form-control select2" id="training_content" tabindex="-1" single>
                        <option value="">Select Staff Course</option>
                      </select>
                    </div>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="form-group">
                    <label class="col-form-label label-align" for="select_lesson">Lessons <span class="required">*</span>
                    </label>
                    <div class="input-group">
                      <span class="input-group-text"><img src="/images/courses.svg" class="mCS_img_loaded"></span>
                      <select class="form-control select2" data-placeholder="Select Lessons"
                        id="lessons" tabindex="-1" multiple>
                        <option value="">Select Lessons</option>
                      </select>
                    </div>
                  </div>
                </div>
                <div class="col-md-4">
                  <label class="d-block">&nbsp;</span>
                  </label>
                  <button type="button" class="content-submit theme-btn" id="add_content">Add Content</button>
                </div>
              </div>
            </div>
            
            <div class="row">
                <div class="col-md-12 mt-4">
                  <h3 class="title-text fn-16">Assessment Content</h3>
                </div>
                <div class="col-sm-12">
                    <ul class="selectedcontent content-sortable" id="select-assessment">
                        <% if(ObjectData.data.content.length > 0) { 
                            let contentIndex = 0;
                        %>
                        <% for(let data of ObjectData.data.content) { %>
                          <% for(let content of data.lessons) { %>
                        <li class="sort-program" data-content-position="<%=contentIndex%>">
                            <div class="iconleft"><img src="/images/lesson.svg" alt="img"></div>
                            <div class="content-detail-block">
                                <ol class="breadcrumb">
                                    <li class="breadcrumb-item 1">
                                        <%=data.training_content_id.topic_id.name %>
                                    </li>
                                    <li class="breadcrumb-item 1">
                                        <%=data.training_content_id.title %>
                                    </li>
                                    <% if(data.training_content_id.sub_topic_id !== null) { %>
                                        <li class="breadcrumb-item 2"><%=data.training_content_id.sub_topic_id.name %></li>
                                    <% } %>
            
                                    <li class="breadcrumb-item 3 lesson-items" data-id="<%=content.lesson_id._id%>"><%=content.lesson_id.title %></li>
                                </ol>
                            </div>
                            <div class="action-right">
                                <a class="remove_content" href="javascript:void(0);">×</a>
                            </div>
                            <input type="hidden" name="original_lesson_id" class="original_lesson_id" value="<%=content.lesson_id.tutor_training_lesson_id%>">
                            <input type="hidden" name="selected_contents[]" value="<%= data.training_content_id._id %>--<%= content.lesson_id._id %>--version">
                        </li>
                    <% } } } %>
                    </ul>
                </div>
            </div>
            <div class="ln_solid"></div>
            <div class="text-right">
              <button type="submit" id="updateTrainingContentBtn" class="btn theme-btn" >Update</button>
            </div>
          </form>
        </div>
      </div>
    </div>
</div>
<!-- tutor-training-assessment creation page content end -->
<%- include('./partials/form_script'); %>
