    function resetPreview(element, src = '', content = '', extension) {
        let wrapper = element.closest('.dropify-wrapper');
        let preview = wrapper.find('.dropify-preview');
        let filename = wrapper.find('.dropify-filename-inner');
        let fileExtension = wrapper.find('.dropify-extension');
        let render = wrapper.find('.dropify-render').html('');
        wrapper.removeClass('has-error').addClass('has-preview');
        if (src !== "" || extension == 'png') {
            src = window.location.origin + src;
            render.append($('<img class="previewfile"/>').attr('src', src).css('max-height', element.data('height') || ''));
            preview.fadeIn();
        } else {
            render.append($('<i class="dropify-font-file"></i><span class="dropify-extension">' + extension + '</span>'));
            preview.find('.dropify-filename-inner').html(content)
            preview.fadeIn();
        }
    }
   
    $(document).on('submit', '#DragAndDropForm', function (event) {
        event.preventDefault();
        const options = []; 
        let lesson_id = $('.lesson_id').val();
        let practice_id = $('.practice_id').val();
        let url = $('#DragAndDropForm').attr('action');
        $('.para-gap').removeClass('answer-right');
        $('.para-gap').removeClass('answer-right');
        $('.drag-question-row').removeClass('answer-checked-right');
        $('.drag-question-row').removeClass('answer-checked-wrong');
        $('.answer-explanation').hide();
        $('.para-gap').each(function () {
            let text = $(this).find('.task').html();
            if (text) {
                options.push(text);
            }
        });
        $.ajax({
            type: "POST",
            url: url,
            dataType: "json",
            data: {
                lesson_id: lesson_id,
                practice_id: practice_id,
                answer: options,
            },
            success: function (response) {
                $('.slick-active').find('.assigment_id').val(response.homework_id);
                
                if (JSON.stringify(options) == JSON.stringify(response.correctAnswer)) {
                    $('.slick-active').find('.para-gap').addClass('answer-right');
                    $('.drag-question-row').has(".drag-question .task").toggleClass("answer-checked-right");
                } else {
                    $('.drag-question-row').has(".drag-question .task").toggleClass("answer-checked-wrong");
                    let i = 0;
                    for (option of options) {
                        if (option == response.correctAnswer[i]) {
                            $('.slick-active').find('.para-gap').eq(i).addClass('answer-right');
                        } else {
                            $('.slick-active').find('.para-gap').eq(i).addClass('answer-wrong');
                        }
                        i++;
                    }
                }
                $('.slick-active').find('.answer-explanation').show();

            },
            error: function (response) {

            },
            complete: function () {
            }
        })
    });
 
