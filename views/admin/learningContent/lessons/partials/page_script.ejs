    function drag_and_drop(doingIndex = 1) {

            let lastIndex = $(".para-gap").data('index');
            let length = $(".para-gap").length;
            let j = 1;
            $(".para-gap").each(function () {
                $(this).find('.index-number').text(j);
                j++;
            });

            let container = new Array();

            for (let i = 1; i <= length; i++) {
                let containt = document.getElementById("answer-" + lastIndex);
                container.push(containt);
                lastIndex++;
            }

            let containt = document.getElementById("doing-" + doingIndex);
            container.push(containt);

            drake = dragula(container, { revertOnSpill: true });

            drake.on('over', function (el, container, source) {
                if (container !== source && container.matches('.para-gap')) {
                    // moved from source to dropzone
                    if (container.children.length === 2) {
                        container.classList.add('invalid');
                    }
                }
            });

            drake.on('drop', function (el, target, source, sibling) {
                if (target.matches('.para-gap') && target.children.length > 2) {
                    drake.cancel();
                }
            });
      }


