<!-- slide modal starts -->
<div class="custum-modal modal-design" id="slideModal">
  <div class="modal-dialog modal-dialog-centered modal-xl">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Slide Form</h3>
        <button type="button" class="modal_close" data-dismiss="modal">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M6.04289 16.5413C5.65237 16.9318 5.65237 17.565 6.04289 17.9555C6.43342 18.346 7.06658 18.346 7.45711 17.9555L11.9987 13.4139L16.5408 17.956C16.9313 18.3466 17.5645 18.3466 17.955 17.956C18.3455 17.5655 18.3455 16.9323 17.955 16.5418L13.4129 11.9997L17.955 7.4576C18.3455 7.06707 18.3455 6.43391 17.955 6.04338C17.5645 5.65286 16.9313 5.65286 16.5408 6.04338L11.9987 10.5855L7.45711 6.0439C7.06658 5.65338 6.43342 5.65338 6.04289 6.0439C5.65237 6.43442 5.65237 7.06759 6.04289 7.45811L10.5845 11.9997L6.04289 16.5413Z" fill="currentColor"></path></svg>
        </button>
      </div>
      <form method="post" action="/learning-content/<%=learningContent.slug%>/lessons/<%=lesson.slug%>/slides/store" id="storeSlideForm" enctype="multipart/form-data" autocomplete="off">
        <div class="modal-body">
          <input type="hidden" name="slide_id" id="update_data" value="">
          <input type="hidden" name="content_directory" id="content_directory"value="<%=learningContent.content_directory%>">
          <div class="form-group">
            <label for="title">Title <span class="text-red">*</span></label>
            <input type="text" class="form-control" placeholder="Enter Title" name="title" id="title">
          </div>

          <div class="form-group">
            <label for="duration">Duration <span class="text-red">*</span></label>
            <input type="text" class="form-control timepicker" placeholder="Enter Duration" name="duration" id="duration">
          </div>

          <div class="form-group">
            <label for="description">Description <span class="text-red">*</span></label>
            <textarea class="form-control editor" placeholder="Enter Description" name="description"
              id="description"></textarea>
          </div>

          <div class="form-group">
            <label for="video_url">Video Url</label>
            <input type="url" class="form-control" placeholder="Enter Video URL" name="video_url" id="video_url">
          </div>

          <div class="row">
            <div class="col-sm-12 col-md-6">
              <div class="form-group dropblock">
                <label for="video" class="w-100 text-left">Upload Video</label>
                <input type="file" class="form-control h-auto" id="video" data-allowed-file-extensions="mp4 mp3 m4a"
                  data-max-file-size-preview="35M" data-max-file-size="35M" name="video" value="">
                <input type="hidden" name="is_video_remove" id="is_video_removed" value="0">
              </div>
            </div>

            <div class="col-sm-12 col-md-6">
              <div class="form-group dropblock">
                <label class="form-label w-100 text-left">Upload Attachment</label>
                <input type="file" class="form-control select-attachments h-auto"
                  data-allowed-file-extensions="pdf png" data-max-file-size-preview="15M" name="attachments" data-max-file-size="15M" id="attachments"
                  data-default-file="">
                <input type="hidden" name="is_attachment_remove" id="is_attachment_removed" value="0">
              </div>
            </div>
          </div>

        </div>
        <div class="modal-footer">
          <button type="submit" class="theme-btn" id="storeSlideBtn">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>
<!-- slide modal end -->
