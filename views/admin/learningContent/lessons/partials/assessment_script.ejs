    $(document).on("click", ".submit_question", async function () {
        $this = $(this).parents(".unassign-content");
        let practiceArray = [];
        let submittedAnswer = [];
        let practiceId = $this.find(".practice_id").val();
        let practiceType = $this.find(".practice_type").val();
        let answer = "";
        let attachment = "";
        if (practiceType == "single_select") {
            answer = $this.find(".custom-option:checked").val();
            submittedAnswer.push(answer);
        } else if (practiceType == "multi_select") {
            var select_button_text = $this
                .find(":checkbox:checked")
                .toArray()
                .map((item) => item.value);
            submittedAnswer = select_button_text;
        } else if (practiceType == "text") {
            tinyMCE.triggerSave();
            answer = $this.find(".editorExplanation").val();
            let form = $("#textForm");
            let formData = new FormData(form[0]);
            formData.append('submit_attachment', this.new_attachments);
            let fileData = formData.get('submit_attachment');
            if(fileData.name){
                attachment = await uploadTextQuestionAttachment(formData);
            }
            submittedAnswer.push(answer);
        } else if (practiceType == "drag_and_drop") {
            var textValues = $this
                .find(".para-gap")
                .map(function () {
                return $(this).find(".task").text();
                })
                .get();
            submittedAnswer = textValues;
            $(".answer-submitted").show(1).delay(1000).hide(1);
        }
        let lessonContent = JSON.parse(localStorage.getItem("assessmentDetails"));
        if (lessonContent != "") {
        for (question of lessonContent) {
            if (question.questionId == practiceId) {
                question.submittedAnswer = submittedAnswer;
                question.attachment = attachment;
                break;
            }
        }
            localStorage.setItem("assessmentDetails", JSON.stringify(lessonContent));
        }
        // console.log(submittedAnswer,'submittedAnswer')
        const totalSortPractices = $('.sort-practices').length;
        const currentMenuIndex = $('.sort-practices.active').data('position');
        // console.log(totalSortPractices,'totalSortPractices',currentMenuIndex);
        $(".unassign-next").trigger("click");
        if(totalSortPractices === currentMenuIndex){
            $('#submit-assessment').modal("show");
        }
    });


    $(".quit_and_save").click(async function () {
        $("#submit-assessment").modal('hide');
        let question_content_type = $(".question_content_type").val();
        getLocalStorageData = JSON.parse(localStorage.getItem("assessmentDetails"));
        $(".full-result-tag").attr("data-type", question_content_type);
        $(".full-result-tag").attr("data-lesson-id", lessonId);
        Swal.fire({
        html: "<p><b>Do you want to quit the assessment in middle?</b><br>Your given answers will be saved but your assessment will not be submitted.</p>",
        icon: "warning",
        showDenyButton: true,
        confirmButtonText: "Yes",
        denyButtonText: `No`,
        }).then((result) => {
        if (result.isConfirmed) {
            saveAndQuitPractice(getLocalStorageData);
        } else {
            console.log("denied");
        }
        });
    });


    function saveAndQuitPractice(getLocalStorageData) {
        $.ajax({
            type: "POST",
            url: `/assessments/save-assessment`,
            data: {
                getData: getLocalStorageData,
                lesson_id: lessonId,
                assessment_id: assessmentId,
            },
            dataType: "json",
            success: function (response) {
                if (response.success) {
                    let message = response.message;
                    successAlertMessage(message);
                }
            },
        });
    }


    function submitChallenge() {
        let assessmentDetail = JSON.parse(localStorage.getItem("assessmentDetails"));
        let postData = null;
        if (assessmentType == "challenges") {
            let challengeAttempts = JSON.parse(localStorage.getItem("challengeAttempts")) ?? {};
            postData = {
                assessmentType: assessmentType,
                assessmentId: taskId,
                lessonId: lessonId,
                challengeId: activeContentId,
                challengeAttempts: challengeAttempts,
            };
        } 
        else {
            postData = {
                assessmentDetail: assessmentDetail,
                assessmentType: assessmentType,
                assessmentId: assessmentId,
                lessonId: lessonId,
            };
        }
        $.ajax({
            type: "POST",
            url: "/assessments/submit-assessment",
            data: postData,
            dataType: "json",
            success: function (response) {
                window.location.href = "/assessments"
            },
            error: function (response) {
                Swal.fire({
                title: "Oops...",
                text: response.message,
                });
            },
            complete: function () {
            },
        });
    }


    function showResult(submitChallenge, question_content_type = "", lesson_id = "", challenge_id = "") {
        Swal.fire({
            text: "Do you want to submit this assessment?",
            icon: "warning",
            showDenyButton: true,
            confirmButtonText: "Yes",
            denyButtonText: `No`,
        }).then((result) => {
            /* Read more about isConfirmed, isDenied below */
            if (result.isConfirmed) {
                submitChallenge();
            }
        });
    }


