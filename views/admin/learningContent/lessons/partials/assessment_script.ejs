    function successAlertMessage(message){
        Swal.fire({
            title: 'Success!',
            html:`<p>${message}</p>`,
            icon: 'success',
            showDenyButton: false,
            denyButtonText: `No`,
            allowOutsideClick: false,
        }).then((result) => {
            window.location.href = "/assessments";
        })
    }

    function uploadTextQuestionAttachment(formData) {
        return new Promise((resolve, reject) => {
            $.ajax({
                type: "POST",
                url: `/assessments/upload-attachment`,
                dataType: "json",
                data: formData,
                processData: false, // Prevent jQuery from processing the formData object
                contentType: false, // Prevent jQuery from setting the content type
                success: function (response) {
                    if (response.success) {
                        const filename = response.file;
                        resolve(filename);
                    } else {
                        reject(new Error("Upload failed")); // Reject the promise with an error
                    }
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    reject(new Error(`AJAX error: ${textStatus}, ${errorThrown}`)); // Reject on network errors
                }
            });
        });
    }
    
    function saveAndSubmitButton(){
        const swalWithBootstrapButtons = Swal.mixin({
