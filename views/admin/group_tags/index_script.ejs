
<script type="text/javascript">
  /**
   * grade index page script.
   * @script start
   * */
  $(document).ready(function () {
    $(".select2").select2({ allowClear: false });
    dataTable();

    $(".filter").click(function () {
      let grade_name = $("#grade-name").val();
      let status = $("#status").val();
      dataTable(grade_name, status);
    });

    $(".reset").click(function () {
      $(".select2").val(null).trigger("change");
      dataTable();
    });
  });

  function dataTable(name = "", status = "") {
    $.fn.dataTable.moment("DD:MM:YYYY HH:mm a");
    $("#groupTagsTable").dataTable().fnDestroy();

    var groupTagsTable = $("#groupTagsTable").DataTable({
      paging: true,
      pageLength: 10,
      language: {
        searchPlaceholder: "Search",
        processing: "<div><div></div><div></div><div></div><div></div></div>",
      },
      processing: true,
      serverSide: true,
      order: [[2, "desc"]],
      ajax: {
        url: "/group-tags/dataTable",
        type: "POST",
        data: {
          id: name,
          status: status,
        },
      },
      columns: [
        { data: "name", name: "name" },
        { 
          data: "student_ids", 
          render: function(data, type, row){
            return data.map((c) => { return `${c.first_name} ${c.last_name}`; }).filter(Boolean).join("; ");
          } 
        },
        { data: "color",
          render: function(data, type, row){
            let colorTag = `<span class="badge" style="background-color:${row.colorRecord.background_color};color:${row.colorRecord.color}">${row.colorRecord.label}</span>`;
            return colorTag;
          }
        },
        { 
          data: "description", 
          render: function (data, type, row) {
            return "-";
          }
        },
        {
          data: "students_total",
          render: function (data, type, row) {
            return row.student_ids.length;
          },
        },
        {
          data: "",
          render: function (data, type, row) {
            return `<div class="d-flex align-items-center table_action_btn">
                      <a class="" href="/group-tags/edit/${row.slug}" data-toggle="tooltip" rel="tooltip" data-placement="top"
                          title="Edit"><img src="/images/edit.svg" alt="icon"></a>
    
                      <a href="javascript:void(0)"
                          onclick="confirmBeforeDeletion('/group-tags/destroy/${row._id}')"><img src="/images/trash.svg"
                          alt="icon" data-toggle="tooltip" rel="tooltip" data-placement="top" title="Delete"></a>
                      </div>`;
          },
        },
      ],
      columnDefs: [
        {
          targets: [1,3] /* column index */,
          orderable: false /* true or false */,
        },
      ],
    });
    groupTagsTable.ajax.reload( function() {
      // Reinitialize tooltips after reload
      $('[data-toggle="tooltip"]').tooltip('dispose'); 
      $('[data-toggle="tooltip"]').tooltip();
    });
  }
    /**
   * grade index page script.
   * @script end
   * */
</script>
