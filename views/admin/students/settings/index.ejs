    // ===============================
    // intlTelInput helper
    // ===============================
    function initTel($input, numberObj) {
      // Destroy previous instance if exists
      if ($input.data("iti")) {
        $input.data("iti").destroy();
        $input.removeData("iti");
      }

      const iti = window.intlTelInput($input[0], {
        separateDialCode: true,
        initialCountry: numberObj?.iso_code || "au",
      });

      $input.data("iti", iti);

      // If editing with data from API (set number first)
      if (numberObj && numberObj.dial_code && numberObj.phone) {
        iti.setNumber("+" + numberObj.dial_code + numberObj.phone);
      }

      // --- sync hidden fields ---
      function syncHiddenFields() {
        const countryData = iti.getSelectedCountryData();
        const inputId = $input.attr("id"); // e.g. "mobile_number"

        // hidden field IDs follow same prefix
        $(`#${inputId}_dial_code`).val(countryData.dialCode);
        $(`#${inputId}_iso_code`).val(countryData.iso2);

        // get current number without dial code
        const fullNumber = iti.getNumber();
        let phoneOnly = fullNumber.replace("+" + countryData.dialCode, "").trim();

        $input.val(phoneOnly);
      }

      // Ensure hidden fields are synced after number is set
      setTimeout(syncHiddenFields, 100);

      // Sync on every change
      $input.off(".itiEvents").on("countrychange.itiEvents keyup.itiEvents change.itiEvents blur.itiEvents", function () {
        syncHiddenFields();
      });
    }


