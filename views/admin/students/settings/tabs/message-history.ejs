
<div class="tab-pane fade message-history-tab" id="message-history" role="tabpanel" aria-labelledby="message-history-tab">
    <div class="row mx-0 row-gap-30">
      <div class="col-12 px-0">
        <div class="card tabcard">
            <div class="card-body">
                <div class="setting_title">
                  <h3 class="m-0">Messages</h3>
                  <div class="drop-down table_filter_dropdown">
                    <div class="selected">
                        <a href="javascript:void(0)" class="item-selected">
                          Last 3 Months
                        </a>
                    </div>
                    <div class="drop-options" style="display: none;">
                        <ul>
                          <li><a href="#"  >Last 3 Months</a></li>
                          <li><a href="#">Last 6 Months</a></li>
                          <li><a href="#">Last Year</a></li>
                          <li><a href="#">Entire History</a></li>
                        </ul>
                    </div>
                  </div>
                  <!-- <div class="dropdown">
                    <button class="dropdown-toggle btn theme-btn new-msg-btn" type="button" data-toggle="dropdown" aria-expanded="false">
                      New Message
                    </button>
                    <div class="dropdown-menu dropdown-menu-right">
                      <a class="dropdown-item" href="#">Email Student</a>
                      <a class="dropdown-item" href="#">Email All</a>
                    </div>
                  </div> -->
                </div>
                <div class="settings mt-10px">
                  <!-- <div class="blank-family-msg-history blank-family-cont">
                    <div class="bfamily-img text-center py-4">
                      <img src="/images/message-history-blank.svg" alt="Message History">
                    </div>
                    <h3>You haven't scheduled any upcoming emails</h3>
                    <div class="dropdown text-center">
                      <% if(userRole === 3){ %>
                      <button class="dropdown-toggle btn theme-btn new-msg-btn position-relative" type="button" data-toggle="dropdown" aria-expanded="false">
                        Create New Message
                      </button>
                      <% } %>
                      <div class="dropdown-menu dropdown-menu-right">
                        <a class="dropdown-item" href="#">Email Student</a>
                        <a class="dropdown-item" href="#">Email All</a>
                      </div>
                    </div>
                  </div> -->
                  <div class="x_panel message_full_panel p-0">
                    <div class="x_title mb-3">
                      <div class="left-btns">
                        <ul>
                          <li class="both-btnli">
                            <div class="dropdown">
                              <button class="bus-outline-btn dropdown-toggle" type="button" data-toggle="dropdown" aria-expanded="false">
                                + New Message
                              </button>
                              <div class="dropdown-menu">
                                <!-- Student -->
                                <button type="button" class="dropdown-item open-new-message" 
                                        data-id="<%= currentStudent._id %>" 
                                        data-send-to="student">
                                  <svg width="16" height="16"></svg>
                                  Email Student
                                </button>
                              
                                <!-- Family contacts -->
                                <% (familyContacts || []).forEach(function(contact){ %>
                                  <% if (contact.user_id) { %>
                                    <button type="button" class="dropdown-item open-new-message" 
                                            data-id="<%= currentStudent._id %>" 
                                            data-family-id="<%= contact.user_id._id %>" 
                                            data-send-to="family"
                                    >
                                      <svg width="16" height="16"></svg>
                                      Email 
                                      <% if (contact.user_id.first_name && contact.user_id.last_name) { %>
                                        <%= contact.user_id.first_name %> <%= contact.user_id.last_name %>
                                      <% } else { %>
                                        <%= contact.user_id.company_name %>
                                      <% } %>
                                      <% if (contact.user_id.relationship) { %>
                                        (<%= contact.user_id.relationship %>)
                                      <% } %>
                                    </button>
                                  <% } %>
                                <% }) %>
                                <!-- Email All (student + all family contacts) -->
                                <button type="button" class="dropdown-item open-new-message" 
                                        data-type="all" 
                                        data-id="<%= currentStudent._id %>" 
                                        data-send-to="all">
                                  <svg width="16" height="16"></svg>
                                  Email All
                                </button>

                              </div>
                            </div>

                          </li>
                        </ul>
                      </div>
                      <ul class="right-btns settings_content">
                          <li class="both-btnli">
                            <div class="dropdown short_dropdown" id="transactions-sort-dropdown">
                              <button class="bus-outline-btn dropdown-toggle" type="button" data-toggle="dropdown"  aria-expanded="false">
                                <img src="/images/short-icon.svg" alt="Setting"  class="mr-2">Sort
                              </button>
                              <div class="dropdown-menu">
                                <button type="button" class="dropdown-item shortbtn sort-trigger" data-column="">Clear Sort</button>
                                <button type="button" class="dropdown-item sort-trigger" data-column-name="date" data-column="0" data-order="1" >Date</button>
                              </div>
                            </div>
                          </li>
                          <li class="search_box searchDropdownCount both-btnli search_btn" id="familyTransactionDropdown">
                            <div class="dropdown">
                              <button class="bus-outline-btn dropdown-toggle" type="button" data-toggle="dropdown" aria-expanded="false">
                                  <img src="/images/search-icon.svg" alt="Search" class="mr-2">
                                  Search
                                  <span class="sounts" style="display: none;"></span>
                              </button>
                              <div class="dropdown-menu dropdown-menu-area dropdown-menu-right">
                                <form id="familyTransactionSearchForm">
                                    <div class="position-relative form-group">
                                        <input type="search" name="category_search" class="form-control" placeholder="Search by subject & sender-receiver" />
                                        <img src="/images/search-icon.svg" alt="Search" class="search_drop_icon">
                                    </div>
                                    <div class="form-group mt-20 mb-20">
                                      <label class="form-label" for="by_type">By Type</label>
                                      <select name="by_type" id="by_type" class="form-control search-input">
                                        <option value="all">All</option>
                                        <option value="email">Email</option>
                                        <option value="sms">SMS</option>
                                      </select>
                                    </div>
                                    <div class="form-group form-check">
                                        <input class="form-check-input" type="checkbox" value="1" id="message_body" name="message_body">
                                        <label class="form-check-label" for="message_body">Search within the message body</label>
                                    </div>
                                    <div class="d-flex mt-20">
                                        <button type="button" class="btn form-button cancel-btn theme-btn cancel-event mr-3 w-100">Clear</button>
                                        <button type="submit" class="btn theme-btn w-100">Search</button>
                                    </div>
                                </form>
                              </div>
                            </div>
                          </li>
                      </ul>
                    </div>
                    <div class="x_content">
                      <div class="card-box table-responsive">
                        <table id="studentmsghistory" class="table table-striped table-bordered dt-responsive nowrap color_first_td" cellspacing="0" width="100%">
                          <thead>
                            <tr>
                              <th>Subject</th>
                              <th>Type</th>
                              <th>Date & Time</th>
                              <th>To</th>
                              <th>From</th>
                              <th>Status</th>
                              <th>Action</th>
                            </tr>
                          </thead>
                          <tbody>
                              
                          </tbody>
                        </table>
                      </div>
                    </div>
                  </div>
                </div>
            </div>
        </div>
      </div>
    </div>
</div>

 <!-- // Forward email modal  -->

 <div class="modal fade common-modal" data-backdrop="static" id="forwardMessageModal" tabindex="-1" role="dialog" aria-labelledby="forwardMessageModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered max-928 normal_form_block" role="document">
    <div class="modal-content form-wizard">
      <div class="modal-header">
        <h3 class="modal-title title_style" id="forwardMessageModalLabel">Forward Message</h3>
        <button type="button" class="close p-0 m-0 opacity-100 inner_modal_close" data-dismiss="modal" aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M18 6L6 18" stroke="#4A4674" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M6 6L18 18" stroke="#4A4674" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
      <form class="form-design" method="post" id="forwardMessageForm">
        <input type="hidden" name="messageId" id="forwardMessageId" />
        <div class="modal-body form_normal settings_content">

          <div class="form-group">
            <label for="from_mail" class="form-label">From</label>
            <select name="from_mail" id="from_mail" class="form-control select2">
              <% (sentFrom || []).forEach(function(user, index) { %>
                <option value="<%= user.value %>" <%= index === 0 ? 'selected' : '' %>>
                  <%= user.label %> &lt;<%= user.value %>&gt;
                </option>
              <% }); %>
            </select>
            <div class="invalid-feedback d-block text-danger" id="error-from_mail"></div>
          </div>

          <div class="form-group">
            <label for="to_mail" class="form-label">To</label>
            <select name="to_mail[]" id="to_mail" class="form-control select2" multiple="multiple">
              <% (toEmails || []).forEach(function(user, index) { %>
                <option value="<%= user.value %>" <%= index === 0 ? 'selected' : '' %>>
                  <%= user.label %> &lt;<%= user.value %>&gt;
                </option>
              <% }); %>
            </select>
            <div class="invalid-feedback d-block text-danger" id="error-to_mail"></div>
          </div>

          <div class="form-group form-check">
            <input class="form-check-input" type="checkbox" value="1" id="cc_email" name="cc_email">
            <label class="form-check-label d-inline-block" for="cc_email">CC me on this Email</label>
          </div>

          <div class="form-group">
            <label for="subject_field" class="form-label">Subject</label>
            <input type="text" name="subject" id="subject_field" class="form-control" />
            <div class="invalid-feedback d-block text-danger" id="error-subject"></div>
          </div>

          <div class="form-group">
            <label for="message-notes" class="form-label">Message</label>
            <textarea class="message-notes" name="message" id="message-notes"></textarea>
            <div class="invalid-feedback d-block text-danger" id="error-message"></div>
          </div>

          <div class="main_stud_info mt-4">
            <h6>Attachments</h6>
            <div id="fm-attachments" class="stud_info stud_attached_info">
              <div class="text-muted">No attachments</div>
            </div>
          </div>
        </div>


        <div class="modal-footer">
          <div class="d-flex w-100">
            <button type="button" data-dismiss="modal" class="btn form-button cancel-btn theme-btn cancel-event mr-3 w-100 min-h-40">Cancel</button>
            <button type="submit" class="btn theme-btn w-100 min-h-40 mb-0 send-email-btn">Send</button>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

 <!-- view message modal  -->

 <div class="modal fade common-modal" id="viewMessageModal" tabindex="-1" role="dialog" aria-labelledby="viewMessageModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
    <div class="modal-content border-0 shadow-none">
      <div class="modal-header">
        <h3 class="modal-title title_style">View Message</h3>
        <button type="button" class="close p-0 m-0 opacity-100 inner_modal_close" data-dismiss="modal" aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M18 6L6 18" stroke="#4A4674" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            <path d="M6 6L18 18" stroke="#4A4674" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>

      <div class="modal-body stud_message_details view_message_content_body">
        <div class="main_stud_info">
          <h6>Subject</h6>
          <div id="vm-subject" class="stud_info"></div>
        </div>
        <div class="main_stud_info">
          <h6>Recipients</h6>
          <div id="vm-recipients" class="stud_info"></div>
        </div>
        <div class="main_stud_info">
          <h6>Message</h6>
          <div id="vm-message" class="stud_info view_message_content"></div>
        </div>
        <div class="main_stud_info">
          <h6>Attachments</h6>
          <div id="vm-attachments" class="stud_info stud_attached_info"></div>
        </div>
      </div>
    </div>
  </div>
</div>


<script src="/vendors/tinymce/tinymce.min.js"></script>

<script type="text/javascript">
  $(document).ready(function () {
    const $blankUI = $(".blank-family-msg-history");
    const $tableWrapper = $(".message_full_panel");
    const $modal = $("#forwardMessageModal");
    const $form = $("#forwardMessageForm");

    // === Helpers ===
    const resetSendBtn = (loading = false) => {
      $(".send-email-btn")
        .text(loading ? "Sending..." : "Send")
        .prop("disabled", loading);
    };

    const $tableContainer = $("#studentmsghistory").closest(".card-box");

    // === AJAX ===
    async function fetchMessageData(params) {
      return $.post("/student-preferences/message-history/get-data", params).then(
        (res) => res,
        (err) => {
          console.error("Error fetching message data", err);
          return { success: false };
        }
      );
    }

    async function sendMessage(formData) {
      return $.post("/student-preferences/message-history/forward-message", formData)
       .then((res) => res)
      .catch((xhr) => {
        if (xhr.status === 422 && xhr.responseJSON) {
          return xhr.responseJSON; // <-- keep the errors
        }
        console.error("Failed to send message", xhr);
        return { success: false };
      });
    }

    // === DataTable ===
    function initDataTable() {
      $.fn.dataTable.moment("DD:MM:YYYY HH:mm a");
      $("#studentmsghistory").DataTable({
        serverSide: true,
        destroy: true,
        paging: true,
        pageLength: 10,
        autoWidth: false,
        order: [[0, "desc"]],
        dom: '<"table-responsive x-responsive"t><"bottom_table_field"<""l><""i><""p>>r',
        ajax: {
          url: "/student-preferences/message-history",
          type: "POST",
          data: (d) => $.extend({}, d, { studentId: "<%= currentStudent.id %>", months: window.currentFilter , by_type: $("#by_type").val(),                  // dropdown
          message_body: $("#message_body").is(":checked") ? 1 : 0 ,category_search: $('input[name="category_search"]').val()}),
          dataSrc: (res) => {
            // toggleUI(res.success && res.data.length > 0, res.message);
            return res.success && res.data ? res.data : [];
          },
        },
        columns: [
          {
            data: "subject",
            render: (d, type, row) => `<a href="#" class="view-message" data-id="${row._id}">${d || "-"}</a>`,
          },
          {
            data: "type",
            render: (d) => {
              if (!d) return "";
              return `<span class="badge badge-${d.toLowerCase()}">${d}</span>`;
            },
          },
          {
            data: "sentAt",
            render: (d) => d ? moment(d).format("DD-MM-YYYY<br>HH:mm") : ""
          },
          {
            data: "receiver",
            render: (to) =>
              to ? `${to.name || ""} <br> [${to.email || to.phone || ""}]` : "",
          },
          {
            data: "sender",
            render: (from) =>
              from ? `${from.name || ""} <br> [${from.email || ""}]` : "",
          },
          { data: "status", render: (d) => (d ? `<span>Sent</span>` : "") },
          {
            data: null,
            render: (row) => `
              <div class="dropdown table_dropdown">
                <a href="javascript:void(0);" class="forward-message" 
                  data-id="${row._id}" title="Forward">
                  <img src="../images/forward-icon.svg" alt="Forward" />
                </a>
              </div>`,
          },
        ],
      });
    }

    // === Modal Populate ===
    function populateModal(data, isNew = false) {
      $("#forwardMessageModalLabel").text(isNew ? "New Message" : "Forward Message");
      $("#forwardMessageId").val(isNew ? "" : data._id || "");
      $("#subject_field").val(isNew ? "" : data.subject || "");
      tinymce.get("message-notes")?.setContent(
        isNew ? "" : data.messageBody || ""
      );

      // Recipients
      const $toMail = $("#to_mail").empty();
      (data.toEmails || []).forEach((item) => {
        $toMail.append(
          `<option value="${item.value}">${item.label} &lt;${item.value}&gt;</option>`
        );
      });
      
      if (data.sendTo) {
        if (data.sendTo === "all") {
          // Select only student + family (skip logged-in/me)
          const valuesToSelect = data.toEmails
            .filter(e => e.type === "student" || e.type === "family" || e.type === "me")
            .map(e => e.value);

          $toMail.val(valuesToSelect).trigger("change");
        } else {
          // Select only the first email for student or family
          $toMail.val(
            isNew && data.toEmails.length > 0 ? [data.toEmails[0].value] : []
          ).trigger("change");
        }
      } else {
        // Fallback: no pre-selection
        $toMail.val([]).trigger("change");
      }

      if (!$toMail.hasClass("select2-hidden-accessible")) {
        $toMail.select2({ placeholder: "Select recipients", multiple: true, width: "100%" });
      }

      $("#from_mail").val($("#from_mail option:first").val()).trigger("change");

      // Attachments
      if (!isNew && (data.transactionId || data.invoiceId)) {
        const fileName = data.invoiceId
          ? `Invoice-${data.invoiceId}`
          : `Transaction-${data.transactionId}`;
        const viewLink = data.invoiceId
          ? `/student/message-history/generate/pdf/${data.invoiceId}`
          : `/student/message-history/download-transaction/pdf/${data.transactionId}`;
        $("#fm-attachments").html(`
          <div class="stud_file_name"><img src="/images/file.svg" alt="file"> ${fileName}</div>
          <div class="stud_action_btns">
            <a href="${viewLink}" target="_blank"><img src="/images/view-declined.svg"> View</a>
            <a href="${viewLink}?download=true"><img src="/images/download-orange2.svg"> Download</a>
          </div>
        `);
      } else {
         $("#fm-attachments").closest(".main_stud_info").hide();
      }

      $modal.modal("show");
    }

    // === Event Handlers ===
    $(document).on("click", ".forward-message", async function () {
      const messageId = $(this).data("id");
      const res = await fetchMessageData({ type: "forward", messageId });
      if (res.success) populateModal(res.data, false);
    });

    $(document).on("click", ".open-new-message", async function () {
      const res = await fetchMessageData({
        type: "new-msg",
        userId: $(this).data("id"),
        familyId: $(this).data("family-id"),
        sendTo: $(this).attr('data-send-to'),
      });
      if (res.success) populateModal(res.data, true);
    });

    $form.on("submit", async function (e) {
      e.preventDefault();
      resetSendBtn(true);

      tinymce.triggerSave();
      const formData = $(this).serializeArray().reduce((acc, { name, value }) => {
        acc[name] = acc[name] ? [].concat(acc[name], value) : value;
        return acc;
      }, {});


      const res = await sendMessage(formData);
      resetSendBtn(false);
      if (res.success) {
        $modal.modal("hide");
        $("#studentmsghistory").DataTable().ajax.reload();
      } else if (res.errors) {
          // Show validation errors under fields
           $(".invalid-feedback").text("");
  $(".form-control").removeClass("is-invalid");

  res.errors.forEach(err => {
    // Map param -> field IDs
    const fieldMap = {
      from_mail: "from_mail",
      to_mail: "to_mail",
      subject: "subject_field",
      message: "message-notes"
    };

    const fieldId = fieldMap[err.param];
    if (fieldId) {
      // Add red border
      $(`#${fieldId}`).addClass("is-invalid");
      // Show error text
      $(`#error-${err.param}`).text(err.msg);
    }
  
          });
        } else {
          console.log("Something went wrong. Please try again.");
        }
    });

    // === TinyMCE ===
    tinymce.init({
      selector: "#message-notes",
      menubar: false,
      statusbar: false,
      height: 300,
      plugins: "lists link code table",
      toolbar: "undo redo | bold italic underline | bullist numlist | link table | code",
      branding: false,
      setup: (editor) => {
        editor.on("change", () => tinymce.triggerSave());
      },
    });

    // Init Table
    window.currentFilter = 3; // Default to last 3 months

   initDataTable();

  // === Dropdown Filter ===
    $(document).on("click", ".table_filter_dropdown .item-selected", function (e) {
      e.preventDefault();
      const $dropOptions = $(this).closest(".table_filter_dropdown").find(".drop-options");

      $(".table_filter_dropdown .drop-options").not($dropOptions).hide();

      $dropOptions.toggle();
    });

    $(document).on("click", ".table_filter_dropdown .drop-options a", function (e) {
      e.preventDefault();

      $(".table_filter_dropdown .drop-options a").removeClass("active");
      $(this).addClass("active");

      $(".table_filter_dropdown .item-selected").text($(this).text());

      $(this).closest(".drop-options").hide();

      const text = $(this).text().trim();
      switch (text) {
        case "Last 3 Months":
          window.currentFilter = 3;
          break;
        case "Last 6 Months":
          window.currentFilter = 6;
          break;
        case "Last Year":
          window.currentFilter = 12;
          break;
        case "Entire History":
          window.currentFilter = "all";
          break;
        default:
          window.currentFilter = 3; 
      }

      $("#studentmsghistory").DataTable().ajax.reload();
    });

    $(document).on("click", ".sort-trigger", function() {
  const column = $(this).data("column");
  const order = $(this).data("order");

  if (column === "") {
    $("#studentmsghistory").DataTable().order([]).draw();
  } else {
    $("#studentmsghistory").DataTable().order([column, order == 1 ? "asc" : "desc"]).draw();
  }
});

    $(document).on("click", function (e) {
      if (!$(e.target).closest(".table_filter_dropdown").length) {
        $(".table_filter_dropdown .drop-options").hide();
      }
    });

    $(document).on("submit", "#familyTransactionSearchForm", function(e) {
      e.preventDefault();
      $("#studentmsghistory").DataTable().ajax.reload();
    });
    $(document).on("click", "#familyTransactionSearchForm .cancel-btn", function(e) {
      e.preventDefault();

      const $form = $(this).closest("form");

      // Reset all inputs
      $form[0].reset();
      $form.find("#by_type").val("all");
      $form.find("#message_body").prop("checked", false);

      // Reload DataTable
      $("#studentmsghistory").DataTable().ajax.reload();
    });

    // view message modal
    $(document).on('click', '.view-message', function(e) {
      e.preventDefault();

      const table = $('#studentmsghistory').DataTable();
      const rowData = table.row($(this).closest('tr')).data();
      if (!rowData) return;

      // Subject
      $('#vm-subject').text(rowData.subject || '-');

      // Recipients
      let recipients = '-';
      if (rowData.receiver) {
        recipients = rowData.receiver.email || rowData.receiver.name || '-';
      }
      $('#vm-recipients').text(recipients);

      // Message
      $('#vm-message').html(rowData.messageBody || '-');

     // Attachments
      const meta = rowData.meta;
      if (meta && (meta.transactionId || meta.invoiceId)) {
        const viewLink = meta.invoiceId
          ? `/student/message-history/generate/pdf/${meta.invoiceId}`
          : `/student/message-history/download-transaction/pdf/${meta.transactionId}`;

        const fileName = meta.invoiceId
          ? `Invoice-${meta.invoiceId}`
          : `Transaction-${meta.transactionId}`;

        $('#vm-attachments').html(`
          <div class="stud_file_name"><img src="/images/file.svg" alt="file"> ${fileName}</div>
          <div class="stud_action_btns">
            <a href="${viewLink}" target="_blank"><img src="/images/view-declined.svg" alt="View"> View</a>
            <a href="${viewLink}?download=true"><img src="/images/download-orange2.svg" alt="Download"> Download</a>
          </div>
        `).closest('.main_stud_info').show();
      } else {
        // hide the entire attachments block
        $('#vm-attachments').closest('.main_stud_info').hide();
      }

      $('#viewMessageModal').modal('show');
    });


});
</script>



