<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css">
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>

<script type="text/javascript">
  const studentId = "<%=currentStudent._id%>";
  $(document).ready(function () {
    renderStudentRecordDataTable();
  });

  $(function () {
    $('.dateQuickselect').daterangepicker({
      ranges: {
        'Today': [moment(), moment()],
        'Yesterday': [moment().subtract(1, 'days'), moment().subtract(1, 'days')],
        'Last 7 Days': [moment().subtract(6, 'days'), moment()],
        'Last 30 Days': [moment().subtract(29, 'days'), moment()],
        'This Month': [moment().startOf('month'), moment().endOf('month')],
        'Last Month': [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')]
      },
      alwaysShowCalendars: true,
      locale: {
        cancelLabel: 'Clear',
        applyLabel: 'Select',
      },

    }, function (start, end, label) {
      $('#dateRangeblock').val(start.format('DD/MM/YYYY') + ' - ' + end.format('DD/MM/YYYY'));
    });

  $('#dateRangeblock').daterangepicker({
    opens: 'left',
    format: 'DD/MM/YYYY',
  });

  $('.student-atte-tabledate').daterangepicker({
    singleDatePicker: true,
    showDropdowns: true,
    minYear: 1901,
    maxYear: parseInt(moment().format('YYYY'), 10)
  });
  });

  function renderStudentRecordDataTable() {
    var gradeTable = $('#studentRecord').DataTable({
      "paging": true,
      "pageLength": 10,
      "language": {
        "searchPlaceholder": "Search",
        "processing": '<div><div></div><div></div><div></div><div></div></div>'
      },
      "processing": true,
      "serverSide": true,
      "ordering": false,
      'ajax': {
        'url': '/student-preferences/students-attendance-notes-datatable',
        'type': 'POST',
        'data': {
          studentId: studentId
        },
      },
      "drawCallback": function (settings) { },
      'columns': [
        {
          data: "event_id",
          "render": function (data, type, row) {
            let html = '';
            if (data) {
              let startTime = moment(data.start_time).format('h:mm A');
              let endTime = moment(data.end_time).format('h:mm A');
              let date = moment(data.start_time).format('D MMM YYYY');
              html = `<p>${date} <br/> <span>${startTime} - ${endTime}</span></p>`
            }
            return html;
          }
        },
        {
          data: "event_id",
          "render": function (data, type, row) {
            return data ? `${data.duration} min` : '';
          }
        },
        {
          data: "tutor",
          "render": function (data, type, row) {
            return data ? `${data.first_name} ${data.last_name}` : '';
          }
        },
        // {
        //     data: "event_id",
        //     "render": function (data, type, row) {
        //       return data ? `${data.event_category_id.name}` : '';
        //     }
        // },
        {
          data: "attendees",
          "render": function (data, type, row) {
            let attendance = data[0].status;
            if (attendance !== '') {
              attendance = attendance.charAt(0).toUpperCase() + attendance.slice(1);
            }
            let status = data[0].std_was_late ? 'Student was late' : data[0].std_absent_billing_option ? 'Billable' : 'Not Billable';
            return `${attendance} (${status})`;
          }
        },
        {
          data: "group_note_id",
          "render": function (data, type, row) {
            let html = 'N/A';
            if(data){
              html = `<a href="javascript:void(0)" data-id="${data}" onclick="studentsNoteAndAttachments(this)" class="attachnote" data-toggle="modal" data-target="#AttendanceNoteAttach"><img src="/images/clipboard.svg" alt=""></a>`;
            }
            return html;
          }
        },
      ],
    });
  }

  function studentsNoteAndAttachments(element) {
    let groupNoteId = $(element).data('id');
    $.ajax({
      type: "POST",
      url: '/student-preferences/students-note-attachments',
      data: {
        groupNoteId: groupNoteId
      },
      success: function (response) {
        $('.st-notes').html(response);
      }
    });
  }

  $('.btn.theme-btn').click(function () {
    $('.error, .serve-error').remove();
  });

  $(document).on('click', '.create-report-btn', function (event) {
    event.preventDefault();
    $('.error, .serve-error').remove();

    let dateRange = $('#dateRangeblock').val();
    const anyChecked = $('input[name="note_report[]"]:checked').length > 0;
    let isValid = true;

    if (dateRange == '') {
      isValid = false;
      $("#dateRangeblock").after('<span class="error" style="color:red;">Please choose date</span>');
    }

    if (!anyChecked) {
      isValid = false;
      $(".settinglist").after('<span class="error" style="color:red;">Please choose at least one checkbox</span>');
    }

    if (isValid) {
      $(".create-report-btn").prop('disabled', true).text('Generating report...');
      $.ajax({
        url: $("#attendance-report-form").attr('action'),
        method: "POST",
        data: $("#attendance-report-form").serialize(),
        success: function (response) {
          if (response.success && response.pdfUrl) {
            const link = document.createElement('a');
            link.href = response.pdfUrl;
            link.download = 'attendance_report.pdf';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link)
          } else {
            alert('Error: Unable to generate the report.');
          }
        },
        error: function (response) {
          $(".dateRangeBlock").after(`<span class="serve-error" style="color:red;margin-top: -20px;">${response.responseJSON.error}</span>`);
        },
        complete: function () {
          $(".create-report-btn").prop('disabled', false).text('Generate Report');
        }
      });
    }
  });
</script>