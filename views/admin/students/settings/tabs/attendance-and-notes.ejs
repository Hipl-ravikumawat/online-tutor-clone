                </div>
              </div>
              <div class="col col-block">
                <div class="attendance-box">
                  <span class="attendance-number">
                    <%=studentEventData.absent%>
                  </span>
                  <p class="student-record">Student Absences</p>
                </div>
              </div>
              <div class="col col-block">
                <div class="attendance-box">
