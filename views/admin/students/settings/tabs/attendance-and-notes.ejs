          <div class="settings">
            <div class="row row-gap-20">
              <div class="col col-block">
                <div class="attendance-box">
                  <div class="full-attendance-area">
                    <%=studentEventData.percentage%>%
                  </div>
                </div>
              </div>
              <div class="col col-block">
                <div class="attendance-box">
                  <span class="attendance-number">
                    <%=studentEventData.present%>
                  </span>
