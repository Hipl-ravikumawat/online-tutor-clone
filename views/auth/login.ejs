<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title> <%=process.env.APP_NAME%></title>

  <link href="/vendors/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendors/font-awesome/css/font-awesome.min.css" rel="stylesheet">

  <link href="/build/css/main.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/noty/3.1.4/noty.min.css" rel="stylesheet" />
</head>
<body class="h-100">
    <%- include('../partials/_loader'); %>
  <div class="login">
    <a class="hiddenanchor" id="signup"></a>
    <a class="hiddenanchor" id="signin"></a>
    <div class="login-blocks">
      <a href="javascript:void(0);" class="logo-top"><img class="mr-2" src="/images/logo.svg"> <span><%=process.env.APP_NAME%></span></a>
      <div class="auth-left">
        <img src="/images/auth-left.png" alt="img" />
      </div>
      <div class="login-form">
        <form action="./sign-in" method="post" class="loginForm">
          <h1>Login</h1>
          <p>Hey, Enter your details to get sign in to your account</p>
          <div class="form-group">
            <span class="icon-left"><img src="/images/email2.svg"></span>
            <input type="text" class="form-control email" placeholder="Email or Username" name="email" required="" />
          </div>
          <div class="form-group">
            <span class="icon-left"><img src="/images/lock2.svg"></span>
            <input type="password" class="form-control password" placeholder="Password" name="password" required="" id="password" />
            <span toggle="#password" class="fa fa-fw fa-eye field-icon form-control-feedback right toggle-password"></span>
          </div>
          <div class="row">
            <div class="col-6 text-left pr-0">
              <input class="styled-checkbox remember-me" id="styled-checkbox-2" type="checkbox" value="1" name="remember">
              <label for="styled-checkbox-2">Remember Me</label>
            </div>
            <div class="col-6 text-right pl-0">
              <a class="link-text mt-0" href="/forget-password">Forgot Password?</a>
            </div>
            <div class="col-md-12">
              <button type="submit" class="btn theme-btn ">Login</button>
            </div>
          </div>
          <div class="or_sign text-center my-4"><span>Or Sign in with</span></div>
          <div class="both_login">
            <a href="#" class="other_login"><img src="/images/google.svg">Google</a>
            <a href="#" class="other_login"><img src="/images/facebook.svg">Facebook</a>
          </div>
        </form>
        <p class="auth_copyright">Copyright ©HIPL Tutor 2026 | <a href="#">Privacy Policy</a></p>
      </div> 
      <div class="auth-left auth-right">
        <img src="/images/auth-right.png" alt="img" />
      </div>
    </div>  
  </div>

<script type="text/javascript" src="https://code.jquery.com/jquery-1.11.0.min.js"></script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/noty/3.1.4/noty.min.js"></script>

<script type="text/javascript">

// Show flash messages (normal page load)
<% if (flash.success && flash.success.length > 0) { %>
new Noty({
  theme: 'relax',
  text: '<%= flash.success %>',
  type: 'success',
  layout: 'topRight',
  timeout: 1500
}).show();
<% } %>

<% if (flash.error && flash.error.length > 0) { %>
new Noty({
  theme: 'relax',
  text: '<%= flash.error %>',
  type: 'error',
  layout: 'topRight',
  timeout: 1500
}).show();
<% } %>

// Show/Hide Password
$(".toggle-password").click(function () {
  $(this).toggleClass("fa-eye fa-eye-slash");
  var input = $($(this).attr("toggle"));
  input.attr("type", input.attr("type") === "password" ? "text" : "password");
});

// Load Remember Me Data
$(document).ready(function () {
  let getStorageData = localStorage.getItem('rememberMe');
  if (getStorageData !== null) {
    try {
      const decoded = atob(getStorageData);
      const data = JSON.parse(decoded);

      $('.email').val(data.email);
      $('.password').val(data.password);
      $('.remember-me').prop('checked', true);

    } catch (err) {
      localStorage.removeItem('rememberMe');
    }
    $('.loader').hide();
  } else {
    setTimeout(() => {
      $('.loginForm')[0].reset();
      $('.loader').hide();
    }, 800);
  }
});

// AJAX Login
$(".loginForm").submit(function (e) {
  e.preventDefault();

  const url = $(".loginForm").attr("action");
  const serializedArray = $(".loginForm").serializeArray();
  const formData = $(".loginForm").serialize();

  const serializedObject = serializedArray.reduce((obj, { name, value }) => {
    obj[name] = value;
    return obj;
  }, {});

  $.ajax({
    type: "POST",
    url: url,
    dataType: "json",
    data: formData,

    success: function (response) {
      if (response.success === true) {

        // Remember Me Save
        if (serializedObject.remember === "1") {
          const base64EncodedData = btoa(JSON.stringify(serializedObject));
          localStorage.setItem("rememberMe", base64EncodedData);
        } else {
          localStorage.removeItem("rememberMe");
        }

        window.location.href = response.redirectUrl;
      } else {
        // 💥 Show Incorrect Credentials Error Without Page Reload
        new Noty({
          theme: "relax",
          text: response.message || "Incorrect Email or Password",
          type: "error",
          layout: "topRight",
          timeout: 2000
        }).show();
      }
    },

    // Passport sends status 400 for login failure → handle here
    error: function (xhr) {
      let msg = "Incorrect Email or Password";

      if (xhr.responseJSON && xhr.responseJSON.message) {
        msg = xhr.responseJSON.message;
      }

      new Noty({
        theme: "relax",
        text: msg,
        type: "error",
        layout: "topRight",
        timeout: 2000
      }).show();
    },

    complete: function () {
      $('.theme-btn').attr('disabled', false);
      $('.spinner').html('');
    }
  });
});

</script>

</body>
</html>